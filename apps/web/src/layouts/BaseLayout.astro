---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Toast from '../components/Toast.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import {
  resolveTenant,
  getSiteSettings,
  getImageUrl,
  buildTenantCssVars,
} from '../lib/cms';

interface Props {
  title?: string;
  description?: string;
  /** Pass a pre-resolved tenantId to avoid double-resolving in parent pages */
  tenantId?: number | string;
  /** Pass pre-fetched siteSettings to avoid double-fetch */
  siteSettings?: any;
  /** Pass the full tenant object to avoid resolving twice, or it will auto-resolve */
  tenant?: any;
}

const { title, description, tenantId: propTenantId, siteSettings: propSiteSettings, tenant: propTenant } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// ── Tenant Resolution ──────────────────────────────────────────
// Resolve once per request; use cached result if passed from parent or in-memory cache
const hostname = Astro.url.hostname + (Astro.url.port ? `:${Astro.url.port}` : '');
const tenant = propTenant ?? await resolveTenant(hostname);
const tenantId = propTenantId ?? tenant?.id;

// ── Site Settings ──────────────────────────────────────────────
const siteSettings = propSiteSettings ?? (tenantId ? await getSiteSettings(tenantId, lang) : null);
const logoUrl = siteSettings?.logo ? getImageUrl(siteSettings.logo) : '';

// ── CSS Theme Variables ────────────────────────────────────────
// Build from Tenants collection (preferred) or fallback
const themeTenant = tenant ?? (tenantId ? { id: tenantId } : null);
const cssVars = buildTenantCssVars(
  // Merge: tenant styling takes precedence, siteSettings is data
  tenant || {
    primaryColor: '#D4AF37',
    primaryDarkColor: '#b5952f',
    secondaryColor: '#FFDF00',
    backgroundDarkColor: '#121212',
    surfaceDarkColor: '#1e1e1e',
    navbarBgColor: '#D4AF37',
    buttonColor: '#D4AF37',
    fontFamily: 'Inter',
  }
);

// ── SEO ────────────────────────────────────────────────────────
const siteTitle = title
  ? `${title} | ${siteSettings?.metaTitle || tenant?.name || 'Logam Mulia'}`
  : (siteSettings?.metaTitle || t('nav.home') + ` | ${tenant?.name || 'Logam Mulia'}`);

const siteDescription = description || siteSettings?.metaDescription || t('services.desc');

// OG Image: use CMS-uploaded ogImage or fallback to static
const ogImageUrl = siteSettings?.ogImage
  ? getImageUrl(siteSettings.ogImage)
  : new URL('/img/og_image.webp', Astro.url).toString();

// Favicons: use CMS-uploaded or fallback to static
const faviconSvgUrl = siteSettings?.faviconSvg ? getImageUrl(siteSettings.faviconSvg) : '/favicon.svg';
const faviconIcoUrl = siteSettings?.faviconIco ? getImageUrl(siteSettings.faviconIco) : '/favicon.ico';

// Font for Google Fonts
const fontName = tenant?.fontFamily || 'Inter';
const googleFontUrl = `https://fonts.googleapis.com/css2?family=${fontName.replace(/ /g, '+')}:wght@400;500;600;700;800&display=swap`;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Theme Color (uses tenant primary) -->
    <meta name="theme-color" content={tenant?.primaryColor || '#D4AF37'} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={tenant?.backgroundDarkColor || '#121212'} media="(prefers-color-scheme: dark)" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href={faviconIcoUrl} />
    <link rel="icon" type="image/svg+xml" href={faviconSvgUrl} />
    <link rel="apple-touch-icon" href={faviconSvgUrl} />

    <!-- Fonts — loaded dynamically from tenant fontFamily setting -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href={googleFontUrl} as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href={googleFontUrl} /></noscript>

    <!-- 🎨 Tenant CSS Custom Properties — injected server-side, no FOUC -->
    <style is:inline set:html={`
      :root:root {
${cssVars}
      }
    `}></style>

    {siteSettings?.googleSearchConsoleCode && (
      <meta name="google-site-verification" content={siteSettings.googleSearchConsoleCode} />
    )}

    {siteSettings?.googleAnalyticsId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${siteSettings.googleAnalyticsId}`} />
        <script>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', `${siteSettings.googleAnalyticsId}`);
        </script>
      </>
    )}
  </head>
  <body class="bg-gray-50 dark:bg-background-dark font-sans text-gray-900 dark:text-white min-h-screen flex flex-col">
    <Navbar logoUrl={logoUrl} tenantId={tenantId} siteSettings={siteSettings} tenantName={tenant?.name} />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer logoUrl={logoUrl} tenantId={tenantId} siteSettings={siteSettings} tenantName={tenant?.name} />
    <Toast />
    <script>
      import { langStore } from '../lib/lang';
      import { ui } from '../i18n/ui';

      const serverLang = document.documentElement.lang as any;
      if (serverLang) {
        langStore.set(serverLang);
      }

      langStore.subscribe((lang) => {
        document.documentElement.lang = lang;
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (key && ui[lang] && (ui[lang] as any)[key]) {
            el.textContent = (ui[lang] as any)[key];
          }
        });
      });
    </script>
  </body>
</html>
