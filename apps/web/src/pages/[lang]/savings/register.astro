---
import SavingsRegisterComponent from '../../../components/pages/SavingsRegister.astro';
import { getTenantForBuild } from '../../../lib/cache';

export async function getStaticPaths() {
  const tenant = await getTenantForBuild();
  if (!tenant?.enableGoldSavings) {
    return [];
  }
  const isMY = import.meta.env.PUBLIC_TENANT_REGION === 'MY';
  return [
    { params: { lang: 'en' } },
    ...(!isMY ? [{ params: { lang: 'my' } }] : []),
  ];
}

---
<SavingsRegisterComponent />
