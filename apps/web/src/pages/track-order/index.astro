---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('nav.track')}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 min-h-[70vh]">
    <!-- Header -->
    <div class="mb-10 text-center md:text-left">
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-2" data-i18n="track.title">
        {t('track.title')}
      </h1>
      <p class="text-gray-500 dark:text-gray-400 font-medium" data-i18n="track.subtitle">
        {t('track.subtitle')}
      </p>
    </div>

    <!-- Search Box -->
    <div class="bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 mb-8">
      <form id="track-form" class="flex flex-col md:flex-row gap-4">
        <input 
          id="track-input"
          type="text" 
          placeholder="ORD-5U617SD8" 
          class="flex-1 px-4 py-3.5 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-[#f59e0b] focus:border-[#f59e0b] outline-none text-gray-900 dark:text-white transition-all font-medium" 
          required 
        />
        <button 
          id="track-btn"
          type="submit" 
          class="bg-[#f59e0b] hover:bg-[#d97706] text-white font-bold py-3.5 px-8 rounded-xl transition-colors shadow-sm flex items-center justify-center whitespace-nowrap"
        >
          <span id="btn-text">Search</span>
          <svg id="btn-icon" class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>
      </form>
      <div id="error-message" class="text-red-500 text-sm mt-3 font-medium hidden">
        Pesanan tidak ditemukan. Pastikan Order ID atau Nomor Resi sudah benar.
      </div>
    </div>

    <!-- Order History (Logged in users only) -->
    <div id="order-history-section" class="hidden mb-12">
      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
        <span class="w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center text-base">📦</span>
        <span data-i18n="track.order_history">{t('track.order_history')}</span>
      </h3>
      <div id="order-history-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Injected via JS -->
      </div>
      <div id="no-history" class="hidden text-center py-12 bg-white dark:bg-surface-dark rounded-2xl border border-dashed border-gray-200 dark:border-gray-800">
        <p class="text-gray-500" data-i18n="track.no_orders">{t('track.no_orders')}</p>
      </div>
    </div>

    <!-- Result Card -->
    <div id="result-card" class="bg-white dark:bg-surface-dark rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden hidden transition-all duration-500 opacity-0 transform translate-y-4">
      
      <!-- Top Header -->
      <div class="p-6 md:p-8 border-b border-gray-100 dark:border-gray-800">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-2">
          <h2 id="res-order-id" class="text-xl font-bold text-gray-900 dark:text-white uppercase">ORD-XXXXX</h2>
          <span id="res-status" class="px-4 py-1.5 rounded-full text-sm font-bold bg-yellow-100 text-yellow-800 border border-yellow-200">
            Belum Dibayar
          </span>
        </div>
        <p class="text-gray-500 text-sm font-medium">Pusat</p>
      </div>

      <!-- Items List -->
      <div class="p-6 md:p-8 border-b border-gray-100 dark:border-gray-800">
        <div id="res-items" class="space-y-4">
          <!-- Injected via JS -->
        </div>
      </div>

      <!-- Details Grid -->
      <div class="p-6 md:p-8 border-b border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-8 text-sm">
          <div class="flex justify-between md:block">
            <span class="text-gray-500 mb-1 md:block">Courier:</span>
            <span id="res-courier" class="font-bold text-gray-900 dark:text-white text-right md:text-left">SICEPAT</span>
          </div>
          <div class="flex justify-between md:block">
            <span class="text-gray-500 mb-1 md:block">Payment:</span>
            <span id="res-payment" class="font-bold text-gray-900 dark:text-white text-right md:text-left">BCA DIGITAL</span>
          </div>
          <div class="flex justify-between md:block">
            <span class="text-gray-500 mb-1 md:block">Phone Number:</span>
            <span id="res-phone" class="font-bold text-gray-900 dark:text-white text-right md:text-left">628123232323</span>
          </div>
          <div class="flex flex-col md:col-span-2 mt-2 md:mt-0">
            <span class="text-gray-500 mb-1">Shipping Address:</span>
            <span id="res-address" class="font-bold text-gray-900 dark:text-white leading-relaxed">
              dawdad, dawd, dawdaw, dwadwa, dawdaw
            </span>
          </div>
        </div>
      </div>

      <!-- Total -->
      <div class="p-6 md:p-8 border-b border-gray-100 dark:border-gray-800 flex justify-between items-center">
        <span class="text-lg font-bold text-gray-900 dark:text-white">Total:</span>
        <span id="res-total" class="text-xl md:text-2xl font-black text-[#d97706]">Rp17.225.000</span>
      </div>

      <!-- Payment Proof -->
      <div class="p-6 md:p-8 bg-gray-50 dark:bg-gray-900">
        <h3 class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-4">PAYMENT PROOF</h3>
        <div id="res-proof-container">
          <img id="res-proof-img" src="" alt="Payment Proof" class="max-w-xs w-full rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 object-cover" />
        </div>
        <div id="res-no-proof" class="hidden text-sm font-medium text-gray-500 italic">
          Belum ada bukti pembayaran yang diunggah.
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const formatCurrency = (val: number) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(val);

  const getStatusBadge = (status: string) => {
    switch(status) {
      case 'Pending': return '<span class="px-4 py-1.5 rounded-full text-sm font-bold bg-yellow-100 text-yellow-800 border border-yellow-200">Belum Dibayar</span>';
      case 'Paid': return '<span class="px-4 py-1.5 rounded-full text-sm font-bold bg-blue-100 text-blue-800 border border-blue-200">Pembayaran Dikonfirmasi</span>';
      case 'Shipped': return '<span class="px-4 py-1.5 rounded-full text-sm font-bold bg-green-100 text-green-800 border border-green-200">Sedang Dikirim</span>';
      case 'Completed': return '<span class="px-4 py-1.5 rounded-full text-sm font-bold bg-emerald-100 text-emerald-800 border border-emerald-200">Selesai</span>';
      case 'Cancelled': return '<span class="px-4 py-1.5 rounded-full text-sm font-bold bg-red-100 text-red-800 border border-red-200">Dibatalkan</span>';
      default: return `<span class="px-4 py-1.5 rounded-full text-sm font-bold bg-gray-100 text-gray-800 border border-gray-200">${status}</span>`;
    }
  };

  import { supabase } from '../../lib/supabase';
  import { CMS_URL } from '../../lib/cms';

  const form = document.getElementById('track-form');
  const input = document.getElementById('track-input') as HTMLInputElement;
  const btn = document.getElementById('track-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const errorMsg = document.getElementById('error-message');
  const resultCard = document.getElementById('result-card');
  const historySection = document.getElementById('order-history-section');
  const historyList = document.getElementById('order-history-list');
  const noHistory = document.getElementById('no-history');

  // Fetch Order History for Logged-In User
  const initHistory = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (session?.user) {
      try {
        const res = await fetch(`${CMS_URL}/api/transactions?where[supabaseUserId][equals]=${session.user.id}&sort=-createdAt&limit=5`);
        const data = await res.json();
        
        if (data.docs && data.docs.length > 0) {
          historySection?.classList.remove('hidden');
          if (historyList) {
            historyList.innerHTML = data.docs.map((order: any) => `
              <button class="history-item text-left p-5 bg-white dark:bg-surface-dark border border-gray-100 dark:border-gray-800 rounded-2xl hover:border-primary/50 hover:shadow-md transition-all group" data-id="${order.orderId}">
                <div class="flex justify-between items-start mb-3">
                  <span class="text-xs font-black text-gray-400 uppercase tracking-widest">${order.orderId}</span>
                  ${getStatusBadge(order.status)}
                </div>
                <div class="flex justify-between items-end">
                  <div>
                    <p class="text-sm font-bold text-gray-900 dark:text-white line-clamp-1">${order.items?.[0]?.productName || 'Produk'}${order.items?.length > 1 ? ` +${order.items.length - 1}` : ''}</p>
                    <p class="text-xs text-gray-500 mt-1">${new Date(order.createdAt).toLocaleDateString()}</p>
                  </div>
                  <p class="text-sm font-black text-primary">${formatCurrency(order.total)}</p>
                </div>
              </button>
            `).join('');

            // Add click events to history items
            document.querySelectorAll('.history-item').forEach(item => {
              item.addEventListener('click', () => {
                const id = (item as HTMLElement).dataset.id;
                if (id) {
                  input.value = id;
                  form?.dispatchEvent(new Event('submit'));
                }
              });
            });
          }
        } else {
          // Optional: show "no history" if desired
          // historySection?.classList.remove('hidden');
          // noHistory?.classList.remove('hidden');
        }
      } catch (e) {
        console.error('Failed to fetch history:', e);
      }
    }
  };

  initHistory();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const query = input.value.trim();
    if (!query) return;

    // Reset UI
    errorMsg?.classList.add('hidden');
    resultCard?.classList.add('hidden', 'opacity-0', 'translate-y-4');
    
    // Hide history when searching
    historySection?.classList.add('hidden');
    
    if (btn && btnText) {
      btn.disabled = true;
      btnText.innerText = 'Mencari...';
      btn.classList.add('opacity-70');
    }

    try {
      // Query CMS API (or query by orderId or trackingNumber)
      const res = await fetch(`${CMS_URL}/api/transactions?where[or][0][orderId][equals]=${query}&where[or][1][trackingNumber][equals]=${query}`);
      const data = await res.json();

      if (data.docs && data.docs.length > 0) {
        const order = data.docs[0];
        
        // Populate Data
        const elOrderId = document.getElementById('res-order-id');
        if(elOrderId) elOrderId.innerText = order.orderId;
        
        const elStatus = document.getElementById('res-status');
        if(elStatus) elStatus.innerHTML = getStatusBadge(order.status);

        // Items
        const elItems = document.getElementById('res-items');
        if(elItems && order.items) {
          elItems.innerHTML = order.items.map((item: any) => `
            <div class="flex justify-between items-center text-sm md:text-base">
              <span class="text-gray-700 dark:text-gray-300 font-medium">${item.productName} <span class="text-gray-400 ml-1">×${item.quantity}</span></span>
              <span class="font-bold text-gray-900 dark:text-white">${formatCurrency(item.priceAtPurchase * item.quantity)}</span>
            </div>
          `).join('');
        }

        // Details
        const elCourier = document.getElementById('res-courier');
        if(elCourier) elCourier.innerText = order.shippingMethod || '-';

        const elPayment = document.getElementById('res-payment');
        if(elPayment) elPayment.innerText = order.paymentChannel || '-';

        const elPhone = document.getElementById('res-phone');
        if(elPhone) elPhone.innerText = order.customerDetails?.phone || '-';

        const elAddress = document.getElementById('res-address');
        if(elAddress) elAddress.innerText = order.customerDetails?.address || '-';

        const elTotal = document.getElementById('res-total');
        if(elTotal) elTotal.innerText = formatCurrency(order.total);

        // Proof
        const elProofImg = document.getElementById('res-proof-img') as HTMLImageElement;
        const elProofContainer = document.getElementById('res-proof-container');
        const elNoProof = document.getElementById('res-no-proof');

        if (order.paymentProofUrl && order.paymentProofUrl !== '(tidak tersedia)') {
          if(elProofImg) elProofImg.src = order.paymentProofUrl;
          elProofContainer?.classList.remove('hidden');
          elNoProof?.classList.add('hidden');
        } else {
          elProofContainer?.classList.add('hidden');
          elNoProof?.classList.remove('hidden');
        }

        // Show Card
        resultCard?.classList.remove('hidden');
        // Trigger animation
        setTimeout(() => {
          resultCard?.classList.remove('opacity-0', 'translate-y-4');
        }, 50);

      } else {
        // Not found
        errorMsg?.classList.remove('hidden');
      }
    } catch (e) {
      console.error(e);
      errorMsg?.classList.remove('hidden');
      if(errorMsg) errorMsg.innerText = "Terjadi kesalahan sistem saat melacak pesanan.";
    } finally {
      if (btn && btnText) {
        btn.disabled = false;
        btnText.innerText = 'Search';
        btn.classList.remove('opacity-70');
      }
    }
  });

  // Handle empty input to show history again
  input.addEventListener('input', () => {
    if (input.value.trim() === '') {
      resultCard?.classList.add('hidden');
      errorMsg?.classList.add('hidden');
      initHistory(); // Refresh and show history
    }
  });
</script>
