---
import ProductDetail from '../../components/pages/ProductDetail.astro';
import { resolveTenant, getDefaultLocale } from '../../lib/cms';

export async function getStaticPaths() {
  const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:3000';
  const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321';
  
  try {
    const url = new URL(SITE_URL);
    const hostname = url.hostname + (url.port ? `:${url.port}` : '');
    
    const tenant = await resolveTenant(hostname);
    const tenantId = tenant?.id;
    const tenantFilter = tenantId ? `&where[tenant][equals]=${tenantId}` : '';
    
    console.log(`[Astro Build] SITE_URL: ${SITE_URL}`);
    console.log(`[Astro Build] Resolved Tenant: ${tenant?.name || 'None'} (ID: ${tenantId || 'None'})`);
    console.log(`[Astro Build] Fetching products with filter: ${tenantFilter || 'None'}`);
    
    const res = await fetch(`${CMS_URL}/api/products?limit=1000${tenantFilter}&locale=${getDefaultLocale()}`);
    
    if (!res.ok) {
      const text = await res.text();
      console.error(`[Astro Build] Failed to fetch products. Status: ${res.status}. Body: ${text.slice(0, 100)}`);
      return [];
    }

    const data = await res.json();
    const docs = data.docs || [];
    return docs.map((p: any) => ({
      params: { id: p.id.toString() },
      props: { product: p },
    }));
  } catch (error) {
    console.error(`[Astro Build] Error in getStaticPaths (products):`, error);
    return [];
  }
}

const { id } = Astro.params;
let { product } = Astro.props;

// Di localhost (mode server), Astro.props akan kosong. Kita ambil data secara Live.
if (!product && id) {
  const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:3000';
  const res = await fetch(`${CMS_URL}/api/products/${id}?locale=${getDefaultLocale()}`);
  if (res.ok) {
    product = await res.json();
  }
}

if (!product) return Astro.redirect('/404');

const defaultLang = getDefaultLocale() as 'id' | 'en' | 'my';
---
<ProductDetail product={product} lang={defaultLang} />
