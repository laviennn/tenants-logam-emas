---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getImageUrl, resolveTenant, getSiteSettings, getDefaultLocale, mergeWithFallback } from '../../lib/cms';
import LexicalRenderer from '../../components/LexicalRenderer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export async function getStaticPaths() {
  const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:3000';
  const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321';
  
  try {
    const url = new URL(SITE_URL);
    const hostname = url.hostname + (url.port ? `:${url.port}` : '');
    
    const tenant = await resolveTenant(hostname);
    const tenantId = tenant?.id;
    const tenantFilter = tenantId ? `&where[tenant][equals]=${tenantId}` : '';
    
    console.log(`[Astro Build] SITE_URL: ${SITE_URL}`);
    console.log(`[Astro Build] Resolved Tenant: ${tenant?.name || 'None'} (ID: ${tenantId || 'None'})`);
    console.log(`[Astro Build] Fetching articles with filter: ${tenantFilter || 'None'}`);
    
    const res = await fetch(`${CMS_URL}/api/articles?limit=100${tenantFilter}&locale=${getDefaultLocale()}`);
    if (!res.ok) return [];
    const data = await res.json();
    return (data.docs || []).map((article: any) => ({
      params: { id: article.id.toString() },
    }));
  } catch (error) {
    console.error(`[Astro Build] Error in getStaticPaths (articles):`, error);
    return [];
  }
}

const { id } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:3000';

// Resolve tenant
const hostname = Astro.url.hostname + (Astro.url.port ? `:${Astro.url.port}` : '');
const tenant = await resolveTenant(hostname);
const tenantId = tenant?.id;
const siteSettings = tenantId ? await getSiteSettings(tenantId, lang) : null;

let article;
const primaryLocale = getDefaultLocale();
const articleRes = await fetch(`${CMS_URL}/api/articles/${id}?locale=${lang || primaryLocale}`, { cache: 'no-store' });
if (articleRes.ok) {
  const targetData = await articleRes.json();
  
  if (lang === primaryLocale || !targetData) {
    article = targetData;
  } else {
    // Fetch fallback primary locale article
    const fallbackRes = await fetch(`${CMS_URL}/api/articles/${id}?locale=${primaryLocale}`, { cache: 'no-store' });
    if (fallbackRes.ok) {
      const sourceData = await fallbackRes.json();
      article = mergeWithFallback(targetData, sourceData);
    } else {
      article = targetData;
    }
  }
} else {
  return Astro.redirect('/404');
}

// Update view count (fire and forget)
fetch(`${CMS_URL}/api/articles/${id}`, {
  method: 'PATCH',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({ viewCount: (article.viewCount || 0) + 1 })
}).catch(console.error);

const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString(lang === 'id' ? 'id-ID' : lang === 'my' ? 'ms-MY' : 'en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};

const currentUrl = Astro.url.href;
const shareText = encodeURIComponent(article.title);
---

<BaseLayout title={article.title} tenantId={tenantId} siteSettings={siteSettings}>
  <article class="py-20 bg-white dark:bg-background-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex mb-8 text-sm font-bold uppercase tracking-widest text-gray-400">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-3">/</span>
        <a href="/articles" class="hover:text-primary transition-colors">Articles</a>
        <span class="mx-3">/</span>
        <span class="text-gray-900 dark:text-white truncate max-w-[200px]">{article.title}</span>
      </nav>

      <header class="mb-12">
        <h1 class="text-4xl md:text-5xl font-black text-gray-900 dark:text-white mb-6 leading-tight">
          {article.title}
        </h1>
        
        <div class="flex items-center gap-6 text-sm text-gray-500 font-medium">
          <div class="flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-black">
              {article.author?.charAt(0) || 'A'}
            </span>
            <span>{article.author || 'Admin'}</span>
          </div>
          <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
          <span>{formatDate(article.publishDate)}</span>
          <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
            <span class="font-bold">{article.viewCount || 0}</span>
          </div>
        </div>
      </header>

      {article.featuredImage && (
        <div class="mb-12 rounded-[2.5rem] overflow-hidden shadow-2xl">
          <img 
            src={getImageUrl(article.featuredImage, 'large')} 
            alt={article.title}
            class="w-full h-auto object-cover"
          />
        </div>
      )}

      <div class="article-content mb-16">
        <LexicalRenderer content={article.content} />
      </div>

      <!-- Share Buttons -->
      <footer class="pt-10 border-t border-gray-100 dark:border-gray-800">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
          <span class="text-lg font-black text-gray-900 dark:text-white">Bagikan Artikel:</span>
          
          <div class="flex items-center gap-3">
            <!-- X (Twitter) -->
            <a 
              href={`https://twitter.com/intent/tweet?text=${shareText}&url=${currentUrl}`}
              target="_blank"
              class="w-12 h-12 rounded-2xl bg-gray-900 text-white flex items-center justify-center hover:scale-110 transition-transform shadow-lg"
              aria-label="Share on X"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
            </a>

            <!-- Facebook -->
            <a 
              href={`https://www.facebook.com/sharer/sharer.php?u=${currentUrl}`}
              target="_blank"
              class="w-12 h-12 rounded-2xl bg-[#1877F2] text-white flex items-center justify-center hover:scale-110 transition-transform shadow-lg"
              aria-label="Share on Facebook"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
            </a>

            <!-- WhatsApp -->
            <a 
              href={`https://wa.me/?text=${shareText}%20${currentUrl}`}
              target="_blank"
              class="w-12 h-12 rounded-2xl bg-[#25D366] text-white flex items-center justify-center hover:scale-110 transition-transform shadow-lg"
              aria-label="Share on WhatsApp"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>
