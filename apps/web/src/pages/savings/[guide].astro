---
import SavingsGuideComponent from '../../components/pages/SavingsGuide.astro';
import { getTenantForBuild } from '../../lib/cache';

export async function getStaticPaths() {
  const tenant = await getTenantForBuild();
  if (!tenant?.enableGoldSavings) {
    return [];
  }
  return [
    { params: { guide: 'guide' } }
  ];
}
---
<SavingsGuideComponent />
