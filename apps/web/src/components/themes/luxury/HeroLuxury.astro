---
import { useTranslations, localizePath } from '../../../i18n/utils';
import { Image } from 'astro:assets';
import emasHeroLuxury from '../../../assets/img/emas_hero_11zon.webp';

interface Props {
  lang: 'id' | 'en' | 'my';
  goldPrice?: number;
}

const { lang, goldPrice } = Astro.props;
const t = useTranslations(lang);
---
<section class="relative pt-20 pb-16 md:pt-32 md:pb-24 bg-[#faf9f6] dark:bg-[#0a0a0a] overflow-hidden">
  <!-- Subtle Background Glow -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-amber-500/10 dark:bg-amber-500/5 blur-[100px] rounded-full translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
      
      <!-- Text Content -->
      <div class="w-full md:w-1/2 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-serif text-gray-900 dark:text-white leading-[1.1] mb-6 tracking-wide uppercase">
          {t('hero.luxury.title')}
        </h1>
        
        <!-- Elegant Divider -->
        <div class="flex items-center justify-center md:justify-start gap-3 mb-6">
          <div class="h-[1px] w-12 bg-amber-500"></div>
          <div class="w-2 h-2 rotate-45 bg-amber-500"></div>
          <div class="h-[1px] w-12 bg-amber-500"></div>
        </div>

        <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed mb-10 max-w-xl mx-auto md:mx-0 font-light">
          {t('hero.luxury.desc')}
        </p>
        
        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center md:justify-start">
          <a href={localizePath('/products', lang)} class="w-full sm:w-auto px-8 py-3.5 bg-gradient-to-r from-amber-400 to-amber-600 hover:from-amber-500 hover:to-amber-700 text-white font-bold tracking-widest text-sm uppercase rounded shadow-lg shadow-amber-500/20 transition-all flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            {t('hero.luxury.buy')}
          </a>
          <a href="#kalkulator" class="w-full sm:w-auto px-8 py-3.5 bg-transparent border border-gray-300 dark:border-gray-700 hover:border-amber-500 text-gray-800 dark:text-gray-200 hover:text-amber-500 font-bold tracking-widest text-sm uppercase rounded transition-all flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            {t('hero.luxury.price')}
          </a>
        </div>
      </div>

      <!-- Image Content -->
      <div class="w-full md:w-1/2 relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-gray-200/50 dark:border-white/5 transform hover:scale-[1.02] transition-transform duration-700">
          <Image 
            src={emasHeroLuxury} 
            alt="Gold Investment" 
            class="w-full h-auto object-cover"
            loading="eager"
            width={800}
            height={600}
          />
        </div>
      </div>

    </div>
  </div>
</section>
