---
import { useTranslations } from '../../../i18n/utils';

interface Props {
  lang: 'id' | 'en' | 'my';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const reasons = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>`,
    titleKey: 'reasons.trusted.title',
    descKey: 'reasons.trusted.desc'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>`,
    titleKey: 'reasons.quality.title',
    descKey: 'reasons.quality.desc'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>`,
    titleKey: 'reasons.safe.title',
    descKey: 'reasons.safe.desc'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>`,
    titleKey: 'reasons.stable.title',
    descKey: 'reasons.stable.desc'
  }
];
---
<section class="py-12 bg-[#faf9f6] dark:bg-[#0a0a0a]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white dark:bg-[#121212] border border-gray-200 dark:border-white/10 rounded-2xl p-8 md:p-12 shadow-xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 divide-y md:divide-y-0 md:divide-x divide-gray-200 dark:divide-white/10">
        {reasons.map((reason, index) => (
          <div class={`flex items-start gap-4 ${index !== 0 ? 'pt-8 md:pt-0 md:pl-8' : ''}`}>
            <div class="flex-shrink-0 text-amber-500">
              <Fragment set:html={reason.icon} />
            </div>
            <div>
              <h4 class="text-sm md:text-base font-bold text-gray-900 dark:text-white mb-1 uppercase tracking-wide">
                {t(reason.titleKey)}
              </h4>
              <p class="text-xs md:text-sm text-gray-500 dark:text-gray-400 leading-relaxed font-light">
                {t(reason.descKey)}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
