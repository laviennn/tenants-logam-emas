---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getImageUrl } from '../lib/cms';

interface Article {
  id: string;
  title: string;
  publishDate: string;
  featuredImage?: any;
  excerpt?: string;
  viewCount?: number;
}

const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:3000';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

let articles: Article[] = [];
try {
  const res = await fetch(`${CMS_URL}/api/articles?locale=${lang}&limit=3&sort=-publishDate`, { cache: 'no-store' });
  if (res.ok) {
    const data = await res.json();
    articles = data.docs || [];
  }
} catch (e) {
  console.error("Failed to fetch articles", e);
}

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString(lang === 'id' ? 'id-ID' : lang === 'my' ? 'ms-MY' : 'en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  {articles.length > 0 ? articles.map((article) => (
    <a href={`/articles/${article.id}`} class="group bg-white dark:bg-surface-dark rounded-[2.5rem] overflow-hidden border border-gray-100 dark:border-white/5 shadow-lg hover:shadow-2xl transition-all duration-500 flex flex-col">
      <div class="relative aspect-[16/10] overflow-hidden">
        {article.featuredImage ? (
          <img 
            src={getImageUrl(article.featuredImage)} 
            alt={article.title} 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
        ) : (
          <div class="w-full h-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
            <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          </div>
        )}
        <div class="absolute top-4 left-4">
          <span class="bg-primary/90 backdrop-blur-md text-white text-[10px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full shadow-lg">Insight</span>
        </div>
      </div>
      
      <div class="p-8 flex-grow flex flex-col">
        <div class="flex items-center justify-between mb-4">
           <p class="text-[10px] font-black text-primary uppercase tracking-widest">{formatDate(article.publishDate)}</p>
           <div class="flex items-center gap-1.5 text-gray-400">
             <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
             </svg>
             <span class="text-[10px] font-bold">{article.viewCount || 0}</span>
           </div>
        </div>

        <h3 class="text-xl font-black text-gray-900 dark:text-white mb-4 line-clamp-2 leading-tight group-hover:text-primary transition-colors">
          {article.title}
        </h3>
        <p class="text-gray-500 dark:text-gray-400 text-sm line-clamp-3 mb-8 leading-relaxed flex-grow">
          {article.excerpt || ''}
        </p>
        
        <div class="flex items-center gap-2 text-primary font-black text-xs uppercase tracking-widest group-hover:translate-x-2 transition-transform duration-300">
          Baca Selengkapnya
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </div>
      </div>
    </a>
  )) : (
    <div class="col-span-full py-20 text-center text-gray-400 bg-gray-50 dark:bg-gray-900/50 rounded-[3rem] border-2 border-dashed border-gray-200 dark:border-white/5">
      <p class="font-black uppercase tracking-widest">Belum ada ulasan pelanggan.</p>
    </div>
  )}
</div>
