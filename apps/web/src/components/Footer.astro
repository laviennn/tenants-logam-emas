---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  logoUrl?: string;
  tenantId?: number | string;
  siteSettings?: any;
  tenantName?: string;
}

// Receive from BaseLayout — no extra network call needed
const { logoUrl, tenantId, siteSettings, tenantName } = Astro.props;

const brandName = siteSettings?.brandName || tenantName || 'Logam Mulia';
const isMY = import.meta.env.PUBLIC_TENANT_REGION === 'MY';

// Default fallback message differs per region; CMS field overrides this if set
const defaultCustomMessage = isMY
  ? 'boleh ajar saya simpan emas?'
  : 'saya tertarik untuk bertransaksi emas. Bagaimana prosedur pembelian dan penjualannya?';
const customMessage = siteSettings?.whatsappDefaultMessage || defaultCustomMessage;
const greeting = isMY ? `Salam ${brandName}` : `Halo Admin ${brandName}`;
const defaultMessage = `${greeting}, ${customMessage}`;
const waLink = `https://wa.me/${siteSettings?.whatsappNumber}?text=${encodeURIComponent(defaultMessage)}`;
const showWA = siteSettings?.enableFloatingWA && siteSettings?.whatsappNumber;

const copyrightMobileAlign = siteSettings?.copyrightMobileAlign || 'left';

const alignContainerClasses = copyrightMobileAlign === 'center'
  ? 'items-center text-center'
  : copyrightMobileAlign === 'right'
  ? 'items-end text-right md:items-center md:text-left'
  : 'items-start text-left md:items-center md:text-left';

const alignParagraphClasses = copyrightMobileAlign === 'center'
  ? 'text-center w-full md:w-auto'
  : copyrightMobileAlign === 'right'
  ? 'text-right w-full md:w-auto'
  : 'text-left w-full md:w-auto';

const formatSocialUrl = (url: string, base: string) => {
  if (!url) return '';
  url = url.trim();
  if (url.startsWith('http')) return url;
  if (url.startsWith('@')) url = url.substring(1);
  return `${base}${url}`;
};

const fbLink = formatSocialUrl(siteSettings?.facebook, 'https://facebook.com/');
const igLink = formatSocialUrl(siteSettings?.instagram, 'https://instagram.com/');
const twLink = formatSocialUrl(siteSettings?.twitter, 'https://twitter.com/');
---

<footer
  class='bg-gray-50 dark:bg-surface-dark border-t border-gray-100 dark:border-gray-800 pt-16 pb-8 transition-colors duration-300'>
  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16'>
      <!-- Brand Section -->
      <div class='space-y-6'>
        <div class='flex items-center gap-2'>
          <span
            class='text-2xl font-bold text-gray-900 dark:text-white tracking-tight'>
            {siteSettings?.brandName || tenantName || 'Logam Mulia'}
          </span>
        </div>
        <p class='text-gray-600 dark:text-gray-400 leading-relaxed max-w-xs'>
          {siteSettings?.footerAbout || t('services.desc')}
        </p>
        <div class='flex items-center gap-4'>
          {
            siteSettings?.facebook && (
              <a
                href={fbLink}
                target='_blank'
                rel='noopener noreferrer'
                class='w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-sm flex items-center justify-center text-gray-400 hover:text-primary hover:shadow-md transition-all'>
                <svg
                  class='w-5 h-5'
                  fill='currentColor'
                  viewBox='0 0 24 24'>
                  <path d='M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' />
                </svg>
              </a>
            )
          }
          {
            siteSettings?.instagram && (
              <a
                href={igLink}
                target='_blank'
                rel='noopener noreferrer'
                class='w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-sm flex items-center justify-center text-gray-400 hover:text-primary hover:shadow-md transition-all'>
                <svg
                  class='w-5 h-5'
                  fill='currentColor'
                  viewBox='0 0 24 24'>
                  <path d='M12.315 2c2.43 0 2.784.012 3.823.06 1.062.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.365.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.365-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.823.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16.4a4.4 4.4 0 110-8.8 4.4 4.4 0 010 8.8zm6.487-11.595a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z' />
                </svg>
              </a>
            )
          }
          {
            siteSettings?.twitter && (
              <a
                href={twLink}
                target='_blank'
                rel='noopener noreferrer'
                class='w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-sm flex items-center justify-center text-gray-400 hover:text-primary hover:shadow-md transition-all'>
                <svg
                  class='w-5 h-5'
                  fill='currentColor'
                  viewBox='0 0 24 24'>
                  <path d='M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z' />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3
          class='text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-6'>
          {t('footer.links')}
        </h3>
        <ul class='space-y-4'>
          <li>
            <a
              href={localizePath('/', lang)}
              class='text-gray-600 dark:text-gray-400 hover:text-primary transition-colors flex items-center gap-2 text-sm'
              ><div class='w-1.5 h-1.5 rounded-full bg-primary/40'></div>
              {t('nav.home')}</a
            >
          </li>
          <li>
            <a
              href={localizePath('/products', lang)}
              class='text-gray-600 dark:text-gray-400 hover:text-primary transition-colors flex items-center gap-2 text-sm'
              ><div class='w-1.5 h-1.5 rounded-full bg-primary/40'></div>
              {t('nav.products')}</a
            >
          </li>
          <li>
            <a
              href={localizePath('/track-order', lang)}
              class='text-gray-600 dark:text-gray-400 hover:text-primary transition-colors flex items-center gap-2 text-sm'
              ><div class='w-1.5 h-1.5 rounded-full bg-primary/40'></div>
              {t('nav.track')}</a
            >
          </li>
          <li>
            <a
              href={localizePath('/articles', lang)}
              class='text-gray-600 dark:text-gray-400 hover:text-primary transition-colors flex items-center gap-2 text-sm'
              ><div class='w-1.5 h-1.5 rounded-full bg-primary/40'></div>
              {t('nav.news')}</a
            >
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3
          class='text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-6'>
          {t('footer.contact')}
        </h3>
        <ul class='space-y-4'>
          <li class='flex items-start gap-3'>
            <div
              class='mt-1 w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary flex-shrink-0'>
              <svg
                class='w-4 h-4'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z'
                ></path><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M15 11a3 3 0 11-6 0 3 3 0 016 0z'
                ></path></svg
              >
            </div>
            <span class='text-gray-600 dark:text-gray-400 text-sm'
              >{siteSettings?.address || 'Jakarta, Indonesia'}</span
            >
          </li>
          <li class='flex items-center gap-3'>
            <div
              class='w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary flex-shrink-0'>
              <svg
                class='w-4 h-4'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
                ></path></svg
              >
            </div>
            {
              showWA ? (
                <a
                  href={waLink}
                  target='_blank'
                  rel='noopener noreferrer'
                  class='text-gray-600 dark:text-gray-400 text-sm hover:text-primary transition-colors underline'>
                  +{siteSettings?.whatsappNumber || '6281234567890'}
                </a>
              ) : (
                <span class='text-gray-600 dark:text-gray-400 text-sm'>
                  +{siteSettings?.whatsappNumber || '6281234567890'}
                </span>
              )
            }
          </li>
          <li class='flex items-center gap-3'>
            <div
              class='w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary flex-shrink-0'>
              <svg
                class='w-4 h-4'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
                ></path></svg
              >
            </div>
            <span class='text-gray-600 dark:text-gray-400 text-sm'
              >{siteSettings?.email || 'support@logammulia.com'}</span
            >
          </li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class='text-lg font-bold mb-4 text-gray-900 dark:text-white'>
          {t('footer.newsletter')}
        </h3>
        <p class='text-gray-600 dark:text-gray-400 text-sm mb-4'>
          {t('footer.newsletter_desc')}
        </p>
        <form class='flex flex-col space-y-2'>
          <input
            type='email'
            placeholder={t('footer.email_placeholder') as string}
            class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-900 dark:text-white text-sm rounded-xl focus:ring-primary focus:border-primary block w-full p-3 outline-none transition-all'
            required
          />
          <button
            type='submit'
            class='w-full text-white bg-primary hover:bg-primary-dark dark:bg-white dark:text-gray-900 dark:hover:bg-gray-100 font-bold rounded-xl text-sm px-5 py-3 text-center transition-all shadow-sm'
            >{t('footer.subscribe')}</button
          >
        </form>
      </div>
    </div>
  </div>

  <div
    class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 border-t border-gray-100 dark:border-gray-800 pt-8'>
    <div
      class={`flex flex-col md:flex-row justify-between gap-4 text-sm text-gray-500 dark:text-gray-400 ${alignContainerClasses}`}>
      <p class={alignParagraphClasses}>
        {siteSettings?.footerCopyright
          ? siteSettings.footerCopyright
          : `© ${new Date().getFullYear()} ${brandName}. All rights reserved.`}
      </p>
      <div class='flex items-center gap-6'>
        <a
          href={localizePath('/privacy-policy', lang)}
          class='hover:text-primary transition-colors'
          >{t('footer.privacy')}</a
        >
        <a
          href={localizePath('/terms-of-service', lang)}
          class='hover:text-primary transition-colors'
          >{t('footer.terms')}</a
        >
      </div>
    </div>
  </div>
</footer>
