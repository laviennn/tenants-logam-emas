---
import {
  getLangFromUrl,
  useTranslations,
  languages,
  localizePath,
} from '../i18n/utils';
import { defaultLang } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(`/${lang}`, '');

const navLinks = [
  { key: 'nav.home', href: '/' },
  { key: 'nav.products', href: '/products' },
  { key: 'nav.track', href: '/track-order' },
];

interface Props {
  logoUrl?: string;
  tenantId?: number | string;
  siteSettings?: any;
  tenantName?: string;
  tenant?: any;
}

// Receive from BaseLayout — no extra network call needed
const { logoUrl, tenantId, siteSettings, tenantName, tenant } = Astro.props;

if (tenant?.enableGoldSavings) {
  navLinks.push({ key: 'savings.dashboard', href: '/dashboard/savings' });
  navLinks.push({ key: 'savings.guide', href: '/savings/guide' });
}

const registerUrl = tenant?.enableGoldSavings ? '/savings/register' : '/register';

import { hasCache, getCachedCategories } from '../lib/cache';

// Luxury Branded Theme Logic
const isBrandedTheme = tenant?.theme_layout === 'luxury-branded';
let brandedCategories: any[] = [];
if (isBrandedTheme && tenantId) {
  // Remove "Products" and "Track Order" for Luxury Branded theme
  const productsIdx = navLinks.findIndex((n) => n.key === 'nav.products');
  if (productsIdx > -1) navLinks.splice(productsIdx, 1);
  const trackIdx = navLinks.findIndex((n) => n.key === 'nav.track');
  if (trackIdx > -1) navLinks.splice(trackIdx, 1);

  if (hasCache()) {
    brandedCategories = getCachedCategories() || [];
  } else {
    const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:3000';
    const catRes = await fetch(`${CMS_URL}/api/categories?where[tenant][equals]=${tenantId}&limit=100&locale=all`, { cache: 'no-store' })
      .catch(() => null);
    if (catRes?.ok) {
      const data = await catRes.json();
      brandedCategories = data.docs || [];
    }
  }
}

const mainCategories = brandedCategories.filter((c: any) => !c.parent && !c.hideFromNavbar);
const childCategories = brandedCategories.filter((c: any) => c.parent);

const getName = (name: any, l: string) => typeof name === 'string' ? name : (name?.[l] || name?.id || name?.en || name?.my || '');
---

<nav class='bg-navbar-bg dark:bg-background-dark shadow-md sticky top-0 z-50 transition-colors duration-300'>
  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
    <div class='flex justify-between items-center min-h-[4rem] md:min-h-[5rem] py-2'>
      <!-- Left: Hamburger + Logo -->
      <div class='flex items-center h-full w-auto shrink-0 mr-4 lg:mr-8'>
        <button
          id='mobile-menu-btn'
          class='md:hidden p-2 mr-2 text-gray-900 dark:text-white hover:bg-black/10 dark:hover:bg-white/10 rounded-lg focus:outline-none relative z-50 cursor-pointer transition-colors'
          aria-label='Toggle menu'
          onclick="
            const menu = document.getElementById('mobile-menu');
            if (menu) {
              const isClosed = menu.classList.contains('max-h-0');
              if (isClosed) {
                menu.classList.remove('max-h-0');
                menu.style.maxHeight = menu.scrollHeight + 'px';
              } else {
                menu.classList.add('max-h-0');
                menu.style.maxHeight = '0px';
              }
            }
          "
        >
          <svg
            class='w-6 h-6'
            fill='none'
            stroke='currentColor'
            viewBox='0 0 24 24'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M4 6h16M4 12h16M4 18h16'
            ></path>
          </svg>
        </button>
        <a
          href={localizePath('/', lang)}
          class='flex items-center h-full py-3'>
          {
            logoUrl ? (
              <img
                src={logoUrl}
                alt={siteSettings?.brandName || 'Logo'}
                class='h-12 md:h-16 w-auto object-contain transition-transform duration-300 hover:scale-105'
                loading='eager'
                fetchpriority='high'
                decoding='async'
              />
            ) : (
              <span class='text-xl md:text-2xl font-black text-gray-900 dark:text-white'>
                {siteSettings?.brandName ? (
                  siteSettings.brandName
                ) : tenantName ? (
                  tenantName
                ) : (
                  <>
                    Logam
                    <span class='text-primary'>Mulia</span>
                  </>
                )}
              </span>
            )
          }
        </a>
      </div>

      <!-- Desktop Menu -->
      <div class='hidden md:flex flex-1 justify-start min-w-0'>
        <div class='flex flex-wrap items-center gap-x-4 lg:gap-x-6 gap-y-2 px-2 py-1'>
          {
            navLinks.map((link) => (
              <a
                href={localizePath(link.href, lang)}
                data-i18n={link.key}
                class='text-gray-900 dark:text-white px-2 py-2 rounded-md text-sm font-black transition-all hover:bg-black/10 dark:hover:bg-white/10'>
                {t(link.key as any)}
              </a>
            ))
          }
        {isBrandedTheme && mainCategories.length > 0 && mainCategories.map((mainCat: any) => {
          const children = childCategories.filter((c: any) => typeof c.parent === 'object' ? c.parent.id === mainCat.id : c.parent === mainCat.id);
          const hasChildren = children.length > 0;
          return (
            <div class="relative group">
              <a href={`/products?category=${mainCat.id}`} class="flex items-center gap-1 text-gray-900 dark:text-white px-2 py-2 rounded-md text-sm font-black transition-all hover:bg-black/10 dark:hover:bg-white/10 capitalize">
                {getName(mainCat.name, lang) || mainCat.id}
                {hasChildren && <svg class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>}
              </a>
              {hasChildren && (
                <div class="absolute left-0 top-full pt-2 w-48 hidden group-hover:block z-50">
                  <div class="absolute inset-x-0 -top-2 h-2"></div>
                  <div class="bg-white dark:bg-surface-dark border border-gray-100 dark:border-gray-800 shadow-xl py-2 flex flex-col">
                    {children.map((child: any) => (
                      <a href={`/products?category=${child.id}`} class="w-full text-left px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:bg-black/5 dark:hover:bg-white/5 hover:text-gray-900 dark:hover:text-white transition-colors capitalize">
                        {getName(child.name, lang) || child.id}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )
        })}
        </div>
      </div>

      <!-- Right Section: Cart, Dark Mode, Auth, Lang -->
      <div
        class='flex items-center justify-end space-x-2 md:space-x-4 w-auto shrink-0 ml-4 lg:ml-8'>
        <!-- Cart -->
        <a
          href='/cart'
          class='relative text-gray-900 dark:text-white p-2 hover:bg-black/10 dark:hover:bg-white/10 rounded-lg transition-colors'>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='h-6 h-6'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z'
            ></path>
          </svg>
          <span
            id='cart-count'
            class='absolute top-0 right-0 inline-flex items-center justify-center px-2 py-1 text-xs font-bold leading-none text-white transform translate-x-1/2 -translate-y-1/2 bg-red-600 rounded-full hidden'
            >0</span
          >
        </a>

        <!-- Dark Mode Toggle -->
        {tenant?.enableDarkMode !== false && (
        <button
          id='theme-toggle'
          type='button'
          class='text-gray-900 dark:text-white hover:bg-black/10 dark:hover:bg-white/10 rounded-lg text-sm p-2 transition-colors'>
          <svg
            id='theme-toggle-dark-icon'
            class='hidden w-5 h-5'
            fill='currentColor'
            viewBox='0 0 20 20'
            xmlns='http://www.w3.org/2000/svg'
            ><path
              d='M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z'
            ></path></svg
          >
          <svg
            id='theme-toggle-light-icon'
            class='hidden w-5 h-5'
            fill='currentColor'
            viewBox='0 0 20 20'
            xmlns='http://www.w3.org/2000/svg'
            ><path
              d='M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z'
              fill-rule='evenodd'
              clip-rule='evenodd'
            ></path></svg
          >
        </button>
        )}

        <!-- Auth Buttons (Desktop) -->
        <div class='hidden md:block'>
          <div
            id='auth-buttons'
            class='flex items-center space-x-4'>
            <a
              href={localizePath('/login', lang)}
              data-i18n='nav.login'
              class='text-gray-900 dark:text-white font-black hover:opacity-75 transition-opacity'
              >{t('nav.login')}</a
            >
            <a
              href={localizePath(registerUrl, lang)}
              data-i18n='nav.register'
              class='bg-gray-900 hover:bg-black text-white px-4 py-2 rounded-md font-black transition-colors whitespace-nowrap shadow-lg'
              >{t('nav.register')}</a
            >
          </div>

          <!-- Profile Dropdown (Hidden by default) -->
          <div
            id='profile-dropdown-container'
            class='relative group hidden'>
            <button
              class='flex items-center text-gray-900 dark:text-white hover:bg-black/10 dark:hover:bg-white/10 p-2 rounded-lg focus:outline-none transition-colors'>
              <svg
                class='w-6 h-6'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z'
                ></path></svg
              >
            </button>
            <div
              class='absolute right-0 md:left-0 md:right-auto top-full pt-2 w-48 hidden group-hover:block z-50'>
              <!-- Hover Bridge -->
              <div class='absolute inset-x-0 -top-2 h-2'></div>
              <div
                class='bg-white dark:bg-surface-dark border border-gray-200 dark:border-gray-700 rounded-2xl shadow-xl overflow-hidden ring-1 ring-black/5'>
                <div
                  class='px-4 py-3 border-b border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/50'>
                  <p
                    class='text-[10px] uppercase tracking-widest font-bold text-white mb-0.5'>
                    {t('nav.logged_in_as')}
                  </p>
                  <p
                    id='profile-email'
                    class='text-xs font-bold text-gray-900 dark:text-white truncate'>
                  </p>
                </div>
                <div class='p-1'>
                  <a
                    href='/track-order'
                    class='flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-primary/10 hover:text-primary rounded-xl transition-colors'>
                    <svg
                      class='w-4 h-4'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
                      ><path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01'
                      ></path></svg
                    >
                    {t('nav.my_orders')}
                  </a>
                  <button
                    id='btn-logout'
                    class='w-full flex items-center gap-2 px-3 py-2 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-xl transition-colors'>
                    <svg
                      class='w-4 h-4'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
                      ><path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1'
                      ></path></svg
                    >
                    {t('nav.logout')}
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Language Dropdown -->
        <div class='relative group'>
          <button
            class='flex items-center gap-2 text-gray-900 dark:text-white hover:bg-black/10 dark:hover:bg-white/10 rounded-lg font-black p-2 text-sm md:text-base transition-colors'>
            <span
              id='current-lang-flag'
              class='text-lg'>
              {lang === 'id' ? '🇮🇩' : lang === 'en' ? '🇬🇧' : '🇲🇾'}
            </span>
            <span
              id='current-lang-label'
              class='uppercase tracking-wide'>
              {lang.toUpperCase()}
            </span>
            <svg
              class='w-4 h-4 opacity-50'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
              ><path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M19 9l-7 7-7-7'
              ></path></svg
            >
          </button>
          <div
            class='absolute right-0 top-full pt-2 w-36 hidden group-hover:block group-focus-within:block z-50'>
            <!-- Hover Bridge -->
            <div class='absolute inset-x-0 -top-2 h-2'></div>
            <div
              id="lang-switcher-container"
              data-default-lang={defaultLang}
              class='bg-white dark:bg-surface-dark border border-gray-200 dark:border-gray-700 rounded-2xl shadow-xl overflow-hidden p-1 ring-1 ring-black/5'>
              {
                Object.entries(languages).map(([key, label]) => (
                  <button
                    type='button'
                    data-lang-key={key}
                    class='btn-lang w-full flex items-center gap-3 px-4 py-2.5 text-sm font-bold text-gray-700 dark:text-gray-300 hover:bg-primary/10 hover:text-primary rounded-xl transition-all'>
                    <span>{label}</span>
                  </button>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu (Fluid Animation via max-height) -->
  <div
    id='mobile-menu'
    class='md:hidden overflow-hidden transition-[max-height] duration-300 ease-in-out max-h-0 bg-navbar-bg dark:bg-background-dark border-t border-black/10 dark:border-white/10'>
    <div class='px-4 py-4 space-y-3'>
      {
        navLinks.map((link) => (
          <a
            href={localizePath(link.href, lang)}
            data-i18n={link.key}
            class='block text-gray-900 dark:text-white font-black px-2 py-2 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors'>
            {t(link.key as any)}
          </a>
        ))
      }
      
      {isBrandedTheme && mainCategories.length > 0 && mainCategories.map((mainCat: any) => {
        const children = childCategories.filter((c: any) => typeof c.parent === 'object' ? c.parent.id === mainCat.id : c.parent === mainCat.id);
        return (
          <div class="flex flex-col px-2 py-1">
            <a href={`/products?category=${mainCat.id}`} class="block text-gray-900 dark:text-white font-black py-2 capitalize">{getName(mainCat.name, lang) || mainCat.id}</a>
            {children.length > 0 && (
              <div class="flex flex-col pl-4 space-y-2 border-l-2 border-gray-100 dark:border-gray-800 mt-1 mb-2">
                {children.map((child: any) => (
                  <a href={`/products?category=${child.id}`} class="text-sm text-gray-600 dark:text-gray-400 capitalize hover:text-gray-900 dark:hover:text-white transition-colors">{getName(child.name, lang) || child.id}</a>
                ))}
              </div>
            )}
          </div>
        )
      })}
      <div
        id='mobile-auth-buttons'
        class='border-t border-gray-200 dark:border-gray-700 pt-3 flex flex-col space-y-2'>
        <a
          href={localizePath('/login', lang)}
          data-i18n='nav.login'
          class='block text-gray-900 dark:text-white font-black px-2 py-2'
          >{t('nav.login')}</a
        >
        <a
          href={localizePath(registerUrl, lang)}
          data-i18n='nav.register'
          class='block bg-gray-900 text-white text-center px-4 py-2 rounded-lg font-black shadow-md'
          >{t('nav.register')}</a
        >
      </div>
      <div
        id='mobile-profile-section'
        class='border-t border-gray-200 dark:border-gray-700 pt-3 flex flex-col space-y-2 hidden'>
        <div class='px-2 py-2'>
          <p class='text-xs text-white'>{t('nav.logged_in_as')}</p>
          <p
            id='mobile-profile-email'
            class='text-sm font-medium text-gray-900 dark:text-white truncate'>
          </p>
        </div>
        <button
          id='btn-mobile-logout'
          class='block text-left text-red-600 font-medium px-2 py-1'
          >{t('nav.logout')}</button
        >
      </div>
    </div>
  </div>
</nav>

<script>
  import { cartStore } from '../lib/cart';

  const cartCountEl = document.getElementById('cart-count');

  cartStore.subscribe((cart) => {
    if (cartCountEl) {
      const totalItems = Object.values(cart).reduce(
        (acc, item) => acc + (Number(item.quantity) || 0),
        0,
      );
      cartCountEl.innerText = totalItems.toString();
      if (totalItems > 0) {
        cartCountEl.classList.remove('hidden');
      } else {
        cartCountEl.classList.add('hidden');
      }
    }
  });



  // Dark mode toggle logic
  const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
  const themeToggleLightIcon = document.getElementById(
    'theme-toggle-light-icon',
  );
  const themeToggleBtn = document.getElementById('theme-toggle');

  // Global flag for dark mode injected from BaseLayout
  const enableDarkMode = (window as any).__enableDarkMode !== false;

  if (enableDarkMode) {
    if (
      localStorage.getItem('color-theme') === 'dark' ||
      (!('color-theme' in localStorage) &&
        window.matchMedia('(prefers-color-scheme: dark)').matches)
    ) {
      themeToggleLightIcon?.classList.remove('hidden');
      document.documentElement.classList.add('dark');
    } else {
      themeToggleDarkIcon?.classList.remove('hidden');
      document.documentElement.classList.remove('dark');
    }
  } else {
    document.documentElement.classList.remove('dark');
  }

  themeToggleBtn?.addEventListener('click', function () {
    themeToggleDarkIcon?.classList.toggle('hidden');
    themeToggleLightIcon?.classList.toggle('hidden');

    if (localStorage.getItem('color-theme')) {
      if (localStorage.getItem('color-theme') === 'light') {
        document.documentElement.classList.add('dark');
        localStorage.setItem('color-theme', 'dark');
      } else {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('color-theme', 'light');
      }
    } else {
      if (document.documentElement.classList.contains('dark')) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('color-theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('color-theme', 'dark');
      }
    }
  });

  // Auth Listener
  import { supabase } from '../lib/supabase';

  const authButtons = document.getElementById('auth-buttons');
  const profileDropdown = document.getElementById('profile-dropdown-container');
  const profileEmail = document.getElementById('profile-email');
  const mobileAuthButtons = document.getElementById('mobile-auth-buttons');
  const mobileProfileSection = document.getElementById(
    'mobile-profile-section',
  );
  const mobileProfileEmail = document.getElementById('mobile-profile-email');

  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session?.user) {
      if (authButtons) authButtons.classList.add('hidden');
      if (mobileAuthButtons) mobileAuthButtons.classList.add('hidden');

      if (profileDropdown) profileDropdown.classList.remove('hidden');
      if (mobileProfileSection) mobileProfileSection.classList.remove('hidden');

      if (profileEmail) profileEmail.innerText = session.user.email || '';
      if (mobileProfileEmail)
        mobileProfileEmail.innerText = session.user.email || '';
    } else {
      if (authButtons) authButtons.classList.remove('hidden');
      if (mobileAuthButtons) mobileAuthButtons.classList.remove('hidden');

      if (profileDropdown) profileDropdown.classList.add('hidden');
      if (mobileProfileSection) mobileProfileSection.classList.add('hidden');
    }
  });

  const handleLogout = async () => {
    await supabase.auth.signOut();
    window.location.reload();
  };

  document
    .getElementById('btn-logout')
    ?.addEventListener('click', handleLogout);
  document
    .getElementById('btn-mobile-logout')
    ?.addEventListener('click', handleLogout);

  // Client-side Localization Store Logic
  import { langStore, type Language } from '../lib/lang';
  import { languages } from '../i18n/utils';

  const currentLangLabel = document.getElementById('current-lang-label');
  const currentLangFlag = document.getElementById('current-lang-flag');
  langStore.subscribe((lang) => {
    if (currentLangLabel) {
      currentLangLabel.innerText = lang.toUpperCase();
    }
    if (currentLangFlag) {
      currentLangFlag.innerText =
        lang === 'id' ? '🇮🇩' : lang === 'en' ? '🇬🇧' : '🇲🇾';
    }
  });

  document.querySelectorAll('.btn-lang').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const key = target.getAttribute('data-lang-key') as string;
      const defaultLang = document.getElementById('lang-switcher-container')?.getAttribute('data-default-lang') || 'id';
      
      if (key) {
        const currentPath = window.location.pathname;
        const parts = currentPath.split('/');

        // Check if current path already has a lang prefix
        const locales = ['en', 'my', 'id'].filter((l) => l !== defaultLang);
        let newPath = '';

        if (locales.includes(parts[1])) {
          // Current is a prefixed route (e.g., /en/... or /my/...)
          if (key === defaultLang) {
            newPath = '/' + parts.slice(2).join('/');
          } else {
            parts[1] = key;
            newPath = parts.join('/');
          }
        } else {
          // Current is the default/un-prefixed route (e.g., /...)
          if (key === defaultLang) {
            newPath = currentPath;
          } else {
            newPath = '/' + key + currentPath;
          }
        }

        // Clean up double slashes
        newPath = newPath.replace(/\/+/g, '/');
        window.location.href = newPath;
      }
    });
  });
</script>
