---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../SectionTitle.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';
import { resolveTenant } from '../../lib/cms';

interface Props {
  lang?: 'id' | 'en' | 'my';
}

const { lang: propLang } = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const hostname = Astro.url.hostname + (Astro.url.port ? `:${Astro.url.port}` : '');
const tenant = await resolveTenant(hostname);
const tenantId = tenant?.id ?? null;

if (tenant?.enableGoldSavings) {
  return Astro.redirect(localizePath('/savings/register', lang));
}

const registerStrings = {
  processing: t('login.processing'),
  mismatch: t('register.mismatch'),
  failed: t('register.failed'),
  success: t('register.success'),
  submit_btn: t('register.submit_btn'),
};
---

<BaseLayout title={t('nav.register')}>
  <div class="min-h-[70vh] flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white dark:bg-surface-dark p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800">
      <div>
        <SectionTitle title={t('nav.register')} i18nTitle="nav.register" />
        <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
          <span data-i18n="login.or">{t('login.or')}</span>
          <a href={localizePath('/login', lang)} class="font-medium text-primary hover:text-primary-dark" data-i18n="register.login_link">
            {t('register.login_link')}
          </a>
        </p>
      </div>
      <form id="register-form" class="mt-8 space-y-6">
        <!-- Toast Notification Container -->
        <div id="toast" class="hidden rounded-lg p-4 mb-4 text-sm font-medium"></div>

        <div class="rounded-md shadow-sm space-y-4">
          <div>
            <label for="email-address" class="sr-only">Email address</label>
            <input id="email-address" name="email" type="email" autocomplete="email" required class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-700 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-primary focus:border-primary focus:z-10 sm:text-sm" placeholder="Email address">
          </div>
          <div>
            <label for="password" class="sr-only">Password</label>
            <input id="password" name="password" type="password" required class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-700 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-primary focus:border-primary focus:z-10 sm:text-sm" placeholder="Password">
            <p id="password-error" class="text-xs text-red-500 hidden mt-1">Password minimal 6 karakter.</p>
          </div>
          <div>
            <label for="confirm-password" class="sr-only">Confirm Password</label>
            <input id="confirm-password" name="confirm-password" type="password" required class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-700 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-primary focus:border-primary focus:z-10 sm:text-sm" placeholder={t('register.confirm_password_placeholder')}>
          </div>
        </div>

        <div>
          <button type="submit" id="btn-register" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-primary hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors disabled:opacity-50" data-i18n="register.submit_btn">
            {t('register.submit_btn')}
          </button>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ registerStrings, tenantId }}>
  window.__REGISTER_STRINGS = registerStrings;
  window.__TENANT_ID = tenantId;
</script>

<script>
  import { supabase } from '../../lib/supabase';

  const registerStrings = (window as any).__REGISTER_STRINGS;
  const tenantId = (window as any).__TENANT_ID;
  const apiUrl = window.location.origin.includes('localhost') || window.location.origin.includes('127.0.0.1')
    ? 'http://localhost:3000'
    : 'https://api-logam-tenants.creosphera.workers.dev';

  const form = document.getElementById('register-form') as HTMLFormElement;
  const btnRegister = document.getElementById('btn-register');
  const toast = document.getElementById('toast');

  const showToast = (message: string, type: 'error' | 'success') => {
    if(!toast) return;
    toast.innerText = message;
    toast.classList.remove('hidden', 'bg-red-50', 'text-red-800', 'border-red-200', 'bg-green-50', 'text-green-800', 'border-green-200');
    toast.classList.add('border');
    if(type === 'error') {
      toast.classList.add('bg-red-50', 'text-red-800', 'border-red-200', 'dark:bg-red-900/30', 'dark:text-red-200');
    } else {
      toast.classList.add('bg-green-50', 'text-green-800', 'border-green-200', 'dark:bg-green-900/30', 'dark:text-green-200');
    }
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(btnRegister) {
      btnRegister.innerText = registerStrings.processing;
      btnRegister.setAttribute('disabled', 'true');
    }

    const email = (document.getElementById('email-address') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

    if (password !== confirmPassword) {
      showToast(registerStrings.mismatch, 'error');
      if(btnRegister) {
        btnRegister.innerText = registerStrings.submit_btn;
        btnRegister.removeAttribute('disabled');
      }
      return;
    }

    try {
      // Use Payload CMS endpoint to register so Customer record is linked to tenant
      const res = await fetch(`${apiUrl}/api/register-customer`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password, tenantId }),
      });

      const resData = await res.json();

      if (!res.ok || !resData.success) {
        throw new Error(resData.error || registerStrings.failed);
      }

      // Auto login after registration
      const { error: signInError } = await supabase.auth.signInWithPassword({ email, password });

      if (signInError) {
        showToast(registerStrings.success, 'success');
        setTimeout(() => { window.location.href = '/'; }, 1500);
        return;
      }

      showToast(registerStrings.success, 'success');
      setTimeout(() => { window.location.href = '/'; }, 1000);

    } catch (err: any) {
      showToast(err.message || registerStrings.failed, 'error');
      if(btnRegister) {
        btnRegister.innerText = registerStrings.submit_btn;
        btnRegister.removeAttribute('disabled');
      }
    }
  });

  // Password Validation on Blur
  const passwordInputEl = document.getElementById('password') as HTMLInputElement;
  const passwordErrorEl = document.getElementById('password-error');
  passwordInputEl?.addEventListener('blur', () => {
    const val = passwordInputEl.value;
    if (val.length < 6) {
      passwordErrorEl?.classList.remove('hidden');
      passwordInputEl.classList.add('border-red-500', 'ring-red-500');
    } else {
      passwordErrorEl?.classList.add('hidden');
      passwordInputEl.classList.remove('border-red-500', 'ring-red-500');
    }
  });

  passwordInputEl?.addEventListener('input', () => {
    const val = passwordInputEl.value;
    if (val.length >= 6) {
      passwordErrorEl?.classList.add('hidden');
      passwordInputEl.classList.remove('border-red-500', 'ring-red-500');
    }
  });
</script>
