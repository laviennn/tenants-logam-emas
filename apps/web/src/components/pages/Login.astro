---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../SectionTitle.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';

interface Props {
  lang?: 'id' | 'en' | 'my';
}

const { lang: propLang } = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const loginStrings = {
  processing: t('login.processing'),
  failed: t('login.failed'),
  success: t('login.success'),
  submit_btn: t('login.submit_btn'),
};
---

<BaseLayout title={t('nav.login')}>
  <div class="min-h-[70vh] flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white dark:bg-surface-dark p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800">
      <div>
        <SectionTitle title={t('nav.login')} i18nTitle="nav.login" />
        <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
          <span data-i18n="login.or">{t('login.or')}</span>
          <a href={localizePath('/register', lang)} class="font-medium text-primary hover:text-primary-dark" data-i18n="login.register_link">
            {t('login.register_link')}
          </a>
        </p>
      </div>
      <form id="login-form" class="mt-8 space-y-6">
        <!-- Toast Notification Container -->
        <div id="toast" class="hidden rounded-lg p-4 mb-4 text-sm font-medium"></div>
        
        <div class="rounded-md shadow-sm space-y-4">
          <div>
            <label for="email-address" class="sr-only">Email address</label>
            <input id="email-address" name="email" type="email" autocomplete="email" required class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-700 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-primary focus:border-primary focus:z-10 sm:text-sm" placeholder="Email address">
          </div>
          <div>
            <label for="password" class="sr-only">Password</label>
            <div class="relative">
              <input id="password" name="password" type="password" autocomplete="current-password" required class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-700 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-primary focus:border-primary focus:z-10 sm:text-sm" placeholder="Password">
              <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 toggle-password" data-target="password">
                <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>
              </button>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-end mt-2">
          <div class="text-sm">
            <a href={localizePath('/forgot-password', lang)} class="font-medium text-primary hover:text-primary-dark" data-i18n="login.forgot_password">
              {t('login.forgot_password') || 'Lupa Password?'}
            </a>
          </div>
        </div>

        <div>
          <button type="submit" id="btn-login" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-primary hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors disabled:opacity-50" data-i18n="login.submit_btn">
            {t('login.submit_btn')}
          </button>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ loginStrings }}>
  window.__LOGIN_STRINGS = loginStrings;
</script>

<script>
  import { supabase } from '../../lib/supabase';

  const loginStrings = (window as any).__LOGIN_STRINGS;
  const form = document.getElementById('login-form') as HTMLFormElement;
  const btnLogin = document.getElementById('btn-login');
  const toast = document.getElementById('toast');

  const showToast = (message: string, type: 'error' | 'success') => {
    if(!toast) return;
    toast.innerText = message;
    toast.classList.remove('hidden', 'bg-red-50', 'text-red-800', 'border-red-200', 'bg-green-50', 'text-green-800', 'border-green-200');
    toast.classList.add('border');
    if(type === 'error') {
      toast.classList.add('bg-red-50', 'text-red-800', 'border-red-200', 'dark:bg-red-900/30', 'dark:text-red-200');
    } else {
      toast.classList.add('bg-green-50', 'text-green-800', 'border-green-200', 'dark:bg-green-900/30', 'dark:text-green-200');
    }
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(btnLogin) {
      btnLogin.innerText = loginStrings.processing;
      btnLogin.setAttribute('disabled', 'true');
    }

    const email = (document.getElementById('email-address') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    const { data, error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (error) {
      showToast(loginStrings.failed + ' ' + error.message, 'error');
      if(btnLogin) {
        btnLogin.innerText = loginStrings.submit_btn;
        btnLogin.removeAttribute('disabled');
      }
    } else {
      showToast(loginStrings.success, 'success');
      setTimeout(() => {
        window.location.href = '/';
      }, 1000);
    }
  });

  // Toggle Password Visibility
  document.querySelectorAll('.toggle-password').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;
      const input = document.getElementById(targetId) as HTMLInputElement;
      if (!input) return;
      
      if (input.type === 'password') {
        input.type = 'text';
        btn.innerHTML = `<svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7 1.274-4.057-5.064-7-9.542-7 4.477 0-8.268-2.943-9.542-7zm-5.04 1.524c-1.265-.438-2.432-1.112-3.473-1.983m1.42-1.42a3 3 0 114.243 4.243 3 3 0 01-4.243-4.243z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 3l18 18'></path></svg>`;
      } else {
        input.type = 'password';
        btn.innerHTML = `<svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>`;
      }
    });
  });
</script>
