---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../ProductCard.astro';
import { useTranslations } from '../../i18n/utils';
import { resolveTenant, getSiteSettings, getImageUrl } from '../../lib/cms';

interface Props {
  product: any;
  lang: 'id' | 'en' | 'my';
}

const { product, lang } = Astro.props;
const t = useTranslations(lang);
const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:3000';

// ── Resolve Tenant ─────────────────────────────────────────────
const hostname = Astro.url.hostname + (Astro.url.port ? `:${Astro.url.port}` : '');
const tenant = await resolveTenant(hostname);
const tenantId = tenant?.id;
const siteSettings = tenantId ? await getSiteSettings(tenantId, lang) : null;
const tenantFilter = tenantId ? `&where[tenant][equals]=${tenantId}` : '';

const id = product.id;

// ── Parallel Fetch Reviews + Related Products ─────────────────
const [reviewsData, relatedData] = await Promise.all([
  fetch(`${CMS_URL}/api/reviews?where[product][equals]=${id}${tenantFilter}&sort=-createdAt&limit=100`, { cache: 'no-store' })
    .then(r => r.ok ? r.json() : { docs: [] })
    .catch(() => ({ docs: [] })),
  fetch(`${CMS_URL}/api/products?where[category][equals]=${product.category?.id || product.category}&where[id][not_equals]=${id}${tenantFilter}&limit=4`, { cache: 'no-store' })
    .then(r => r.ok ? r.json() : { docs: [] })
    .catch(() => ({ docs: [] })),
]);

const reviews = reviewsData.docs || [];
const relatedProducts = relatedData.docs || [];

// Calculate Statistics
const totalReviews = reviews.length;
const averageRating = totalReviews > 0
  ? (reviews.reduce((acc: number, curr: any) => acc + curr.rating, 0) / totalReviews).toFixed(1)
  : '0.0';
const starCount = Math.floor(Number(averageRating));

const formatPrice = (price: number) =>
  new Intl.NumberFormat('id-ID', {
    style: 'currency',
    currency: 'IDR',
    minimumFractionDigits: 0,
  }).format(price);

const _getImageUrl = (image: any, size: string = 'card') => {
  if (!image) return '/img/emas_hero.jpeg';
  return getImageUrl(image, size);
};

const mainImageUrl = _getImageUrl(product.image, 'large');
const gallery = [
  { thumb: _getImageUrl(product.image, 'thumbnail'), large: mainImageUrl },
  ...(product.gallery || []).map((g: any) => ({
    thumb: _getImageUrl(g.image, 'thumbnail'),
    large: _getImageUrl(g.image, 'large'),
  })),
];

const categoryName = product.category?.name || 'Produk';
---

<BaseLayout title={product.name} tenantId={tenantId} siteSettings={siteSettings}>
  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12'>
    <!-- Breadcrumbs -->
    <nav class='flex mb-8 text-sm font-medium' aria-label='Breadcrumb'>
      <ol class='flex items-center space-x-2'>
        <li>
          <a href={`/${lang === 'id' ? '' : lang}`} class='text-gray-400 hover:text-primary transition-colors'>{t('nav.home')}</a>
        </li>
        <li class='flex items-center space-x-2'>
          <svg class='w-4 h-4 text-gray-300' fill='currentColor' viewBox='0 0 20 20'><path d='M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z'></path></svg>
          <a href={`/${lang === 'id' ? '' : lang + '/'}products`} class='text-gray-400 hover:text-primary transition-colors'>{t('nav.products')}</a>
        </li>
        <li class='flex items-center space-x-2'>
          <svg class='w-4 h-4 text-gray-300' fill='currentColor' viewBox='0 0 20 20'><path d='M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z'></path></svg>
          <span class='text-gray-900 dark:text-white truncate max-w-[150px] md:max-w-none'>{product.name}</span>
        </li>
      </ol>
    </nav>

    <div class='grid grid-cols-1 lg:grid-cols-12 gap-12'>
      <!-- Left: Image Gallery -->
      <div class='lg:col-span-7 space-y-4'>
        <div class='aspect-square rounded-3xl overflow-hidden bg-gray-50 dark:bg-gray-900 border border-gray-100 dark:border-gray-800 relative group'>
          <img id='main-image' src={mainImageUrl} alt={product.name} class='w-full h-full object-contain p-8 md:p-12 transition-all duration-500' />
        </div>
        {gallery.length > 1 && (
          <div class='flex gap-4 overflow-x-auto pb-2 no-scrollbar'>
            {gallery.map((img, idx) => (
              <button class:list={['gallery-thumb min-w-[80px] md:min-w-[100px] aspect-square rounded-2xl overflow-hidden border-2 transition-all p-2 bg-white dark:bg-gray-900', idx === 0 ? 'border-primary shadow-md' : 'border-gray-100 dark:border-gray-800 opacity-60 hover:opacity-100']} data-large={img.large}>
                <img src={img.thumb} alt={`${product.name} ${idx + 1}`} class='w-full h-full object-contain' />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Right: Product Info -->
      <div class='lg:col-span-5'>
        <div class='sticky top-24'>
          <div class='mb-2'>
            <span class='px-3 py-1 bg-primary/10 text-primary text-[10px] font-black uppercase tracking-widest rounded-full'>{categoryName}</span>
          </div>
          <h1 class='text-3xl md:text-4xl font-black text-gray-900 dark:text-white mb-4 leading-tight'>{product.name}</h1>
          <div class='flex items-center gap-4 mb-6'>
            <div class='flex text-yellow-400'>
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-5 h-5 ${i < Math.floor(product.rating || 5) ? 'fill-current' : 'text-gray-300 dark:text-gray-700'}`} viewBox='0 0 20 20'><path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' /></svg>
              ))}
            </div>
            <span class='text-sm text-gray-500 font-bold'>{(product.rating || 5).toFixed(1)} / 5.0</span>
            <span class='w-1 h-1 bg-gray-300 rounded-full'></span>
            <span class='text-sm text-gray-500 font-medium'>{product.soldCount || 0} {t('product.sold')}</span>
          </div>

          <div class='bg-gray-50 dark:bg-gray-900/50 p-6 rounded-3xl border border-gray-100 dark:border-gray-800 mb-8'>
            <div class='flex flex-col gap-1 mb-2'>
              {product.strikePrice && <span class='text-lg text-gray-400 line-through font-medium'>{formatPrice(product.strikePrice)}</span>}
              <div class='text-4xl font-black text-[#d97706]'>{formatPrice(product.price)}</div>
            </div>
            <div class='flex items-center gap-2 text-sm'>
              <span class='text-gray-500'>{t('product.stock')}:</span>
              <span class:list={['font-bold', product.stock > 0 ? 'text-green-600' : 'text-red-600']}>{product.stock > 0 ? `${product.stock} pcs` : 'Habis'}</span>
            </div>
          </div>

          <div class='flex items-center gap-4 mb-8'>
            <span class='text-sm font-bold text-gray-700 dark:text-gray-300'>{t('product.quantity')}:</span>
            <div class='flex items-center border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden bg-white dark:bg-surface-dark'>
              <button id='qty-minus' class='px-4 py-2 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-xl font-bold'>-</button>
              <input id='qty-input' type='number' value='1' min='1' max={product.stock} class='w-16 text-center border-x border-gray-200 dark:border-gray-700 bg-transparent focus:outline-none font-bold text-gray-900 dark:text-white' />
              <button id='qty-plus' class='px-4 py-2 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-xl font-bold'>+</button>
            </div>
          </div>

          <div class='flex flex-col sm:flex-row gap-4 mb-10'>
            <button id='btn-add-cart' class='flex-1 flex items-center justify-center gap-3 py-4 px-6 rounded-2xl border-2 border-primary text-primary font-black hover:bg-primary/5 transition-all'>
              <span data-i18n="index.cart">{t('index.cart')}</span>
            </button>
            <button id='btn-buy-now' class='flex-1 flex items-center justify-center gap-3 py-4 px-6 rounded-2xl bg-[#d97706] hover:bg-[#b45309] text-white font-black transition-all shadow-lg shadow-primary/20'>
              <span data-i18n="index.buy">{t('index.buy')}</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Details Section -->
    <div class='mt-20 border-t border-gray-100 dark:border-gray-800 pt-12'>
      <div class='grid grid-cols-1 lg:grid-cols-12 gap-12'>
        <div class='lg:col-span-8'>
          <div class='mb-12'>
            <h2 class='text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3'><span data-i18n="product.description">{t('product.description')}</span></h2>
            <div class='prose dark:prose-invert max-w-none text-gray-600 dark:text-gray-400 leading-relaxed'>
              {product.description ? <div class='whitespace-pre-line'>{product.description}</div> : <p>No description available.</p>}
            </div>
          </div>
          <div>
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 pb-10 border-b border-gray-100 dark:border-gray-800">
              <div>
                <h2 class='text-3xl font-black text-gray-900 dark:text-white mb-2 flex items-center gap-3'>
                  <span data-i18n="product.reviews">{t('product.reviews')}</span>
                </h2>
                <div class="flex items-center gap-4">
                  <div class="flex items-center gap-1.5 bg-yellow-50 dark:bg-yellow-900/30 px-3 py-1.5 rounded-xl border border-yellow-100 dark:border-yellow-800">
                    <span class="text-xl font-black text-yellow-700 dark:text-yellow-400">{averageRating}</span>
                    <div class="flex text-yellow-400">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <svg class={`w-4 h-4 ${i < starCount ? 'fill-current' : 'text-gray-200 dark:text-gray-700'}`} viewBox='0 0 20 20'><path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' /></svg>
                      ))}
                    </div>
                  </div>
                  <span class="text-sm font-bold text-gray-500 uppercase tracking-widest">{totalReviews} Ulasan Pelanggan</span>
                </div>
              </div>
            </div>

            <div class='space-y-6'>
              {reviews.length > 0 ? reviews.map((rev: any) => (
                <div class='bg-gray-50 dark:bg-gray-900/50 p-6 rounded-2xl border border-gray-100 dark:border-gray-800'>
                  <div class='flex justify-between items-start mb-4'>
                    <div>
                      <p class='font-bold text-gray-900 dark:text-white'>{rev.userName}</p>
                      <div class='flex text-yellow-400 mt-1'>
                        {Array.from({ length: 5 }).map((_, i) => (
                          <svg class={`w-3.5 h-3.5 ${i < rev.rating ? 'fill-current' : 'text-gray-300'}`} viewBox='0 0 20 20'><path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' /></svg>
                        ))}
                      </div>
                    </div>
                    <span class='text-xs text-gray-400'>{new Date(rev.createdAt).toLocaleDateString(lang === 'id' ? 'id-ID' : 'en-US')}</span>
                  </div>
                  <p class='text-gray-600 dark:text-gray-400 text-sm italic'>"{rev.comment}"</p>
                  
                  {rev.image && (
                    <div class='mt-5 max-w-sm rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-800 shadow-sm bg-gray-50 dark:bg-gray-900'>
                      <img
                        src={_getImageUrl(rev.image)}
                        alt={`Review by ${rev.userName}`}
                        class='w-full h-auto block'
                        loading="lazy"
                      />
                    </div>
                  )}
                </div>
              )) : <p class='text-gray-400 italic text-center py-8 border-2 border-dashed border-gray-100 dark:border-gray-800 rounded-2xl'>{t('product.no_reviews') || 'Belum ada ulasan.'}</p>}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ product, mainImageUrl }}>
  // Basic logic for gallery and qty
  const mainImageEl = document.getElementById('main-image');
  document.querySelectorAll('.gallery-thumb').forEach(thumb => {
    thumb.addEventListener('click', () => {
      mainImageEl.src = thumb.dataset.large;
      document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('border-primary'));
      thumb.classList.add('border-primary');
    });
  });

  const qtyInput = document.getElementById('qty-input');
  document.getElementById('qty-minus')?.addEventListener('click', () => { if (qtyInput.value > 1) qtyInput.value--; });
  document.getElementById('qty-plus')?.addEventListener('click', () => { if (qtyInput.value < product.stock) qtyInput.value++; });

  document.getElementById('btn-add-cart')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('add-to-cart-qty', { detail: { ...product, image: mainImageUrl, quantity: parseInt(qtyInput.value) } }));
  });
  document.getElementById('btn-buy-now')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('buy-now-qty', { detail: { ...product, image: mainImageUrl, quantity: parseInt(qtyInput.value) } }));
  });
</script>

<script>
  import { addToCart } from '../../lib/cart';
  window.addEventListener('add-to-cart-qty', (e: any) => { addToCart(e.detail, e.detail.quantity); });
  window.addEventListener('buy-now-qty', (e: any) => { addToCart(e.detail, e.detail.quantity); window.location.href = '/checkout'; });
</script>
