---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../ProductCard.astro';
import { useTranslations } from '../../i18n/utils';
import { resolveTenant, getSiteSettings, getImageUrl, getDefaultLocale } from '../../lib/cms';
import { formatCurrency } from '../../utils/currency';

interface Props {
  product: any;
  lang: 'id' | 'en' | 'my';
  prefetchedReviews?: any[];
  prefetchedRelated?: any[];
}

const { product, lang, prefetchedReviews, prefetchedRelated } = Astro.props;
const t = useTranslations(lang);
const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:3000';

// ── Resolve Tenant ─────────────────────────────────────────────
const hostname = Astro.url.hostname + (Astro.url.port ? `:${Astro.url.port}` : '');
const tenant = await resolveTenant(hostname);
const tenantId = tenant?.id;
const siteSettings = tenantId ? await getSiteSettings(tenantId, lang) : null;
const tenantFilter = tenantId ? `&where[tenant][equals]=${tenantId}` : '';
const defaultLocale = getDefaultLocale();
const isBrandedTheme = tenant?.theme_layout === 'luxury-branded';
const enableCustomerReviews = tenant?.enableCustomerReviews !== false;

const id = product.id;

// ── Conditional Fetch Reviews + Related Products ─────────────────
let reviewsData = { docs: prefetchedReviews || [] };
let relatedData = { docs: prefetchedRelated || [] };

if (!prefetchedReviews || !prefetchedRelated) {
  const [fetchedReviews, fetchedRelated] = await Promise.all([
    fetch(`${CMS_URL}/api/reviews?where[product][equals]=${id}${tenantFilter}&sort=-createdAt&limit=100`, { cache: 'no-store' })
      .then(r => r.ok ? r.json() : { docs: [] })
      .catch(() => ({ docs: [] })),
    fetch(`${CMS_URL}/api/products?where[category][equals]=${product.category?.id || product.category}&where[id][not_equals]=${id}${tenantFilter}&limit=4&locale=${defaultLocale}`, { cache: 'no-store' })
      .then(r => r.ok ? r.json() : { docs: [] })
      .catch(() => ({ docs: [] })),
  ]);
  reviewsData = fetchedReviews;
  relatedData = fetchedRelated;
}

const reviews = reviewsData.docs || [];
const relatedProducts = relatedData.docs || [];

// Calculate Statistics
const totalReviews = reviews.length;
const averageRating = totalReviews > 0
  ? (reviews.reduce((acc: number, curr: any) => acc + curr.rating, 0) / totalReviews).toFixed(1)
  : '0.0';
const starCount = Math.floor(Number(averageRating));


const _getImageUrl = (image: any, size: string = 'card') => {
  if (!image) return '/img/emas_hero.jpeg';
  return getImageUrl(image, size);
};

const mainImageUrl = _getImageUrl(product.image, 'large');
const gallery = [
  { thumb: _getImageUrl(product.image, ''), large: mainImageUrl }, // Menggunakan gambar original jika thumbnail size bermasalah
  ...(product.gallery || []).map((g: any) => ({
    thumb: _getImageUrl(g.image, ''),
    large: _getImageUrl(g.image, 'large'),
  })),
];

const categoryName = product.category?.name || 'Produk';

let finalPrice = product.price;
let hasDiscount = false;
let displayedDiscount = 0;
const discountPercent = product.discountPercent || 0;
const spreadPrice = product.spreadPrice || 0;

if (discountPercent !== 0 || spreadPrice !== 0) {
  hasDiscount = true;
  let discounted = product.price * (1 - (discountPercent / 100));
  finalPrice = discounted + spreadPrice;
  if (finalPrice < 0) finalPrice = 0;
  
  if (product.price > 0 && finalPrice < product.price) {
    displayedDiscount = Math.round(((product.price - finalPrice) / product.price) * 100);
  }
} else if (product.strikePrice && product.strikePrice > product.price) {
  hasDiscount = true;
  finalPrice = product.price;
  displayedDiscount = Math.round(((product.strikePrice - product.price) / product.strikePrice) * 100);
}

const originalPrice = hasDiscount ? (discountPercent !== 0 || spreadPrice !== 0 ? product.price : product.strikePrice) : null;
---

<BaseLayout title={product.name} tenantId={tenantId} siteSettings={siteSettings}>
  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12'>
    <!-- Breadcrumbs -->
    <nav class='flex mb-8 text-sm font-medium' aria-label='Breadcrumb'>
      <ol class='flex items-center space-x-2'>
        <li>
          <a href={`/${lang === 'id' ? '' : lang}`} class='text-gray-400 hover:text-primary transition-colors'>{t('nav.home')}</a>
        </li>
        <li class='flex items-center space-x-2'>
          <svg class='w-4 h-4 text-gray-300' fill='currentColor' viewBox='0 0 20 20'><path d='M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z'></path></svg>
          <a href={`/${lang === 'id' ? '' : lang + '/'}products`} class='text-gray-400 hover:text-primary transition-colors'>{t('nav.products')}</a>
        </li>
        <li class='flex items-center space-x-2'>
          <svg class='w-4 h-4 text-gray-300' fill='currentColor' viewBox='0 0 20 20'><path d='M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z'></path></svg>
          <span class='text-gray-900 dark:text-white truncate max-w-[150px] md:max-w-none'>{product.name}</span>
        </li>
      </ol>
    </nav>

    <div class='grid grid-cols-1 lg:grid-cols-12 gap-12'>
      <!-- Left: Image Gallery -->
      <div class='lg:col-span-7 space-y-4'>
        <div class='aspect-square rounded-3xl overflow-hidden bg-gray-50 dark:bg-gray-900 border border-gray-100 dark:border-gray-800 relative group'>
          <img id='main-image' src={mainImageUrl} alt={product.name} class='w-full h-full object-contain p-8 md:p-12 transition-all duration-500' />
        </div>
        {gallery.length > 1 && (
          <div class='flex gap-4 overflow-x-auto pb-2 no-scrollbar'>
            {gallery.map((img, idx) => (
              <button class:list={['gallery-thumb w-20 h-20 md:w-24 md:h-24 flex-shrink-0 rounded-2xl overflow-hidden border-2 transition-all p-2 bg-white dark:bg-gray-900', idx === 0 ? 'border-primary shadow-md' : 'border-gray-100 dark:border-gray-800 opacity-60 hover:opacity-100']} data-large={img.large}>
                <img src={img.thumb} alt={`${product.name} ${idx + 1}`} class='w-full h-full object-contain' />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Right: Product Info -->
      <div class='lg:col-span-5'>
        <div class='sticky top-24'>
          {isBrandedTheme ? (
            <>
              <h1 class='text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4 uppercase tracking-wide' style="font-family: var(--font-family, 'Fjalla One', sans-serif);">{product.name}</h1>
              
              <div class='flex flex-col gap-1 mb-8'>
                <div class="flex items-center gap-3">
                  <div class='text-2xl md:text-3xl font-black text-red-600'>{formatCurrency(finalPrice)}</div>
                  {displayedDiscount > 0 && (
                    <span class='bg-red-600 text-white text-xs font-black px-2 py-1 uppercase tracking-wider'>
                      SALE -{displayedDiscount}%
                    </span>
                  )}
                </div>
                {originalPrice && <span class='text-sm text-gray-400 line-through font-medium'>{formatCurrency(originalPrice)}</span>}
              </div>

              {product.colors && product.colors.length > 0 && (
                <div class="mb-6">
                  <span class="text-sm font-bold text-gray-700 dark:text-gray-300 block mb-2 uppercase tracking-widest">Color</span>
                  <div class="flex flex-wrap gap-2" id="color-selector">
                    {product.colors.map((colorObj: any, index: number) => (
                      <button type="button" class={`color-btn px-4 py-2 border text-sm font-bold uppercase transition-all ${index === 0 ? 'border-gray-900 dark:border-white text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-800 selected' : 'border-gray-200 dark:border-gray-700 text-gray-500 hover:border-gray-400'}`}>
                        {colorObj.name}
                      </button>
                    ))}
                  </div>
                </div>
              )}

              <div class='mb-8'>
                <span class="text-sm font-bold text-gray-700 dark:text-gray-300 block mb-2 uppercase tracking-widest">Quantity</span>
                <div class='inline-flex items-center border border-gray-200 dark:border-gray-700 bg-white dark:bg-surface-dark'>
                  <button type="button" id='qty-minus' class='px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-lg font-bold'>-</button>
                  <input id='qty-input' type='number' value='1' min='1' max={product.stock} class='w-16 text-center border-x border-gray-200 dark:border-gray-700 bg-transparent focus:outline-none font-bold text-gray-900 dark:text-white' />
                  <button type="button" id='qty-plus' class='px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-lg font-bold'>+</button>
                </div>
              </div>

              <div class='flex flex-row gap-2 mb-10'>
                <button id='btn-buy-now' class='flex-1 flex items-center justify-center py-4 px-2 rounded-none bg-[#FFDF00] hover:bg-[#e6c800] text-black text-sm font-black transition-all uppercase tracking-wider'>
                  BUY NOW
                </button>
                <button id='btn-add-cart' class='flex-1 flex items-center justify-center py-4 px-2 rounded-none bg-[#0047AB] hover:bg-[#003580] text-white text-sm font-black transition-all uppercase tracking-wider'>
                  ADD TO CART
                </button>
              </div>
            </>
          ) : (
            <>
              <div class='mb-2'>
                <span class='px-3 py-1 bg-primary/10 text-primary text-[10px] font-black uppercase tracking-widest rounded-full'>{categoryName}</span>
              </div>
              <h1 class='text-3xl md:text-4xl font-black text-gray-900 dark:text-white mb-4 leading-tight'>{product.name}</h1>
              <div class='flex items-center gap-4 mb-6'>
                {enableCustomerReviews && (
                  <>
                    <div class='flex text-yellow-400'>
                      {Array.from({ length: 5 }).map((_, i) => (
                        <svg class={`w-5 h-5 ${i < Math.floor(product.rating || 5) ? 'fill-current' : 'text-gray-300 dark:text-gray-700'}`} viewBox='0 0 20 20'><path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' /></svg>
                      ))}
                    </div>
                    <span class='text-sm text-gray-500 font-bold'>{(product.rating || 5).toFixed(1)} / 5.0</span>
                    <span class='w-1 h-1 bg-gray-300 rounded-full'></span>
                  </>
                )}
                <span class='text-sm text-gray-500 font-medium'>{product.soldCount || 0} {t('product.sold')}</span>
              </div>

              <div class='bg-gray-50 dark:bg-gray-900/50 p-6 rounded-3xl border border-gray-100 dark:border-gray-800 mb-8'>
                <div class='flex flex-col gap-1 mb-2'>
                  <div class="flex items-center gap-3">
                    <div class='text-4xl font-black text-[var(--color-product-price)]'>{formatCurrency(finalPrice)}</div>
                    {displayedDiscount > 0 && (
                      <span class='bg-red-600 text-white text-sm font-black px-2 py-1 rounded-lg'>
                        -{displayedDiscount}%
                      </span>
                    )}
                  </div>
                  {originalPrice && <span class='text-lg text-gray-400 line-through font-medium'>{formatCurrency(originalPrice)}</span>}
                </div>
                <div class='flex items-center gap-2 text-sm'>
                  <span class='text-gray-500'>{t('product.stock')}:</span>
                  <span class:list={['font-bold', product.stock > 0 ? 'text-green-600' : 'text-red-600']}>{product.stock > 0 ? `${product.stock} pcs` : 'Habis'}</span>
                </div>
              </div>

              <div class='flex items-center gap-4 mb-8'>
                <span class='text-sm font-bold text-gray-700 dark:text-gray-300'>{t('product.quantity')}:</span>
                <div class='flex items-center border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden bg-white dark:bg-surface-dark'>
                  <button type="button" id='qty-minus' class='px-4 py-2 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-xl font-bold'>-</button>
                  <input id='qty-input' type='number' value='1' min='1' max={product.stock} class='w-16 text-center border-x border-gray-200 dark:border-gray-700 bg-transparent focus:outline-none font-bold text-gray-900 dark:text-white' />
                  <button type="button" id='qty-plus' class='px-4 py-2 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-xl font-bold'>+</button>
                </div>
              </div>

              <div class='flex flex-col sm:flex-row gap-4 mb-10'>
                <button id='btn-add-cart' class='flex-1 flex items-center justify-center gap-3 py-4 px-6 rounded-2xl border-2 border-primary text-primary font-black hover:bg-primary/5 transition-all'>
                  <span data-i18n="index.cart">{t('index.cart')}</span>
                </button>
                <button id='btn-buy-now' class='flex-1 flex items-center justify-center gap-3 py-4 px-6 rounded-2xl bg-[var(--color-cart-button)] hover:opacity-90 text-white font-black transition-all shadow-lg shadow-primary/20'>
                  <span data-i18n="index.buy">{t('index.buy')}</span>
                </button>
              </div>
            </>
          )}

          {isBrandedTheme && (
            <!-- Trust Badges Section -->
            <div class="border-t border-gray-200 dark:border-gray-800 pt-6 mt-6 space-y-4">
              <!-- Free Shipping Badge -->
              <div class="flex items-center gap-3">
                <div class="text-gray-900 dark:text-white flex-shrink-0">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2 8h4M0 12h6M2 16h4" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 18H8a2 2 0 01-2-2V7a2 2 0 012-2h9a2 2 0 012 2v9a2 2 0 01-2 2h-1" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9h3l2 3v4a2 2 0 01-2 2h-3" />
                    <circle cx="10" cy="18" r="2" stroke="currentColor" fill="none" stroke-width="2" />
                    <circle cx="19" cy="18" r="2" stroke="currentColor" fill="none" stroke-width="2" />
                  </svg>
                </div>
                <span class="text-[#0f5b3f] dark:text-[#10b981] font-bold text-base">Free Shipping</span>
              </div>

              <!-- 100% Authentic Badge -->
              <div class="flex items-start gap-3">
                <div class="text-gray-900 dark:text-white flex-shrink-0 mt-0.5">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4" stroke-width="2.5" />
                  </svg>
                </div>
                <div class="flex flex-col">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[#0f5b3f] dark:text-[#10b981] font-bold text-base">100% Authentic</span>
                    <button type="button" id="authentic-info-trigger" class="focus:outline-none flex-shrink-0" aria-label="Authenticity info">
                      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="10" fill="#b9bec9" class="fill-[#b9bec9] dark:fill-gray-600 transition-colors" />
                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3 M12 17h.01" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </button>
                  </div>
                  <span class="text-gray-400 dark:text-gray-500 text-sm font-medium">or your money back 💎</span>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Details Section -->
    <div class='mt-20 border-t border-gray-100 dark:border-gray-800 pt-12'>
      <div class='grid grid-cols-1 lg:grid-cols-12 gap-12'>
        <div class='lg:col-span-8'>
          <div class='mb-12'>
            <h2 class='text-2xl font-black text-gray-900 dark:text-white mb-6 flex items-center gap-3'><span data-i18n="product.description">{t('product.description')}</span></h2>
            <div class='prose dark:prose-invert max-w-none text-gray-600 dark:text-gray-400 leading-relaxed'>
              {product.description ? <div class='whitespace-pre-line'>{product.description}</div> : <p>No description available.</p>}
            </div>
          </div>
          {enableCustomerReviews && (
            <div>
              <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 pb-10 border-b border-gray-100 dark:border-gray-800">
                <div>
                  <h2 class='text-3xl font-black text-gray-900 dark:text-white mb-2 flex items-center gap-3'>
                    <span data-i18n="product.reviews">{t('product.reviews')}</span>
                  </h2>
                  <div class="flex items-center gap-4">
                    <div class="flex items-center gap-1.5 bg-yellow-50 dark:bg-yellow-900/30 px-3 py-1.5 rounded-xl border border-yellow-100 dark:border-yellow-800">
                      <span class="text-xl font-black text-yellow-700 dark:text-yellow-400">{averageRating}</span>
                      <div class="flex text-yellow-400">
                        {Array.from({ length: 5 }).map((_, i) => (
                          <svg class={`w-4 h-4 ${i < starCount ? 'fill-current' : 'text-gray-200 dark:text-gray-700'}`} viewBox='0 0 20 20'><path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' /></svg>
                        ))}
                      </div>
                    </div>
                    <span class="text-sm font-bold text-gray-500 uppercase tracking-widest">{totalReviews} Ulasan Pelanggan</span>
                  </div>
                </div>
              </div>

              <div class='space-y-6'>
                {reviews.length > 0 ? reviews.map((rev: any) => (
                  <div class='bg-gray-50 dark:bg-gray-900/50 p-6 rounded-2xl border border-gray-100 dark:border-gray-800'>
                    <div class='flex justify-between items-start mb-4'>
                      <div>
                        <p class='font-bold text-gray-900 dark:text-white'>{rev.userName}</p>
                        <div class='flex text-yellow-400 mt-1'>
                          {Array.from({ length: 5 }).map((_, i) => (
                            <svg class={`w-3.5 h-3.5 ${i < rev.rating ? 'fill-current' : 'text-gray-300'}`} viewBox='0 0 20 20'><path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' /></svg>
                          ))}
                        </div>
                      </div>
                      <span class='text-xs text-gray-400'>{new Date(rev.createdAt).toLocaleDateString(lang === 'id' ? 'id-ID' : 'en-US')}</span>
                    </div>
                    <p class='text-gray-600 dark:text-gray-400 text-sm italic'>"{rev.comment}"</p>
                    
                    {rev.image && (
                      <div class='mt-5 max-w-sm rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-800 shadow-sm bg-gray-50 dark:bg-gray-900'>
                        <img
                          src={_getImageUrl(rev.image)}
                          alt={`Review by ${rev.userName}`}
                          class='w-full h-auto block'
                          loading="lazy"
                        />
                      </div>
                    )}
                  </div>
                )) : <p class='text-gray-400 italic text-center py-8 border-2 border-dashed border-gray-100 dark:border-gray-800 rounded-2xl'>{t('product.no_reviews') || 'Belum ada ulasan.'}</p>}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  {isBrandedTheme && (
    <!-- Authenticity Info Modal -->
    <div id="authenticity-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300 hidden">
      <div class="bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-3xl p-6 md:p-8 max-w-xl w-full shadow-2xl transform scale-95 transition-all duration-300 pointer-events-auto" id="authenticity-modal-content">
        <div class="flex justify-between items-start mb-6">
          <h3 class="text-xl font-black text-gray-900 dark:text-white uppercase tracking-wider">100% Authentic</h3>
          <button type="button" id="authenticity-modal-close" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 text-sm font-black uppercase tracking-wider transition-colors flex items-center gap-1.5 focus:outline-none">
            <span>Close</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        
        <div class="space-y-4 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
          <p class="font-extrabold text-gray-900 dark:text-white text-base">Curated with Respect 💎</p>
          <p>
            At <strong class="text-gray-900 dark:text-white font-bold">Lux Brand Store</strong>, we honor every designer’s craftsmanship and rights. Our trained team checks each item through several steps so that you can feel confident and informed about your purchase.
          </p>
          <p>
            We look closely at the leather, stitching, lining, hardware engravings, serial numbers, date codes, and hologram stickers. We also assess design proportions, brand markings, and craftsmanship to confirm that each item meets the original luxury standards. We guarantee every product is 100% authentic, or you get your money back.
          </p>
          <p class="text-xs text-gray-400 dark:text-gray-500 border-t border-gray-100 dark:border-gray-800 pt-4">
            Lux Brand Store operates independently and is not affiliated with the brands featured. All trademarks and logos are used solely for identification and remain the property of their respective owners.
          </p>
        </div>
      </div>
    </div>
  )}

  <script is:inline define:vars={{ product, mainImageUrl, finalPrice }}>
    // Basic logic for gallery and qty
    const mainImageEl = document.getElementById('main-image');
    document.querySelectorAll('.gallery-thumb').forEach(thumb => {
      thumb.addEventListener('click', () => {
        mainImageEl.src = thumb.dataset.large;
        document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('border-primary'));
        thumb.classList.add('border-primary');
      });
    });

    const qtyInput = document.getElementById('qty-input');
    const qtyMinus = document.getElementById('qty-minus');
    const qtyPlus = document.getElementById('qty-plus');

    console.log('[Qty Selector Init]', {
      qtyInput: qtyInput,
      qtyMinus: qtyMinus,
      qtyPlus: qtyPlus,
      productStock: product?.stock,
      inputMax: qtyInput?.getAttribute('max')
    });

    if (qtyMinus && qtyInput) {
      qtyMinus.addEventListener('click', (e) => {
        e.preventDefault();
        let currentVal = parseInt(qtyInput.value, 10);
        console.log('[Qty Minus Clicked]', { currentVal });
        if (isNaN(currentVal) || currentVal <= 1) {
          qtyInput.value = '1';
        } else {
          qtyInput.value = (currentVal - 1).toString();
        }
        console.log('[Qty Minus Set Value]', { newVal: qtyInput.value });
      });
    } else {
      console.warn('[Qty Selector] qtyMinus or qtyInput not found for minus handler');
    }

    if (qtyPlus && qtyInput) {
      qtyPlus.addEventListener('click', (e) => {
        e.preventDefault();
        let currentVal = parseInt(qtyInput.value, 10);
        const maxStock = parseInt(qtyInput.getAttribute('max'), 10) || (product && product.stock) || 999;
        console.log('[Qty Plus Clicked]', { currentVal, maxStock });
        if (isNaN(currentVal)) {
          qtyInput.value = '1';
          return;
        }
        if (currentVal < maxStock) {
          qtyInput.value = (currentVal + 1).toString();
        }
        console.log('[Qty Plus Set Value]', { newVal: qtyInput.value });
      });
    } else {
      console.warn('[Qty Selector] qtyPlus or qtyInput not found for plus handler');
    }

    // Handle color selection
    let selectedColor = product.colors && product.colors.length > 0 ? product.colors[0].name : null;
    document.querySelectorAll('.color-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('.color-btn').forEach(b => {
          b.classList.remove('border-gray-900', 'dark:border-white', 'text-gray-900', 'dark:text-white', 'bg-gray-50', 'dark:bg-gray-800', 'selected');
          b.classList.add('border-gray-200', 'dark:border-gray-700', 'text-gray-500');
        });
        const target = e.currentTarget;
        target.classList.remove('border-gray-200', 'dark:border-gray-700', 'text-gray-500');
        target.classList.add('border-gray-900', 'dark:border-white', 'text-gray-900', 'dark:text-white', 'bg-gray-50', 'dark:bg-gray-800', 'selected');
        selectedColor = target.innerText;
      });
    });

    document.getElementById('btn-add-cart')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('add-to-cart-qty', { detail: { ...product, price: finalPrice, image: mainImageUrl, quantity: parseInt(qtyInput.value), selectedColor } }));
    });
    document.getElementById('btn-buy-now')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('buy-now-qty', { detail: { ...product, price: finalPrice, image: mainImageUrl, quantity: parseInt(qtyInput.value), selectedColor } }));
    });

    // Authenticity Modal Logic
    const trigger = document.getElementById('authentic-info-trigger');
    const modal = document.getElementById('authenticity-modal');
    const modalClose = document.getElementById('authenticity-modal-close');
    const modalContent = document.getElementById('authenticity-modal-content');

    let isModalLocked = false;
    let hoverTimeout;

    function showModal(isClick = false) {
      if (!modal || !modalContent) return;
      modal.classList.remove('hidden');
      modal.offsetWidth; // Force reflow
      modal.classList.remove('opacity-0');
      modal.classList.add('opacity-100');
      modalContent.classList.remove('scale-95');
      modalContent.classList.add('scale-100');
      
      if (isClick || isModalLocked) {
        modal.classList.remove('pointer-events-none');
        modal.classList.add('pointer-events-auto');
      } else {
        modal.classList.remove('pointer-events-auto');
        modal.classList.add('pointer-events-none');
      }
    }

    function hideModal() {
      if (!modal || !modalContent || isModalLocked) return;
      modal.classList.remove('opacity-100', 'pointer-events-auto');
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalContent.classList.remove('scale-100');
      modalContent.classList.add('scale-95');
      setTimeout(() => {
        if (modal.classList.contains('opacity-0')) {
          modal.classList.add('hidden');
        }
      }, 300);
    }

    function forceHideModal() {
      if (!modal || !modalContent) return;
      isModalLocked = false;
      modal.classList.remove('opacity-100', 'pointer-events-auto');
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalContent.classList.remove('scale-100');
      modalContent.classList.add('scale-95');
      setTimeout(() => {
        if (modal.classList.contains('opacity-0')) {
          modal.classList.add('hidden');
        }
      }, 300);
    }

    trigger?.addEventListener('mouseenter', () => {
      clearTimeout(hoverTimeout);
      showModal(false);
    });

    trigger?.addEventListener('mouseleave', () => {
      hoverTimeout = setTimeout(() => {
        hideModal();
      }, 200);
    });

    modalContent?.addEventListener('mouseenter', () => {
      clearTimeout(hoverTimeout);
    });

    modalContent?.addEventListener('mouseleave', () => {
      hoverTimeout = setTimeout(() => {
        hideModal();
      }, 200);
    });

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isModalLocked = true;
      showModal(true);
    });

    modalClose?.addEventListener('click', (e) => {
      e.stopPropagation();
      forceHideModal();
    });

    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        forceHideModal();
      }
    });
  </script>

  <script>
    import { addToCart } from '../../lib/cart';
    window.addEventListener('add-to-cart-qty', (e: any) => { addToCart(e.detail, e.detail.quantity); });
    window.addEventListener('buy-now-qty', (e: any) => { addToCart(e.detail, e.detail.quantity); window.location.href = '/checkout'; });
  </script>
</BaseLayout>
