---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../SectionTitle.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { resolveTenant, getSiteSettings, getImageUrl } from '../../lib/cms';
import { formatCurrency } from '../../utils/currency';

// ── Region config (SSG build-time, read from ENV) ──────────────
const regionCode = import.meta.env.PUBLIC_TENANT_REGION === 'MY' ? 'MY' : 'ID';
const isMY = regionCode === 'MY';

interface Props {
  lang?: 'id' | 'en' | 'my';
}

const { lang: propLang } = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// ── Resolve Tenant ────────────────────────────────────────
const hostname =
  Astro.url.hostname + (Astro.url.port ? `:${Astro.url.port}` : '');
const tenant = await resolveTenant(hostname);
const tenantId = tenant?.id;

const siteSettings = (tenantId
  ? await getSiteSettings(tenantId, lang)
  : null) || {
  shippingMethods: [],
  paymentChannels: [],
  whatsappNumber: '6281234567890',
};

const brandName = siteSettings?.brandName || tenant?.brandName || 'Logam Mulia';

const checkoutStrings = {
  errCompleteForm: t('checkout.err_complete_form'),
  errShipping: t('checkout.err_shipping'),
  errPayment: t('checkout.err_payment'),
  errPhoneMy: t('checkout.err_phone_my'),
  errPhoneId: t('checkout.err_phone_id'),
  errPasswordMismatch: t('checkout.err_password_mismatch'),
  errSignupFailed: t('checkout.err_signup_failed'),
  errEmailInvalid: t('checkout.err_email_invalid'),
  errNoProof: t('checkout.err_no_proof'),
  errFileSize: t('checkout.err_file_size'),
  statusUploading: t('checkout.status_uploading'),
  statusConfirmWa: t('checkout.status_confirm_wa'),
  errUploadFailed: t('checkout.err_upload_failed'),
  errServer: t('checkout.err_server'),
  errNetwork: t('checkout.err_network'),
  errLoginFailed: t('checkout.err_login_failed'),
  waGreetingMy: t('checkout.wa_greeting_my').replace('{brandName}', brandName),
  waGreetingId: t('checkout.wa_greeting_id').replace('{brandName}', brandName),
};
---

<BaseLayout
  title='Checkout'
  tenantId={tenantId}
  siteSettings={siteSettings}>
  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12'>
    <SectionTitle
      title={t('checkout.title')}
      subtitle={t('checkout.subtitle')}
      i18nTitle='checkout.title'
      i18nSubtitle='checkout.subtitle'
    />

    <div
      id='checkout-container'
      class='grid grid-cols-1 lg:grid-cols-12 gap-12 hidden mt-8'>
      <!-- Form Kiri -->
      <div class='lg:col-span-7'>
        <form
          id='checkout-form'
          class='space-y-8'>
          <!-- Data Pembeli -->
          <div
            class='bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800'>
            <h3
              data-i18n='checkout.buyer_data'
              class='text-xl font-bold mb-4 text-gray-900 dark:text-white'>
              {t('checkout.buyer_data')}
            </h3>
            <div class='grid grid-cols-1 md:grid-cols-2 gap-4'>
              <div>
                <label
                  data-i18n='checkout.full_name'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  >{t('checkout.full_name')}</label
                >
                <input
                  type='text'
                  id='name'
                  required
                  class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                />
              </div>
              <div>
                <label
                  data-i18n='checkout.email'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  >{t('checkout.email')}</label
                >
                <input
                  type='email'
                  id='email'
                  required
                  class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                />
              </div>
              <div class='md:col-span-2'>
                <label
                  data-i18n='checkout.whatsapp'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  >{t('checkout.whatsapp')}</label
                >
                <input
                  type='tel'
                  id='phone'
                  required
                  class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  placeholder={isMY
                    ? 'Contoh: 0123456789 atau 60123456789'
                    : 'Contoh: 081234567890'}
                />
                <p
                  id='phone-error'
                  class='text-red-500 text-[11px] font-bold mt-1 hidden uppercase tracking-wider bg-red-50 dark:bg-red-900/20 p-2 rounded border border-red-100 dark:border-red-900/30'>
                  {
                    isMY
                      ? '⚠️ Format nombor salah. Mesti bermula 01... atau 60... dan nombor sahaja.'
                      : '⚠️ Format nomor salah. Harus diawali 08... atau 62... dan hanya angka.'
                  }
                </p>
              </div>
            </div>

            <!-- Password Info -->
            <div
              id='password-section'
              class='mt-6 border-t border-gray-200 dark:border-gray-700 pt-6'>
              <div
                class='bg-yellow-50 dark:bg-yellow-900/30 p-4 rounded-lg border border-yellow-200 dark:border-yellow-800 mb-4 flex items-start'>
                <span class='text-xl mr-3'>⚠️</span>
                <p
                  data-i18n='checkout.password_info'
                  class='text-sm text-yellow-800 dark:text-yellow-200 font-medium'>
                  {t('checkout.password_info')}
                </p>
              </div>
              <div class='grid grid-cols-1 md:grid-cols-2 gap-4'>
                <div>
                  <label
                    data-i18n='checkout.password'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.password')}</label
                  >
                  <div class='relative'>
                    <input
                      type='password'
                      id='password'
                      minlength='6'
                      class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                    />
                    <button
                      type='button'
                      class='absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 toggle-password'
                      data-target='password'>
                      <svg
                        class='h-5 w-5 text-gray-500'
                        fill='none'
                        stroke='currentColor'
                        viewBox='0 0 24 24'
                        ><path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'
                        ></path><path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'
                        ></path></svg
                      >
                    </button>
                  </div>
                  <p class='text-xs text-gray-500 dark:text-gray-400 mt-1'>
                    Minimal 6 karakter.
                  </p>
                  <p
                    id='password-error'
                    class='text-xs text-red-500 hidden mt-1'>
                    Password minimal 6 karakter.
                  </p>
                </div>
                <div>
                  <label
                    data-i18n='checkout.confirm_password'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.confirm_password')}</label
                  >
                  <div class='relative'>
                    <input
                      type='password'
                      id='confirm-password'
                      minlength='6'
                      class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                    />
                    <button
                      type='button'
                      class='absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 toggle-password'
                      data-target='confirm-password'>
                      <svg
                        class='h-5 w-5 text-gray-500'
                        fill='none'
                        stroke='currentColor'
                        viewBox='0 0 24 24'
                        ><path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'
                        ></path><path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'
                        ></path></svg
                      >
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Alamat Pengiriman -->
          <div
            class='bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800'>
            <h3
              data-i18n='checkout.shipping_address'
              class='text-xl font-bold mb-4 text-gray-900 dark:text-white'>
              {t('checkout.shipping_address')}
            </h3>
            <div class='space-y-4'>
              <div>
                <label
                  data-i18n='checkout.full_address'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  >{t('checkout.full_address')}</label
                >
                <textarea
                  id='address'
                  rows='3'
                  required
                  class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                ></textarea>
              </div>
              <div class='grid grid-cols-1 md:grid-cols-2 gap-4'>
                <div>
                  <label
                    data-i18n='checkout.province'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.province')}</label
                  >
                  <input
                    type='text'
                    id='province'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                </div>
                <div>
                  <label
                    data-i18n='checkout.city'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.city')}</label
                  >
                  <input
                    type='text'
                    id='city'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                </div>
                <div>
                  <label
                    data-i18n='checkout.district'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.district')}</label
                  >
                  <input
                    type='text'
                    id='district'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                </div>
                <div>
                  <label
                    data-i18n='checkout.zipcode'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.zipcode')}</label
                  >
                  <input
                    type='text'
                    id='zipcode'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                </div>
              </div>
            </div>
          </div>

          <!-- Pengiriman & Pembayaran -->
          <div
            class='bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800'>
            <h3
              data-i18n='checkout.shipping_payment'
              class='text-xl font-bold mb-4 text-gray-900 dark:text-white'>
              {t('checkout.shipping_payment')}
            </h3>
            <div class='space-y-6'>
              <!-- Shipping Cards -->
              <div>
                <label
                  data-i18n='checkout.choose_shipping'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3'
                  >{t('checkout.choose_shipping')}</label
                >
                <div
                  id='shipping-cards'
                  class='grid grid-cols-1 sm:grid-cols-2 gap-3'>
                  {
                    siteSettings.shippingMethods?.length > 0 ? (
                      siteSettings.shippingMethods.map((method: any) => (
                        <button
                          type='button'
                          class='shipping-card text-left p-4 rounded-xl border-2 border-gray-200 dark:border-gray-700 hover:border-primary transition-all duration-200'
                          data-name={method.name}
                          data-price={method.price}>
                          <div class='flex items-center justify-between'>
                            <div>
                              <p class='font-bold text-gray-900 dark:text-white text-sm'>
                                {method.name}
                              </p>
                              <p class='text-primary font-semibold text-sm mt-0.5'>
                                {formatCurrency(method.price)}
                              </p>
                            </div>
                            <div class='w-5 h-5 rounded-full border-2 border-gray-300 dark:border-gray-600 flex-shrink-0 shipping-radio' />
                          </div>
                        </button>
                      ))
                    ) : (
                      <p class='text-gray-500 text-sm col-span-2'>
                        Belum ada jasa pengiriman dikonfigurasi di CMS.
                      </p>
                    )
                  }
                </div>
                <input
                  type='hidden'
                  id='shipping-method'
                />
                <input
                  type='hidden'
                  id='shipping-price'
                  value='0'
                />
              </div>

              <!-- Payment Channel Cards -->
              <div>
                <label
                  data-i18n='checkout.choose_payment'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3'
                  >{t('checkout.choose_payment')}</label
                >
                <div
                  id='payment-cards'
                  class='grid grid-cols-1 sm:grid-cols-2 gap-3'>
                  {
                    siteSettings.paymentChannels?.length > 0 ? (
                      siteSettings.paymentChannels
                        .filter((channel: any) => !channel.displayLocation || channel.displayLocation === 'checkout' || channel.displayLocation === 'both')
                        .map((channel: any) => (
                          <button
                          type='button'
                          class='payment-card text-left p-4 rounded-xl border-2 border-gray-200 dark:border-gray-700 hover:border-primary transition-all duration-200'
                          data-bank={channel.bankName}
                          data-acc={channel.accountNumber || ''}
                          data-phone={channel.phoneNumber || ''}
                          data-accname={channel.accountName}
                          data-logo={getImageUrl(channel.logo, 'thumbnail')}
                          data-qr={
                            channel.qrCode ? getImageUrl(channel.qrCode) : ''
                          }>
                          <div class='flex items-center gap-3'>
                            {channel.logo ? (
                              <img
                                src={getImageUrl(channel.logo, 'thumbnail')}
                                alt={channel.bankName}
                                class='h-8 w-16 object-contain flex-shrink-0'
                              />
                            ) : (
                              <div class='h-8 w-16 bg-primary/10 rounded flex items-center justify-center flex-shrink-0'>
                                <span class='text-primary font-bold text-xs'>
                                  {channel.bankName.slice(0, 3)}
                                </span>
                              </div>
                            )}
                            <div class='flex-1 min-w-0'>
                              <p class='font-bold text-gray-900 dark:text-white text-sm truncate'>
                                {channel.bankName}
                              </p>
                              {channel.accountNumber && (
                                <p class='text-gray-500 text-[11px] leading-tight truncate'>
                                  Rek: {channel.accountNumber}
                                </p>
                              )}
                              {channel.phoneNumber && (
                                <p class='text-gray-500 text-[11px] leading-tight truncate'>
                                  HP: {channel.phoneNumber}
                                </p>
                              )}
                              <p class='text-gray-500 text-[11px] leading-tight truncate'>
                                {channel.accountName}
                              </p>
                            </div>
                            <div class='w-5 h-5 rounded-full border-2 border-gray-300 dark:border-gray-600 flex-shrink-0 payment-radio' />
                          </div>
                        </button>
                      ))
                    ) : (
                      <p class='text-gray-500 text-sm col-span-2'>
                        Belum ada channel pembayaran dikonfigurasi di CMS.
                      </p>
                    )
                  }
                </div>
                <input
                  type='hidden'
                  id='payment-method'
                />
                <input
                  type='hidden'
                  id='payment-acc'
                />
                <input
                  type='hidden'
                  id='payment-accname'
                />
                <input
                  type='hidden'
                  id='payment-logo'
                />
                <input
                  type='hidden'
                  id='payment-qr'
                />
                <input
                  type='hidden'
                  id='payment-phone'
                />
              </div>
            </div>
          </div>
        </form>
      </div>

      <!-- Ringkasan Kanan -->
      <div class='lg:col-span-5'>
        <div
          class='bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 sticky top-24'>
          <h3
            data-i18n='checkout.order_summary'
            class='text-xl font-bold mb-6 text-gray-900 dark:text-white'>
            {t('checkout.order_summary')}
          </h3>
          <div
            id='checkout-items'
            class='space-y-4 mb-6 max-h-60 overflow-y-auto pr-2'>
            <!-- Items inject via JS -->
          </div>

          <div
            class='border-t border-gray-200 dark:border-gray-700 pt-4 space-y-3 mb-6'>
            <div class='flex justify-between text-gray-600 dark:text-gray-400'>
              <span data-i18n='checkout.subtotal'>{t('checkout.subtotal')}</span
              >
              <span
                id='summary-subtotal'
                class='font-medium text-gray-900 dark:text-white'
                >{formatCurrency(0)}</span
              >
            </div>
            <div class='flex justify-between text-gray-600 dark:text-gray-400'>
              <span data-i18n='checkout.shipping_insurance'
                >{t('checkout.shipping_insurance')}</span
              >
              <span
                id='summary-shipping'
                class='font-medium text-gray-900 dark:text-white'
                >{formatCurrency(0)}</span
              >
            </div>
            <div
              class='border-t border-gray-200 dark:border-gray-700 pt-3 flex justify-between items-center'>
              <span
                data-i18n='checkout.total'
                class='text-lg font-bold text-gray-900 dark:text-white'
                >{t('checkout.total')}</span
              >
              <span
                id='summary-total'
                class='text-2xl font-extrabold text-primary'
                >{formatCurrency(0)}</span
              >
            </div>
          </div>

          <button
            id='btn-proceed'
            type='button'
            data-i18n='checkout.proceed_payment'
            class='w-full bg-cart-button hover:opacity-90 text-white font-bold py-3.5 px-4 rounded-xl transition-colors shadow-sm flex items-center justify-center'>
            {t('checkout.proceed_payment')}
            <svg
              class='w-5 h-5 ml-2'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
              ><path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M14 5l7 7m0 0l-7 7m7-7H3'
              ></path></svg
            >
          </button>
        </div>
      </div>
    </div>

    <!-- Empty State -->
    <div
      id='empty-state'
      class='text-center py-20 hidden'>
      <div
        class='w-24 h-24 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-6'>
        <svg
          class='w-10 h-10 text-gray-400'
          fill='none'
          stroke='currentColor'
          viewBox='0 0 24 24'
          ><path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z'
          ></path></svg
        >
      </div>
      <h3
        data-i18n='checkout.empty_cart'
        class='text-2xl font-bold text-gray-900 dark:text-white mb-2'>
        {t('checkout.empty_cart')}
      </h3>
      <p
        data-i18n='checkout.empty_cart_desc'
        class='text-gray-500 mb-8'>
        {t('checkout.empty_cart_desc')}
      </p>
      <a
        href='/'
        data-i18n='checkout.shop_now'
        class='inline-flex bg-cart-button hover:opacity-90 text-white font-bold py-3 px-8 rounded-lg transition-colors'
        >{t('checkout.shop_now')}</a
      >
    </div>

    <!-- Upload Proof Modal / Section -->
    <div
      id='upload-section'
      class='hidden max-w-2xl mx-auto bg-white dark:bg-surface-dark p-8 rounded-3xl shadow-xl border border-gray-100 dark:border-gray-800 mt-8'>
      <div class='text-center mb-8'>
        <h3
          data-i18n='checkout.payment_instructions'
          class='text-2xl font-bold text-gray-900 dark:text-white mb-2'>
          {t('checkout.payment_instructions')}
        </h3>
        <p class='text-gray-500'>
          <span data-i18n='checkout.transfer_instruction'
            >{t('checkout.transfer_instruction')}</span
          >
          <span
            id='upload-total'
            class='font-bold text-primary'
            >{formatCurrency(0)}</span
          >
        </p>
      </div>

      <div
        class='bg-gray-50 dark:bg-gray-900 p-6 rounded-2xl border border-gray-100 dark:border-gray-800 space-y-4 mb-8'>
        <!-- Header: Bank Info -->
        <div class='flex items-center gap-4'>
          <div
            class='w-16 h-16 bg-white rounded-xl p-2 flex items-center justify-center border border-gray-100 dark:border-gray-700 flex-shrink-0'>
            <img
              id='bank-logo'
              src=''
              alt='Bank Logo'
              class='w-full h-full object-contain hidden'
            />
          </div>
          <div>
            <p
              id='bank-name'
              class='text-lg font-bold text-gray-900 dark:text-white'>
              BCA
            </p>
            <span class='text-xs text-gray-500 uppercase tracking-wider'
              >Metode Pembayaran</span
            >
          </div>
        </div>

        <!-- Divider -->
        <div class='border-t border-gray-100 dark:border-gray-800 pt-4'>
          <!-- Account Number Section -->
          <div
            id='acc-container'
            class='hidden mb-4'>
            <p class='text-xs text-gray-500 mb-1'>Nomor Rekening</p>
            <div class='flex items-center justify-between gap-3'>
              <p
                id='bank-account'
                class='text-xl sm:text-2xl font-mono font-black text-primary tracking-wider'>
                1234567890
              </p>
              <button
                id='btn-copy'
                class='flex items-center gap-1 p-2 text-xs text-primary hover:text-primary-dark transition-colors flex-shrink-0'
                title='Salin Nomor Rekening'>
                <svg
                  class='w-4 h-4'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'>
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3'
                  ></path>
                </svg>
                <span>Salin</span>
              </button>
            </div>
          </div>

          <!-- Phone Number Section -->
          <div
            id='phone-container'
            class='hidden mb-4'>
            <p
              data-i18n='checkout.payment_phone'
              class='text-xs text-gray-500 mb-1'>
              {t('checkout.payment_phone')}
            </p>
            <div class='flex items-center justify-between gap-3'>
              <p
                id='bank-phone'
                class='text-xl sm:text-2xl font-mono font-black text-primary tracking-wider'>
                08123456789
              </p>
              <button
                id='btn-copy-phone'
                class='flex items-center gap-1 p-2 text-xs text-primary hover:text-primary-dark transition-colors flex-shrink-0'
                title='Salin Nomor HP'>
                <svg
                  class='w-4 h-4'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'>
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3'
                  ></path>
                </svg>
                <span>Salin</span>
              </button>
            </div>
          </div>

          <!-- Account Name Section -->
          <div id='acc-name-container'>
            <p class='text-xs text-gray-500 mb-1'>Atas Nama</p>
            <p
              id='bank-acc-name'
              class='text-base font-semibold text-gray-900 dark:text-white uppercase'>
              PT Logam Mulia
            </p>
          </div>
        </div>

        <!-- QR Code Section (Optional, only visible if QRIS image is available) -->
        <div
          id='qr-container'
          class='hidden border-t border-gray-100 dark:border-gray-800 pt-6 text-center'>
          <p
            data-i18n='checkout.scan_qr'
            class='text-xs text-gray-500 mb-2 font-medium'>
            {t('checkout.scan_qr')}
          </p>
          <div
            class='inline-block p-4 bg-white rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm'>
            <img
              id='qr-image'
              src=''
              alt='QRIS Code'
              class='max-w-[200px] h-auto mx-auto object-contain rounded-lg'
            />
          </div>
          <p
            data-i18n='checkout.save_qr_desc'
            class='text-[10px] text-gray-400 mt-2 italic'>
            {t('checkout.save_qr_desc')}
          </p>
        </div>
      </div>

      <div id="checkout-proof-container" class={`space-y-4 ${(siteSettings?.enableTopupProofUpload === 'checkout' || siteSettings?.enableTopupProofUpload === 'both' || siteSettings?.enableTopupProofUpload === undefined || siteSettings?.enableTopupProofUpload === true) ? '' : 'hidden'}`}>
        <label
          data-i18n='checkout.upload_proof'
          class='block text-sm font-medium text-gray-700 dark:text-gray-300'
          >{t('checkout.upload_proof')}</label
        >
        <input
          type='file'
          id='payment-proof'
          accept='image/*'
          class='block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 cursor-pointer'
        />
      </div>

      <button
        id='btn-confirm'
        data-brand={siteSettings.brandName}
        type='button'
        data-i18n='checkout.confirm_wa'
        data-wa={siteSettings.whatsappNumber}
        class='mt-8 w-full bg-[var(--color-success-btn)] hover:opacity-90 text-white font-bold py-3.5 px-4 rounded-xl transition-all shadow-sm flex items-center justify-center disabled:opacity-50 disabled:cursor-not-allowed'>
        {t('checkout.confirm_wa')}
        <svg
          class='w-5 h-5 ml-2'
          fill='currentColor'
          viewBox='0 0 24 24'
          ><path
            d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'
          ></path></svg
        >
      </button>
    </div>

    <!-- Success Modal -->
    <div
      id='success-modal'
      class='fixed inset-0 z-[100] flex items-center justify-center px-4 hidden'>
      <div class='absolute inset-0 bg-gray-900/60 backdrop-blur-sm'></div>
      <div
        class='bg-white dark:bg-surface-dark w-full max-w-md rounded-3xl shadow-2xl relative z-10 overflow-hidden transform transition-all scale-95 opacity-0 duration-300'
        id='success-modal-content'>
        <div class='p-8 text-center'>
          <div
            class='w-20 h-20 bg-[var(--color-success-btn)]/20 text-[var(--color-success-btn)] rounded-full flex items-center justify-center mx-auto mb-6 text-4xl'>
            ✅
          </div>
          <h3 class='text-2xl font-black text-gray-900 dark:text-white mb-2'>
            {isMY ? 'Pesanan Berjaya!' : 'Pesanan Berhasil!'}
          </h3>
          <p class='text-gray-500 dark:text-gray-400 mb-8'>
            {
              isMY
                ? 'Data pesanan anda telah kami terima. Sila klik butang di bawah untuk pengesahan melalui Admin dan menjejak pesanan anda.'
                : 'Data pesanan Anda telah kami terima. Silakan klik tombol di bawah untuk konfirmasi ke Admin dan melacak pesanan Anda.'
            }
          </p>

          <div class='space-y-3'>
            <button
              id='btn-success-wa'
              class='w-full bg-[var(--color-success-btn)] hover:opacity-90 text-white font-bold py-4 px-6 rounded-2xl transition-all shadow-lg flex items-center justify-center gap-3'>
              {isMY ? 'Pengesahan WhatsApp' : 'Konfirmasi ke Admin'}
            </button>
            <p
              class='text-[10px] text-gray-400 uppercase font-black tracking-widest mt-4 italic'>
              {
                isMY
                  ? 'AKAN DIARAHKAN SECARA AUTOMATIK KE HALAMAN JEJAK PESANAN'
                  : 'OTOMATIS DIARAHKAN KE HALAMAN LACAK PESANAN'
              }
            </p>
          </div>
        </div>
      </div>

      <!-- Login Modal -->
      <div
        id='login-modal'
        class='fixed inset-0 z-[100] flex items-center justify-center px-4 hidden'>
        <div class='absolute inset-0 bg-gray-900/60 backdrop-blur-sm'></div>
        <div
          class='bg-white dark:bg-surface-dark w-full max-w-md rounded-3xl shadow-2xl relative z-10 overflow-hidden transform transition-all'
          id='login-modal-content'>
          <div class='p-8'>
            <div class='text-center mb-6'>
              <div
                class='w-16 h-16 bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl'>
                ⚠️
              </div>
              <h3
                class='text-xl font-bold text-gray-900 dark:text-white mb-2'
                data-i18n='checkout.email_registered_title'>
                {
                  t('checkout.email_registered_title') ||
                    'Email Sudah Terdaftar'
                }
              </h3>
              <p
                class='text-sm text-gray-500 dark:text-gray-400'
                data-i18n='checkout.email_registered_desc'>
                {
                  t('checkout.email_registered_desc') ||
                    'Email ini sudah memiliki akun. Silakan masuk untuk melanjutkan pesanan.'
                }
              </p>
            </div>

            <form
              id='modal-login-form'
              class='space-y-4'>
              <!-- Error Container -->
              <div
                id='modal-login-error'
                class='hidden rounded-lg p-3 text-sm font-medium bg-red-50 text-red-800 border border-red-200 dark:bg-red-900/30 dark:text-red-200 dark:border-red-800'>
              </div>

              <div>
                <label
                  for='modal-email'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  data-i18n='checkout.email'
                  >{t('checkout.email')}</label
                >
                <input
                  type='email'
                  id='modal-email'
                  readonly
                  class='w-full px-4 py-2 bg-gray-100 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                />
              </div>
              <div>
                <label
                  for='modal-password'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  data-i18n='checkout.password'
                  >{t('checkout.password')}</label
                >
                <div class='relative'>
                  <input
                    type='password'
                    id='modal-password'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                  <button
                    type='button'
                    class='absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 toggle-password'
                    data-target='modal-password'>
                    <!-- Eye Icon -->
                    <svg
                      class='h-5 w-5 text-gray-500'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
                      ><path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'
                      ></path><path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'
                      ></path></svg
                    >
                  </button>
                </div>
              </div>

              <div class='flex items-center justify-between'>
                <a
                  href='/forgot-password'
                  class='text-sm text-primary hover:text-primary-dark'
                  data-i18n='login.forgot_password'
                  >{t('login.forgot_password') || 'Lupa Password?'}</a
                >
              </div>

              <button
                type='submit'
                class='w-full bg-primary hover:bg-primary-dark text-white font-bold py-3 px-4 rounded-xl transition-colors'
                data-i18n='nav.login'>
                {t('nav.login')}
              </button>
              <button
                type='button'
                id='btn-close-login-modal'
                class='w-full bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold py-3 px-4 rounded-xl transition-colors mt-2'
                data-i18n='checkout.cancel'>
                {t('checkout.cancel') || 'Batal'}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ tenantId, regionCode, checkoutStrings, lang, enableTopupProofUpload: siteSettings?.enableTopupProofUpload === 'checkout' || siteSettings?.enableTopupProofUpload === 'both' || siteSettings?.enableTopupProofUpload === undefined || siteSettings?.enableTopupProofUpload === true }}>
    window.__tenantId = tenantId;
    window.__regionCode = regionCode;
    window.__CHECKOUT_STRINGS = checkoutStrings;
    window.__enableProofUpload = enableTopupProofUpload;
    window.__currentLang = lang;
  </script>

  <script>
    import { cartStore } from '../../lib/cart';
    import { supabase } from '../../lib/supabase';
    import { CMS_URL, getImageUrl } from '../../lib/cms';

    // tenantId passed from server via window.__tenantId
    const tenantIdVar = (window as any).__tenantId;
    const checkoutStrings = (window as any).__CHECKOUT_STRINGS;

    console.log('[Checkout] Initializing with CMS_URL:', CMS_URL);

    // ── Toast helper (Delegated to Global Toast.astro) ─────────────
    const showToast = (
      message: string,
      type: 'error' | 'success' | 'warning',
      _ignoredContainerId = '',
    ) => {
      window.dispatchEvent(
        new CustomEvent('cart-toast', {
          detail: { message, type },
        }),
      );
    };

    // ── Terminal Logger helper ────────────────────────────────────
    const logToTerminal = async (message: string, details: any = null) => {
      console.log(`[Terminal Log] ${message}`, details);
      try {
        await fetch(`${CMS_URL}/api/client-log`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ level: 'error', message, details }),
        });
      } catch (e) {
        console.error('Failed to send log to terminal:', e);
      }
    };

    import { formatCurrency } from '../../utils/currency';

    // Render Cart Items
    const renderCheckoutItems = () => {
      const cart = cartStore.get();
      const itemsContainer = document.getElementById('checkout-items');
      const items = Object.values(cart);

      if (items.length === 0) {
        document.getElementById('checkout-container')?.classList.add('hidden');
        document.getElementById('empty-state')?.classList.remove('hidden');
        return;
      }

      document.getElementById('checkout-container')?.classList.remove('hidden');
      document.getElementById('empty-state')?.classList.add('hidden');

      let subtotal = 0;
      if (itemsContainer) {
        itemsContainer.innerHTML = items
          .map((item) => {
            const safePrice = Number(item.price) || 0;
            const safeQty = Number(item.quantity) || 0;
            subtotal += safePrice * safeQty;
            return `
          <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-800 last:border-0">
            <div class="flex items-center">
              <img src="${item.image}" alt="${item.name}" class="w-12 h-12 object-cover rounded bg-gray-100 mr-3" />
              <div>
                <p class="text-sm font-semibold text-gray-900 dark:text-white line-clamp-1">${item.name}</p>
                <p class="text-xs text-gray-500">${item.quantity} x ${formatCurrency(item.price)}</p>
              </div>
            </div>
            <p class="text-sm font-bold text-gray-900 dark:text-white">${formatCurrency(item.price * item.quantity)}</p>
          </div>
        `;
          })
          .join('');
      }

      const shippingPriceInput = document.getElementById(
        'shipping-price',
      ) as HTMLInputElement;
      const shippingPrice = parseInt(shippingPriceInput?.value || '0', 10);

      const total = subtotal + shippingPrice;

      const subEl = document.getElementById('summary-subtotal');
      if (subEl) subEl.innerText = formatCurrency(subtotal);

      const shippingEl = document.getElementById('summary-shipping');
      if (shippingEl) shippingEl.innerText = formatCurrency(shippingPrice);

      const totEl = document.getElementById('summary-total');
      if (totEl) totEl.innerText = formatCurrency(total);

      const upTotEl = document.getElementById('upload-total');
      if (upTotEl) upTotEl.innerText = formatCurrency(total);
    };

    // Initialize
    renderCheckoutItems();

    // Shipping Card Selection
    document.querySelectorAll('.shipping-card').forEach((card) => {
      card.addEventListener('click', () => {
        const name = (card as HTMLElement).dataset.name || '';
        const price = (card as HTMLElement).dataset.price || '0';

        // Update hidden inputs
        (document.getElementById('shipping-method') as HTMLInputElement).value =
          name;
        (document.getElementById('shipping-price') as HTMLInputElement).value =
          price;

        // Update UI active state
        document.querySelectorAll('.shipping-card').forEach((c) => {
          c.classList.remove('border-primary', 'bg-primary/5');
          c.querySelector('.shipping-radio')?.classList.remove(
            'bg-primary',
            'border-primary',
          );
        });
        card.classList.add('border-primary', 'bg-primary/5');
        card
          .querySelector('.shipping-radio')
          ?.classList.add('bg-primary', 'border-primary');

        renderCheckoutItems();
      });
    });

    // Payment Card Selection function definition
    const setupPaymentCardListeners = () => {
      document.querySelectorAll('.payment-card').forEach((card) => {
        // Clone card element to remove any previous listeners
        const newCard = card.cloneNode(true) as HTMLElement;
        card.parentNode?.replaceChild(newCard, card);

        newCard.addEventListener('click', () => {
          const bank = newCard.dataset.bank || '';
          const acc = newCard.dataset.acc || '';
          const phone = newCard.dataset.phone || '';
          const name = newCard.dataset.accname || '';
          const logo = newCard.dataset.logo || '';
          const qr = newCard.dataset.qr || '';

          // Update hidden inputs
          (document.getElementById('payment-method') as HTMLInputElement).value = bank;
          (document.getElementById('payment-acc') as HTMLInputElement).value = acc;
          (document.getElementById('payment-phone') as HTMLInputElement).value = phone;
          (document.getElementById('payment-accname') as HTMLInputElement).value = name;
          (document.getElementById('payment-logo') as HTMLInputElement).value = logo;
          (document.getElementById('payment-qr') as HTMLInputElement).value = qr;

          // Update UI active state
          document.querySelectorAll('.payment-card').forEach((c) => {
            c.classList.remove('border-primary', 'bg-primary/5');
            c.querySelector('.payment-radio')?.classList.remove(
              'bg-primary',
              'border-primary',
            );
          });
          newCard.classList.add('border-primary', 'bg-primary/5');
          newCard
            .querySelector('.payment-radio')
            ?.classList.add('bg-primary', 'border-primary');
        });
      });
    };

    // Initialize listeners initially
    setupPaymentCardListeners();

    // Fetch site settings dynamically on the client side to bypass static build issues
    const loadDynamicSettings = async () => {
      try {
        const pathParts = window.location.pathname.split('/');
        const defaultLocale = (window as any).__currentLang || 'id';
        const currentLang = hasLangPrefix ? pathParts[1] : defaultLocale;
        
        let res = await fetch(`${CMS_URL}/api/site-settings?where[tenant][equals]=${tenantIdVar}&locale=${currentLang}&depth=1`);
        let settingsData = await res.json();
        let settings = settingsData.docs && settingsData.docs.length > 0 ? settingsData.docs[0] : null;

        // Fallback to default lang if currentLang settings are empty/not configured
        if ((!settings || !settings.paymentChannels || settings.paymentChannels.length === 0) && currentLang !== defaultLocale) {
           const fallbackRes = await fetch(`${CMS_URL}/api/site-settings?where[tenant][equals]=${tenantIdVar}&locale=${defaultLocale}&depth=1`);
           const fallbackData = await fallbackRes.json();
           if (fallbackData.docs && fallbackData.docs.length > 0) {
              const fallbackSettings = fallbackData.docs[0];
              if (!settings) {
                 settings = fallbackSettings;
              } else {
                 settings.paymentChannels = fallbackSettings.paymentChannels;
              }
           }
        }

        if (settings) {
            const enableProofUpload = settings.enableTopupProofUpload === 'checkout' || settings.enableTopupProofUpload === 'both' || settings.enableTopupProofUpload === undefined || settings.enableTopupProofUpload === true;
           (window as any).__enableProofUpload = enableProofUpload;
           
           const checkoutProofContainer = document.getElementById('checkout-proof-container');
           if (checkoutProofContainer) {
              if (enableProofUpload) {
                 checkoutProofContainer.classList.remove('hidden');
              } else {
                 checkoutProofContainer.classList.add('hidden');
              }
           }

           const channels = (settings.paymentChannels || []).filter((channel: any) => !channel.displayLocation || channel.displayLocation === 'checkout' || channel.displayLocation === 'both');
           const paymentCardsContainer = document.getElementById('payment-cards');
           if (paymentCardsContainer && channels.length > 0) {
              paymentCardsContainer.innerHTML = channels.map((channel: any) => {
                 const logoUrl = channel.logo ? (typeof channel.logo === 'object' && channel.logo.url ? channel.logo.url : `${CMS_URL}${channel.logo.url || channel.logo}`) : '';
                 const qrUrl = channel.qrCode ? (typeof channel.qrCode === 'object' && channel.qrCode.url ? channel.qrCode.url : `${CMS_URL}${channel.qrCode.url || channel.qrCode}`) : '';
                 
                 return `
                    <button
                      type="button"
                      class="payment-card text-left p-4 rounded-xl border-2 border-gray-200 dark:border-gray-700 hover:border-primary transition-all duration-200"
                      data-bank="${channel.bankName}"
                      data-acc="${channel.accountNumber || ''}"
                      data-phone="${channel.phoneNumber || ''}"
                      data-accname="${channel.accountName}"
                      data-logo="${logoUrl}"
                      data-qr="${qrUrl}"
                    >
                      <div class="flex items-center gap-3">
                        ${logoUrl ? `
                          <img
                            src="${logoUrl}"
                            alt="${channel.bankName}"
                            class="h-8 w-16 object-contain flex-shrink-0"
                          />
                        ` : `
                          <div class="h-8 w-16 bg-primary/10 rounded flex items-center justify-center flex-shrink-0">
                            <span class="text-primary font-bold text-xs">
                              ${channel.bankName.slice(0, 3)}
                            </span>
                          </div>
                        `}
                        <div class="flex-1 min-w-0">
                          <p class="font-bold text-gray-900 dark:text-white text-sm truncate">
                            ${channel.bankName}
                          </p>
                          ${channel.accountNumber ? `
                            <p class="text-gray-500 text-[11px] leading-tight truncate">
                              Rek: ${channel.accountNumber}
                            </p>
                          ` : ''}
                          ${channel.phoneNumber ? `
                            <p class="text-gray-500 text-[11px] leading-tight truncate">
                              HP: ${channel.phoneNumber}
                            </p>
                          ` : ''}
                          <p class="text-gray-500 text-[11px] leading-tight truncate">
                            ${channel.accountName}
                          </p>
                        </div>
                        <div class="w-5 h-5 rounded-full border-2 border-gray-300 dark:border-gray-600 flex-shrink-0 payment-radio" />
                      </div>
                    </button>
                 `;
              }).join('');
              
              setupPaymentCardListeners();
           }
        }
      } catch (err) {
         console.error('[Checkout] Failed to fetch settings dynamically:', err);
      }
    };

    loadDynamicSettings();

    // ── Region config bridged from server ─────────────────────────
    const regionCode = (window as any).__regionCode || 'ID';
    const isMY = regionCode === 'MY';

    // MY: 01XXXXXXXXX (10-11 digits) or 601XXXXXXXXX (11-12 digits)
    // ID: 08XXXXXXXXXX (10-13 digits) or 628XXXXXXXXX (11-15 digits)
    const phoneRegex = isMY
      ? /^(60[1-9][0-9]{7,10}|0[1-9][0-9]{7,10})$/
      : /^(08|628)[0-9]{8,13}$/;

    // Supabase Auth logic
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session?.user) {
        // Auto-fill and hide password fields if logged in
        const pwSection = document.getElementById('password-section');
        if (pwSection) pwSection.style.display = 'none';
        const emailEl = document.getElementById('email') as HTMLInputElement;
        if (emailEl && session.user.email) {
          emailEl.value = session.user.email;
          emailEl.readOnly = true;
        }
      }
    });

    // Proceed button logic
    const btnProceed = document.getElementById('btn-proceed');
    btnProceed?.addEventListener('click', async () => {
      const form = document.getElementById('checkout-form') as HTMLFormElement;
      if (!form.checkValidity()) {
        showToast(checkoutStrings.errCompleteForm, 'warning');
        form.reportValidity();
        return;
      }

      const shippingMethodVal = (
        document.getElementById('shipping-method') as HTMLInputElement
      )?.value;
      if (!shippingMethodVal) {
        showToast(checkoutStrings.errShipping, 'warning');
        document
          .getElementById('shipping-cards')
          ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      const paymentMethodVal = (
        document.getElementById('payment-method') as HTMLInputElement
      )?.value;
      if (!paymentMethodVal) {
        showToast(checkoutStrings.errPayment, 'warning');
        document
          .getElementById('payment-cards')
          ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      const phoneInput = document.getElementById('phone') as HTMLInputElement;
      const phoneVal = phoneInput.value;

      if (!phoneRegex.test(phoneVal)) {
        showToast(
          isMY ? checkoutStrings.errPhoneMy : checkoutStrings.errPhoneId,
          'warning',
        );
        phoneInput.focus();
        const phoneError = document.getElementById('phone-error');
        phoneError?.classList.remove('hidden');
        return;
      }

      const email = (document.getElementById('email') as HTMLInputElement)
        .value;
      const password = (document.getElementById('password') as HTMLInputElement)
        ?.value;
      const confirmPassword = (
        document.getElementById('confirm-password') as HTMLInputElement
      )?.value;

      const {
        data: { session },
      } = await supabase.auth.getSession();

      if (!session && password) {
        if (password !== confirmPassword) {
          showToast(
            checkoutStrings.errPasswordMismatch,
            'warning',
            'upload-toast',
          );
          console.warn('[Checkout] Password mismatch for email:', email);
          return;
        }

        const fullName = (document.getElementById('name') as HTMLInputElement)?.value || '';
        try {
          const res = await fetch(`${CMS_URL}/api/register-customer`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password, tenantId: tenantIdVar, fullName }),
          });

          const resData = await res.json();
          if (!res.ok || !resData.success) {
            throw new Error(resData.error || checkoutStrings.errSignupFailed);
          }

          // Auto-login
          const { error: signInError } = await supabase.auth.signInWithPassword({ email, password });
          if (signInError) throw signInError;
        } catch (err: any) {
          console.error('[Checkout] signup error:', err);
          showToast(
            checkoutStrings.errSignupFailed + (err.message || ''),
            'error',
            'upload-toast',
          );
          return;
        }
      }

      // Update UI for Payment Method selection (Instructions)
      const bankName = (
        document.getElementById('payment-method') as HTMLInputElement
      ).value;
      const bankAcc = (
        document.getElementById('payment-acc') as HTMLInputElement
      ).value;
      const bankPhone = (
        document.getElementById('payment-phone') as HTMLInputElement
      ).value;
      const bankAccName = (
        document.getElementById('payment-accname') as HTMLInputElement
      ).value;
      const bankLogo = (
        document.getElementById('payment-logo') as HTMLInputElement
      ).value;
      const bankQr = (document.getElementById('payment-qr') as HTMLInputElement)
        .value;

      if (!bankName) {
        showToast(checkoutStrings.errPayment, 'warning', 'upload-toast');
        return;
      }

      const bNameEl = document.getElementById('bank-name');
      if (bNameEl) bNameEl.innerText = bankName;

      // Toggle Account Number container
      const accContainer = document.getElementById('acc-container');
      const bAccEl = document.getElementById('bank-account');
      if (accContainer && bAccEl) {
        if (bankAcc) {
          bAccEl.innerText = bankAcc;
          accContainer.classList.remove('hidden');
        } else {
          accContainer.classList.add('hidden');
        }
      }

      // Toggle Phone Number container
      const phoneContainer = document.getElementById('phone-container');
      const bPhoneEl = document.getElementById('bank-phone');
      if (phoneContainer && bPhoneEl) {
        if (bankPhone) {
          bPhoneEl.innerText = bankPhone;
          phoneContainer.classList.remove('hidden');
        } else {
          phoneContainer.classList.add('hidden');
        }
      }

      const bAccNameEl = document.getElementById('bank-acc-name');
      const accNameContainer = document.getElementById('acc-name-container');
      if (bAccNameEl && accNameContainer) {
        if (bankAccName && bankAccName.trim() !== '') {
          bAccNameEl.innerText = bankAccName;
          accNameContainer.classList.remove('hidden');
        } else {
          accNameContainer.classList.add('hidden');
        }
      }

      const bLogoEl = document.getElementById('bank-logo') as HTMLImageElement;
      if (bLogoEl) {
        if (bankLogo) {
          bLogoEl.src = bankLogo;
          bLogoEl.classList.remove('hidden');
        } else {
          bLogoEl.classList.add('hidden');
        }
      }

      // Optional QR Code display
      const qrContainerEl = document.getElementById('qr-container');
      const qrImageEl = document.getElementById('qr-image') as HTMLImageElement;
      if (qrContainerEl && qrImageEl) {
        if (bankQr) {
          qrImageEl.src = bankQr;
          qrContainerEl.classList.remove('hidden');
        } else {
          qrContainerEl.classList.add('hidden');
        }
      }

      document.getElementById('checkout-container')?.classList.add('hidden');
      document.getElementById('upload-section')?.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });

      // Copy Account Button logic
      const btnCopy = document.getElementById('btn-copy');
      btnCopy?.addEventListener('click', () => {
        navigator.clipboard.writeText(bankAcc).then(() => {
          const originalIcon = btnCopy.innerHTML;
          btnCopy.innerHTML =
            '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
          setTimeout(() => {
            btnCopy.innerHTML = originalIcon;
          }, 2000);
        });
      });

      // Copy Phone Button logic
      const btnCopyPhone = document.getElementById('btn-copy-phone');
      btnCopyPhone?.addEventListener('click', () => {
        navigator.clipboard.writeText(bankPhone).then(() => {
          const originalIcon = btnCopyPhone.innerHTML;
          btnCopyPhone.innerHTML =
            '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
          setTimeout(() => {
            btnCopyPhone.innerHTML = originalIcon;
          }, 2000);
        });
      });
    });

    // Confirm button logic
    const btnConfirm = document.getElementById(
      'btn-confirm',
    ) as HTMLButtonElement | null;
    btnConfirm?.addEventListener('click', async () => {
      // Validations
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const phoneInput = document.getElementById('phone') as HTMLInputElement;
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(emailInput.value)) {
        showToast(checkoutStrings.errEmailInvalid, 'warning');
        return;
      }

      const enableProofUpload = (window as any).__enableProofUpload !== false;
      const fileInput = document.getElementById(
        'payment-proof',
      ) as HTMLInputElement;

      let file: File | null = null;
      if (enableProofUpload) {
        if (!fileInput.files || fileInput.files.length === 0) {
          showToast(checkoutStrings.errNoProof, 'warning');
          console.warn(
            '[Checkout] User tried to confirm without uploading proof.',
          );
          return;
        }

        file = fileInput.files[0];
        if (file.size > 4 * 1024 * 1024) {
          // 4MB
          showToast(checkoutStrings.errFileSize, 'warning');
          return;
        }
      }

      const orderId = 'ORD-' + Date.now();
      if (btnConfirm) {
        btnConfirm.innerText = enableProofUpload ? checkoutStrings.statusUploading : 'Memproses...';
        btnConfirm.setAttribute('disabled', 'true');
      }

      // Build order details first (needed for both upload-success and fallback paths)
      const cart = cartStore.get();
      let orderList = '';
      Object.values(cart).forEach((item) => {
        orderList += `- ${item.name} (${item.quantity}x)\n`;
      });
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const total = document.getElementById('summary-total')?.innerText || '0';

      // 1. Upload to Supabase Storage (bucket: payment-proofs, must be public)
      let publicUrl = '(tidak tersedia)';
      let uploadError = null;

      if (enableProofUpload && file) {
        const { data: uploadData, error: uErr } = await supabase.storage
          .from('payment-proofs')
          .upload(`proofs/${orderId}-${file.name}`, file);

        if (uErr) {
          uploadError = uErr;
          // 1. Log to browser console
          console.error('[Checkout] Supabase Storage upload error:', uErr);

          // 2. Log to CMS Terminal (as requested)
          await logToTerminal(`Upload gagal untuk Order ID: ${orderId}`, {
            error: uErr.message,
            hint: 'Pastikan SQL Policy sudah dijalankan di Dashboard Supabase!',
            bucket: 'payment-proofs',
            fileName: file.name,
          });

          // Show friendly non-blocking warning — order still proceeds
          showToast(checkoutStrings.errUploadFailed, 'warning');

          // Give user 2s to read the warning before proceeding
          await new Promise((r) => setTimeout(r, 2000));
        } else {
          const { data: urlData } = supabase.storage
            .from('payment-proofs')
            .getPublicUrl(`proofs/${orderId}-${file.name}`);
          publicUrl = urlData?.publicUrl || publicUrl;
          console.log('[Checkout] Upload success. Public URL:', publicUrl);
        }
      }

      // 2. Save to Payload CMS API
      try {
        const {
          data: { session },
        } = await supabase.auth.getSession();
        const payloadTransaction = {
          tenant: tenantIdVar || undefined,
          orderId,
          status: uploadError ? 'Pending' : 'Paid',
          customerDetails: {
            name: (document.getElementById('name') as HTMLInputElement).value,
            email: emailInput.value,
            phone: phoneInput.value,
            address: (document.getElementById('address') as HTMLTextAreaElement)
              .value,
          },
          items: Object.values(cart).map((item) => ({
            productId: item.id,
            productName: item.name,
            quantity: Number(item.quantity),
            priceAtPurchase: Number(item.price),
          })),
          shippingMethod: (
            document.getElementById('shipping-method') as HTMLInputElement
          ).value,
          shippingCost: Number(
            (document.getElementById('shipping-price') as HTMLInputElement)
              .value,
          ),
          paymentChannel: (
            document.getElementById('payment-method') as HTMLInputElement
          ).value,
          subtotal: Object.values(cart).reduce(
            (acc, item) => acc + Number(item.price) * Number(item.quantity),
            0,
          ),
          total: Number(total.replace(/[^0-9]/g, '')),
          paymentProofUrl: publicUrl,
          supabaseUserId: session?.user?.id || 'guest',
        };

        console.log(
          '[Checkout] Sending transaction to Payload CMS...',
          payloadTransaction,
        );

        const response = await fetch(`${CMS_URL}/api/transactions`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payloadTransaction),
        });

        console.log('[Checkout] Payload response status:', response.status);

        if (!response.ok) {
          const errData = await response.json();
          console.error('[Checkout] Payload API error:', errData);
          showToast(checkoutStrings.errServer, 'error');
          if (btnConfirm) {
            btnConfirm.innerText = checkoutStrings.statusConfirmWa;
            btnConfirm.removeAttribute('disabled');
          }
          return; // Hentikan proses, jangan reset cart
        } else {
          console.log('[Checkout] Transaction saved to Payload CMS.');
        }
      } catch (e) {
        console.error('[Checkout] Failed to save transaction to Payload:', e);
        showToast(checkoutStrings.errNetwork, 'error');
        if (btnConfirm) {
          btnConfirm.innerText = checkoutStrings.statusConfirmWa;
          btnConfirm.removeAttribute('disabled');
        }
        return; // Hentikan proses, jangan reset cart
      }

      // 3. Clear cart (hanya jika sukses masuk database)
      cartStore.set({});

      // 4. Redirect to WhatsApp
      const email = emailInput.value;
      const phone = phoneInput.value;
      const address = (
        document.getElementById('address') as HTMLTextAreaElement
      ).value;
      const province = (document.getElementById('province') as HTMLInputElement)
        .value;
      const city = (document.getElementById('city') as HTMLInputElement).value;
      const shippingMethod = (
        document.getElementById('shipping-method') as HTMLInputElement
      ).value;

      const brandName = btnConfirm?.dataset.brand || 'Mulia Gold';

      // WhatsApp confirmation message — localized per region
      let waText = isMY
        ? `${checkoutStrings.waGreetingMy}
 
 *ID Pesanan:* ${orderId}
 *Nama Penuh:* ${name}
 *E-mel:* ${email}
 *No. Telefon:* ${phone}
 *Alamat Penghantaran:* ${address}, ${city}, ${province}
 *Kaedah Penghantaran:* ${shippingMethod}
 
 *Senarai Pesanan:*
 ${orderList}
 *Jumlah Pembayaran:* ${total}`
        : `${checkoutStrings.waGreetingId}
 
 *Order ID:* ${orderId}
 *Nama Lengkap:* ${name}
 *Email:* ${email}
 *No Telephone:* ${phone}
 *Alamat Pengiriman:* ${address}, ${city}, ${province}
 *Jasa Pengiriman:* ${shippingMethod}
 
 *Daftar Pesanan:*
 ${orderList}
 *Total Pembayaran:* ${total}`;

      if (enableProofUpload) {
        waText += `\n\n*Bukti Pembayaran:* ${publicUrl}`;
      }

      // 4. Show Success Modal instead of direct redirect (to avoid popup blocker)
      const adminWA = btnConfirm?.dataset.wa || '6281234567890';
      const waUrl = `https://wa.me/${adminWA}?text=${encodeURIComponent(waText)}`;

      const modal = document.getElementById('success-modal');
      const modalContent = document.getElementById('success-modal-content');
      const btnSuccessWa = document.getElementById('btn-success-wa');

      if (modal && modalContent && btnSuccessWa) {
        modal.classList.remove('hidden');
        setTimeout(() => {
          modalContent.classList.remove('scale-95', 'opacity-0');
          modalContent.classList.add('scale-100', 'opacity-100');
        }, 50);

        btnSuccessWa.addEventListener('click', () => {
          // Open WA in new tab (This is now a direct user action, so it won't be blocked)
          window.open(waUrl, '_blank');
          // Redirect current tab to Track Order
          window.location.href = `/track-order?id=${orderId}`;
        });
      }
    });
    // Real-time Phone Validation (region-aware)
    const phoneInputEl = document.getElementById('phone') as HTMLInputElement;
    const phoneErrorEl = document.getElementById('phone-error');

    phoneInputEl?.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      // Strip non-digit characters
      const originalValue = target.value;
      const cleanedValue = originalValue.replace(/\D/g, '');
      if (originalValue !== cleanedValue) target.value = cleanedValue;

      const val = target.value;

      if (isMY) {
        // MY: must start with 0 (local) or 6 (international)
        if (val.length >= 2) {
          const valid = val.startsWith('01') || val.startsWith('60');
          phoneErrorEl?.classList.toggle('hidden', valid);
          target.classList.toggle('border-red-500', !valid);
          target.classList.toggle('ring-red-500', !valid);
        } else if (val.length === 1) {
          const validStart = val === '0' || val === '6';
          phoneErrorEl?.classList.toggle('hidden', validStart);
        } else {
          phoneErrorEl?.classList.add('hidden');
          target.classList.remove('border-red-500', 'ring-red-500');
        }
      } else {
        // ID: must start with 08 or 62
        if (val.length >= 2) {
          const valid = val.startsWith('08') || val.startsWith('62');
          phoneErrorEl?.classList.toggle('hidden', valid);
          target.classList.toggle('border-red-500', !valid);
          target.classList.toggle('ring-red-500', !valid);
        } else if (val.length === 1) {
          const validStart = val === '0' || val === '6';
          phoneErrorEl?.classList.toggle('hidden', validStart);
        } else {
          phoneErrorEl?.classList.add('hidden');
          target.classList.remove('border-red-500', 'ring-red-500');
        }
      }
    });

    // Phone Validation on Blur
    phoneInputEl?.addEventListener('blur', () => {
      const val = phoneInputEl.value;
      if (val.length === 0) return;
      if (!phoneRegex.test(val)) {
        phoneErrorEl?.classList.remove('hidden');
        phoneInputEl.classList.add('border-red-500', 'ring-red-500');
      }
    });

    // Password Validation on Blur
    const passwordInputEl = document.getElementById(
      'password',
    ) as HTMLInputElement;
    const passwordErrorEl = document.getElementById('password-error');
    passwordInputEl?.addEventListener('blur', () => {
      const val = passwordInputEl.value;
      if (val.length < 6) {
        passwordErrorEl?.classList.remove('hidden');
        passwordInputEl.classList.add('border-red-500', 'ring-red-500');
      } else {
        passwordErrorEl?.classList.add('hidden');
        passwordInputEl.classList.remove('border-red-500', 'ring-red-500');
      }
    });

    passwordInputEl?.addEventListener('input', () => {
      const val = passwordInputEl.value;
      if (val.length >= 6) {
        passwordErrorEl?.classList.add('hidden');
        passwordInputEl.classList.remove('border-red-500', 'ring-red-500');
      }
    });

    // Real-time Email Check on Blur (RPC)
    const emailInputEl = document.getElementById('email') as HTMLInputElement;
    emailInputEl?.addEventListener('blur', async () => {
      if (emailInputEl.readOnly) return; // Skip if already logged in
      const email = emailInputEl.value;
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) return;

      console.log('[Checkout] Checking email existence via RPC:', email);
      const { data: exists, error } = await supabase.rpc('check_email_exists', {
        email_to_check: email,
      });

      if (error) {
        console.error('[Checkout] RPC error checking email:', error);
        return;
      }

      if (exists) {
        console.log('[Checkout] Email already exists, showing login modal');
        const loginModal = document.getElementById('login-modal');
        const modalContent = document.getElementById('login-modal-content');
        if (loginModal && modalContent) {
          loginModal.classList.remove('hidden');
          setTimeout(() => {
            modalContent.classList.remove('scale-95', 'opacity-0');
            modalContent.classList.add('scale-100', 'opacity-100');
          }, 50);

          const modalEmailInput = document.getElementById(
            'modal-email',
          ) as HTMLInputElement;
          if (modalEmailInput) modalEmailInput.value = email;
        }
      }
    });

    // Modal Login Form Submission
    const modalLoginForm = document.getElementById(
      'modal-login-form',
    ) as HTMLFormElement;
    modalLoginForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('modal-email') as HTMLInputElement)
        .value;
      const password = (
        document.getElementById('modal-password') as HTMLInputElement
      ).value;
      const modalLoginErrorEl = document.getElementById('modal-login-error');

      modalLoginErrorEl?.classList.add('hidden');

      console.log('[Checkout Modal] Attempting login for:', email);

      if (tenantIdVar) {
        try {
          const checkRes = await fetch(`${CMS_URL}/api/check-customer?email=${encodeURIComponent(email)}&tenantId=${tenantIdVar}`);
          const checkData = await checkRes.json();

          if (checkData.blocked) {
            if (modalLoginErrorEl) {
              modalLoginErrorEl.innerText = 'Akun dengan email ini telah diblokir. Sila hubungi admin.';
              modalLoginErrorEl.classList.remove('hidden');
            }
            return;
          }

          if (checkData.wrongTenant) {
            if (modalLoginErrorEl) {
              modalLoginErrorEl.innerText = 'Akun tidak terdaftar di website ini.';
              modalLoginErrorEl.classList.remove('hidden');
            }
            return;
          }
        } catch (checkErr) {
          console.warn('[Checkout Login] Customer check failed, proceeding:', checkErr);
        }
      }

      const { data, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        console.error('[Checkout Modal] Login error:', error);
        if (modalLoginErrorEl) {
          modalLoginErrorEl.innerText =
            checkoutStrings.errLoginFailed + error.message;
          modalLoginErrorEl.classList.remove('hidden');
        }
        return;
      }

      console.log(
        '[Checkout Modal] Login success, hiding modal and reloading session',
      );
      const loginModal = document.getElementById('login-modal');
      if (loginModal) loginModal.classList.add('hidden');

      window.location.reload();
    });

    // Close Login Modal
    const btnCloseLoginModal = document.getElementById('btn-close-login-modal');
    btnCloseLoginModal?.addEventListener('click', () => {
      const loginModal = document.getElementById('login-modal');
      if (loginModal) loginModal.classList.add('hidden');
    });

    // Toggle Password Visibility
    document.querySelectorAll('.toggle-password').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = (btn as HTMLElement).dataset.target;
        if (!targetId) return;
        const input = document.getElementById(targetId) as HTMLInputElement;
        if (!input) return;

        if (input.type === 'password') {
          input.type = 'text';
          btn.innerHTML = `<svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7 1.274-4.057-5.064-7-9.542-7 4.477 0 8.268-2.943 9.542-7zm-5.04 1.524c-1.265-.438-2.432-1.112-3.473-1.983m1.42-1.42a3 3 0 114.243 4.243 3 3 0 01-4.243-4.243z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 3l18 18'></path></svg>`;
        } else {
          input.type = 'password';
          btn.innerHTML = `<svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>`;
        }
      });
    });
  </script>
</BaseLayout>
