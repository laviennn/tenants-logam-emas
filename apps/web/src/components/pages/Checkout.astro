---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../SectionTitle.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { resolveTenant, getSiteSettings, getImageUrl } from '../../lib/cms';

interface Props {
  lang?: 'id' | 'en' | 'my';
}

const { lang: propLang } = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// ── Resolve Tenant ────────────────────────────────────────
const hostname = Astro.url.hostname + (Astro.url.port ? `:${Astro.url.port}` : '');
const tenant = await resolveTenant(hostname);
const tenantId = tenant?.id;

const siteSettings = (tenantId ? await getSiteSettings(tenantId, lang) : null) || {
  shippingMethods: [],
  paymentChannels: [],
  whatsappNumber: '6281234567890',
};
---

<BaseLayout title='Checkout' tenantId={tenantId} siteSettings={siteSettings}>
  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12'>
    <SectionTitle
      title={t('checkout.title')}
      subtitle={t('checkout.subtitle')}
      i18nTitle='checkout.title'
      i18nSubtitle='checkout.subtitle'
    />

    <div id='global-toast' class='hidden mb-6 rounded-xl p-4 text-sm font-medium border'></div>

    <div
      id='checkout-container'
      class='grid grid-cols-1 lg:grid-cols-12 gap-12 hidden mt-8'>
      <!-- Form Kiri -->
      <div class='lg:col-span-7'>
        <form
          id='checkout-form'
          class='space-y-8'>
          <!-- Data Pembeli -->
          <div
            class='bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800'>
            <h3
              data-i18n='checkout.buyer_data'
              class='text-xl font-bold mb-4 text-gray-900 dark:text-white'>
              {t('checkout.buyer_data')}
            </h3>
            <div class='grid grid-cols-1 md:grid-cols-2 gap-4'>
              <div>
                <label
                  data-i18n='checkout.full_name'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  >{t('checkout.full_name')}</label
                >
                <input
                  type='text'
                  id='name'
                  required
                  class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                />
              </div>
              <div>
                <label
                  data-i18n='checkout.email'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  >{t('checkout.email')}</label
                >
                <input
                  type='email'
                  id='email'
                  required
                  class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                />
              </div>
              <div class='md:col-span-2'>
                <label
                  data-i18n='checkout.whatsapp'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  >{t('checkout.whatsapp')}</label
                >
                <input
                  type='tel'
                  id='phone'
                  required
                  class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  placeholder='Contoh: 081234567890'
                />
                <p
                  id='phone-error'
                  class='text-red-500 text-[11px] font-bold mt-1 hidden uppercase tracking-wider bg-red-50 dark:bg-red-900/20 p-2 rounded border border-red-100 dark:border-red-900/30'>
                  ⚠️ Format nomor salah. Harus diawali 08... atau 62... dan hanya angka.
                </p>
              </div>
            </div>

            <!-- Password Info -->
            <div
              id='password-section'
              class='mt-6 border-t border-gray-200 dark:border-gray-700 pt-6'>
              <div
                class='bg-yellow-50 dark:bg-yellow-900/30 p-4 rounded-lg border border-yellow-200 dark:border-yellow-800 mb-4 flex items-start'>
                <span class='text-xl mr-3'>⚠️</span>
                <p
                  data-i18n='checkout.password_info'
                  class='text-sm text-yellow-800 dark:text-yellow-200 font-medium'>
                  {t('checkout.password_info')}
                </p>
              </div>
              <div class='grid grid-cols-1 md:grid-cols-2 gap-4'>
                <div>
                  <label
                    data-i18n='checkout.password'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.password')}</label
                  >
                  <div class='relative'>
                    <input
                      type='password'
                      id='password'
                      minlength='6'
                      class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                    />
                    <button type='button' class='absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 toggle-password' data-target='password'>
                      <svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>
                    </button>
                  </div>
                  <p class='text-xs text-gray-500 dark:text-gray-400 mt-1'>Minimal 6 karakter.</p>
                  <p id='password-error' class='text-xs text-red-500 hidden mt-1'>Password minimal 6 karakter.</p>
                </div>
                <div>
                  <label
                    data-i18n='checkout.confirm_password'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.confirm_password')}</label
                  >
                  <div class='relative'>
                    <input
                      type='password'
                      id='confirm-password'
                      minlength='6'
                      class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                    />
                    <button type='button' class='absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 toggle-password' data-target='confirm-password'>
                      <svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Alamat Pengiriman -->
          <div
            class='bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800'>
            <h3
              data-i18n='checkout.shipping_address'
              class='text-xl font-bold mb-4 text-gray-900 dark:text-white'>
              {t('checkout.shipping_address')}
            </h3>
            <div class='space-y-4'>
              <div>
                <label
                  data-i18n='checkout.full_address'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                  >{t('checkout.full_address')}</label
                >
                <textarea
                  id='address'
                  rows='3'
                  required
                  class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                ></textarea>
              </div>
              <div class='grid grid-cols-1 md:grid-cols-2 gap-4'>
                <div>
                  <label
                    data-i18n='checkout.province'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.province')}</label
                  >
                  <input
                    type='text'
                    id='province'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                </div>
                <div>
                  <label
                    data-i18n='checkout.city'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.city')}</label
                  >
                  <input
                    type='text'
                    id='city'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                </div>
                <div>
                  <label
                    data-i18n='checkout.district'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.district')}</label
                  >
                  <input
                    type='text'
                    id='district'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                </div>
                <div>
                  <label
                    data-i18n='checkout.zipcode'
                    class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'
                    >{t('checkout.zipcode')}</label
                  >
                  <input
                    type='text'
                    id='zipcode'
                    required
                    class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary'
                  />
                </div>
              </div>
            </div>
          </div>

          <!-- Pengiriman & Pembayaran -->
          <div
            class='bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800'>
            <h3
              data-i18n='checkout.shipping_payment'
              class='text-xl font-bold mb-4 text-gray-900 dark:text-white'>
              {t('checkout.shipping_payment')}
            </h3>
            <div class='space-y-6'>
              <!-- Shipping Cards -->
              <div>
                <label
                  data-i18n='checkout.choose_shipping'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3'
                  >{t('checkout.choose_shipping')}</label
                >
                <div
                  id='shipping-cards'
                  class='grid grid-cols-1 sm:grid-cols-2 gap-3'>
                  {
                    siteSettings.shippingMethods?.length > 0 ? (
                      siteSettings.shippingMethods.map((method: any) => (
                        <button
                          type='button'
                          class='shipping-card text-left p-4 rounded-xl border-2 border-gray-200 dark:border-gray-700 hover:border-primary transition-all duration-200'
                          data-name={method.name}
                          data-price={method.price}>
                          <div class='flex items-center justify-between'>
                            <div>
                              <p class='font-bold text-gray-900 dark:text-white text-sm'>
                                {method.name}
                              </p>
                              <p class='text-primary font-semibold text-sm mt-0.5'>
                                Rp {method.price.toLocaleString('id-ID')}
                              </p>
                            </div>
                            <div class='w-5 h-5 rounded-full border-2 border-gray-300 dark:border-gray-600 flex-shrink-0 shipping-radio' />
                          </div>
                        </button>
                      ))
                    ) : (
                      <p class='text-gray-500 text-sm col-span-2'>
                        Belum ada jasa pengiriman dikonfigurasi di CMS.
                      </p>
                    )
                  }
                </div>
                <input
                  type='hidden'
                  id='shipping-method'
                  required
                />
                <input
                  type='hidden'
                  id='shipping-price'
                  value='0'
                />
              </div>

              <!-- Payment Channel Cards -->
              <div>
                <label
                  data-i18n='checkout.choose_payment'
                  class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3'
                  >{t('checkout.choose_payment')}</label
                >
                <div
                  id='payment-cards'
                  class='grid grid-cols-1 sm:grid-cols-2 gap-3'>
                  {
                    siteSettings.paymentChannels?.length > 0 ? (
                      siteSettings.paymentChannels.map((channel: any) => (
                        <button
                          type='button'
                          class='payment-card text-left p-4 rounded-xl border-2 border-gray-200 dark:border-gray-700 hover:border-primary transition-all duration-200'
                          data-bank={channel.bankName}
                          data-acc={channel.accountNumber}
                          data-accname={channel.accountName}
                          data-logo={getImageUrl(channel.logo, 'thumbnail')}>
                          <div class='flex items-center gap-3'>
                            {channel.logo ? (
                              <img
                                src={getImageUrl(channel.logo, 'thumbnail')}
                                alt={channel.bankName}
                                class='h-8 w-16 object-contain flex-shrink-0'
                              />
                            ) : (
                              <div class='h-8 w-16 bg-primary/10 rounded flex items-center justify-center flex-shrink-0'>
                                <span class='text-primary font-bold text-xs'>
                                  {channel.bankName.slice(0, 3)}
                                </span>
                              </div>
                            )}
                            <div class='flex-1 min-w-0'>
                              <p class='font-bold text-gray-900 dark:text-white text-sm truncate'>
                                {channel.bankName}
                              </p>
                              <p class='text-gray-500 text-xs truncate'>
                                {channel.accountNumber} · {channel.accountName}
                              </p>
                            </div>
                            <div class='w-5 h-5 rounded-full border-2 border-gray-300 dark:border-gray-600 flex-shrink-0 payment-radio' />
                          </div>
                        </button>
                      ))
                    ) : (
                      <p class='text-gray-500 text-sm col-span-2'>
                        Belum ada channel pembayaran dikonfigurasi di CMS.
                      </p>
                    )
                  }
                </div>
                <input
                  type='hidden'
                  id='payment-method'
                  required
                />
                <input
                  type='hidden'
                  id='payment-acc'
                />
                <input
                  type='hidden'
                  id='payment-accname'
                />
                <input
                  type='hidden'
                  id='payment-logo'
                />
              </div>
            </div>
          </div>
        </form>
      </div>

      <!-- Ringkasan Kanan -->
      <div class='lg:col-span-5'>
        <div
          class='bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 sticky top-24'>
          <h3
            data-i18n='checkout.order_summary'
            class='text-xl font-bold mb-6 text-gray-900 dark:text-white'>
            {t('checkout.order_summary')}
          </h3>
          <div
            id='checkout-items'
            class='space-y-4 mb-6 max-h-60 overflow-y-auto pr-2'>
            <!-- Items inject via JS -->
          </div>

          <div
            class='border-t border-gray-200 dark:border-gray-700 pt-4 space-y-3 mb-6'>
            <div class='flex justify-between text-gray-600 dark:text-gray-400'>
              <span data-i18n='checkout.subtotal'>{t('checkout.subtotal')}</span
              >
              <span
                id='summary-subtotal'
                class='font-medium text-gray-900 dark:text-white'
                >Rp 0</span
              >
            </div>
            <div class='flex justify-between text-gray-600 dark:text-gray-400'>
              <span data-i18n='checkout.shipping_insurance'
                >{t('checkout.shipping_insurance')}</span
              >
              <span
                id='summary-shipping'
                class='font-medium text-gray-900 dark:text-white'
                >Rp 0</span
              >
            </div>
            <div
              class='border-t border-gray-200 dark:border-gray-700 pt-3 flex justify-between items-center'>
              <span
                data-i18n='checkout.total'
                class='text-lg font-bold text-gray-900 dark:text-white'
                >{t('checkout.total')}</span
              >
              <span
                id='summary-total'
                class='text-2xl font-extrabold text-primary'
                >Rp 0</span
              >
            </div>
          </div>

          <button
            id='btn-proceed'
            type='button'
            data-i18n='checkout.proceed_payment'
            class='w-full bg-cart-button hover:opacity-90 text-white font-bold py-3.5 px-4 rounded-xl transition-colors shadow-sm flex items-center justify-center'>
            {t('checkout.proceed_payment')}
            <svg
              class='w-5 h-5 ml-2'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
              ><path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M14 5l7 7m0 0l-7 7m7-7H3'
              ></path></svg
            >
          </button>
        </div>
      </div>
    </div>

    <!-- Empty State -->
    <div
      id='empty-state'
      class='text-center py-20 hidden'>
      <div
        class='w-24 h-24 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-6'>
        <svg
          class='w-10 h-10 text-gray-400'
          fill='none'
          stroke='currentColor'
          viewBox='0 0 24 24'
          ><path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z'
          ></path></svg
        >
      </div>
      <h3
        data-i18n='checkout.empty_cart'
        class='text-2xl font-bold text-gray-900 dark:text-white mb-2'>
        {t('checkout.empty_cart')}
      </h3>
      <p
        data-i18n='checkout.empty_cart_desc'
        class='text-gray-500 mb-8'>
        {t('checkout.empty_cart_desc')}
      </p>
      <a
        href='/'
        data-i18n='checkout.shop_now'
        class='inline-flex bg-cart-button hover:opacity-90 text-white font-bold py-3 px-8 rounded-lg transition-colors'
        >{t('checkout.shop_now')}</a
      >
    </div>

    <!-- Upload Proof Modal / Section -->
    <div
      id='upload-section'
      class='hidden max-w-2xl mx-auto bg-white dark:bg-surface-dark p-8 rounded-3xl shadow-xl border border-gray-100 dark:border-gray-800 mt-8'>
      <!-- Toast container for upload section -->
      <div
        id='upload-toast'
        class='hidden mb-6 rounded-xl p-4 text-sm font-medium border'>
      </div>

      <div class='text-center mb-8'>
        <h3
          data-i18n='checkout.payment_instructions'
          class='text-2xl font-bold text-gray-900 dark:text-white mb-2'>
          {t('checkout.payment_instructions')}
        </h3>
        <p class='text-gray-500'>
          <span data-i18n='checkout.transfer_instruction'
            >{t('checkout.transfer_instruction')}</span
          >
          <span
            id='upload-total'
            class='font-bold text-primary'
            >Rp 0</span>
        </p>
      </div>

      <div class='bg-gray-50 dark:bg-gray-900 p-6 rounded-2xl border border-gray-100 dark:border-gray-800 space-y-4 mb-8'>
        <!-- Header: Bank Info -->
        <div class='flex items-center gap-4'>
          <div class='w-16 h-16 bg-white rounded-xl p-2 flex items-center justify-center border border-gray-100 dark:border-gray-700 flex-shrink-0'>
            <img id='bank-logo' src='' alt='Bank Logo' class='w-full h-full object-contain hidden' />
          </div>
          <div>
            <p id='bank-name' class='text-lg font-bold text-gray-900 dark:text-white'>BCA</p>
            <span class='text-xs text-gray-500 uppercase tracking-wider'>Metode Pembayaran</span>
          </div>
        </div>
        
        <!-- Divider -->
        <div class='border-t border-gray-100 dark:border-gray-800 pt-4'>
          <!-- Account Number Section -->
          <div class='mb-4'>
            <p class='text-xs text-gray-500 mb-1'>Nomor Rekening</p>
            <div class='flex items-center justify-between gap-3'>
              <p id='bank-account' class='text-xl sm:text-2xl font-mono font-black text-primary tracking-wider'>
                1234567890
              </p>
              <button id='btn-copy' class='flex items-center gap-1 p-2 text-xs text-primary hover:text-primary-dark transition-colors flex-shrink-0' title='Salin Nomor Rekening'>
                <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3'></path>
                </svg>
                <span>Salin</span>
              </button>
            </div>
          </div>
          
          <!-- Account Name Section -->
          <div>
            <p class='text-xs text-gray-500 mb-1'>Atas Nama</p>
            <p id='bank-acc-name' class='text-base font-semibold text-gray-900 dark:text-white uppercase'>
              A.N. PT Logam Mulia
            </p>
          </div>
        </div>
      </div>

      <div class='space-y-4'>
        <label
          data-i18n='checkout.upload_proof'
          class='block text-sm font-medium text-gray-700 dark:text-gray-300'
          >{t('checkout.upload_proof')}</label
        >
        <input
          type='file'
          id='payment-proof'
          accept='image/*'
          class='block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 cursor-pointer'
        />
      </div>

      <button
        id='btn-confirm'
        data-brand={siteSettings.brandName}
        type='button'
        data-i18n='checkout.confirm_wa'
        data-wa={siteSettings.whatsappNumber}
        class='mt-8 w-full bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-3.5 px-4 rounded-xl transition-colors shadow-sm flex items-center justify-center disabled:opacity-50 disabled:cursor-not-allowed'>
        {t('checkout.confirm_wa')}
        <svg
          class='w-5 h-5 ml-2'
          fill='currentColor'
          viewBox='0 0 24 24'
          ><path
            d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'
          ></path></svg
