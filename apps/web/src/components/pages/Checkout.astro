            <button type='button' id='btn-close-login-modal' class='w-full bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold py-3 px-4 rounded-xl transition-colors mt-2' data-i18n="checkout.cancel">
