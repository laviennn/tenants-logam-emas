<!-- Bridge: pass tenantId from server to client -->
<script is:inline define:vars={{ tenantId }}>
  window.__tenantId = tenantId;
</script>

<script>
  import { cartStore } from '../../lib/cart';
  import { supabase } from '../../lib/supabase';
  import { CMS_URL, getImageUrl } from '../../lib/cms';

  // tenantId passed from server via window.__tenantId
  const tenantIdVar = (window as any).__tenantId;

  console.log('[Checkout] Initializing with CMS_URL:', CMS_URL);

  // ── Toast helper ──────────────────────────────────────────────
  const showToast = (
    message: string,
    type: 'error' | 'success' | 'warning',
    containerId = 'global-toast',
  ) => {
    const toast = document.getElementById(containerId);
    if (!toast) return;
    toast.innerText = message;
    toast.className = 'mb-6 rounded-xl p-4 text-sm font-medium border'; // reset
    if (type === 'error')
      toast.classList.add(
        'bg-red-50',
        'text-red-800',
        'border-red-200',
        'dark:bg-red-900/30',
        'dark:text-red-200',
      );
    if (type === 'success')
      toast.classList.add(
        'bg-green-50',
        'text-green-800',
        'border-green-200',
        'dark:bg-green-900/30',
        'dark:text-green-200',
      );
    if (type === 'warning')
      toast.classList.add(
        'bg-yellow-50',
        'text-yellow-800',
        'border-yellow-200',
        'dark:bg-yellow-900/30',
        'dark:text-yellow-200',
      );
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 6000);
  };

  // ── Terminal Logger helper ────────────────────────────────────
  const logToTerminal = async (message: string, details: any = null) => {
    console.log(`[Terminal Log] ${message}`, details);
    try {
      await fetch(`${CMS_URL}/api/client-log`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ level: 'error', message, details }),
      });
    } catch (e) {
      console.error('Failed to send log to terminal:', e);
    }
  };

  const formatCurrency = (val: number) =>
    new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0,
    }).format(val);

  // Render Cart Items
  const renderCheckoutItems = () => {
    const cart = cartStore.get();
    const itemsContainer = document.getElementById('checkout-items');
    const items = Object.values(cart);

    if (items.length === 0) {
      document.getElementById('checkout-container')?.classList.add('hidden');
      document.getElementById('empty-state')?.classList.remove('hidden');
      return;
    }

    document.getElementById('checkout-container')?.classList.remove('hidden');
    document.getElementById('empty-state')?.classList.add('hidden');

    let subtotal = 0;
    if (itemsContainer) {
      itemsContainer.innerHTML = items
        .map((item) => {
          const safePrice = Number(item.price) || 0;
          const safeQty = Number(item.quantity) || 0;
          subtotal += safePrice * safeQty;
          return `
          <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-800 last:border-0">
            <div class="flex items-center">
              <img src="${item.image}" alt="${item.name}" class="w-12 h-12 object-cover rounded bg-gray-100 mr-3" />
              <div>
                <p class="text-sm font-semibold text-gray-900 dark:text-white line-clamp-1">${item.name}</p>
                <p class="text-xs text-gray-500">${item.quantity} x ${formatCurrency(item.price)}</p>
              </div>
            </div>
            <p class="text-sm font-bold text-gray-900 dark:text-white">${formatCurrency(item.price * item.quantity)}</p>
          </div>
        `;
        })
        .join('');
    }

    const shippingPriceInput = document.getElementById(
      'shipping-price',
    ) as HTMLInputElement;
    const shippingPrice = parseInt(shippingPriceInput?.value || '0', 10);

    const total = subtotal + shippingPrice;

    const subEl = document.getElementById('summary-subtotal');
    if (subEl) subEl.innerText = formatCurrency(subtotal);

    const shippingEl = document.getElementById('summary-shipping');
    if (shippingEl) shippingEl.innerText = formatCurrency(shippingPrice);

    const totEl = document.getElementById('summary-total');
    if (totEl) totEl.innerText = formatCurrency(total);

    const upTotEl = document.getElementById('upload-total');
    if (upTotEl) upTotEl.innerText = formatCurrency(total);
  };

  // Initialize
  renderCheckoutItems();

  // Shipping Card Selection
  document.querySelectorAll('.shipping-card').forEach((card) => {
    card.addEventListener('click', () => {
      const name = (card as HTMLElement).dataset.name || '';
      const price = (card as HTMLElement).dataset.price || '0';

      // Update hidden inputs
      (document.getElementById('shipping-method') as HTMLInputElement).value =
        name;
      (document.getElementById('shipping-price') as HTMLInputElement).value =
        price;

      // Update UI active state
      document.querySelectorAll('.shipping-card').forEach((c) => {
        c.classList.remove('border-primary', 'bg-primary/5');
        c.querySelector('.shipping-radio')?.classList.remove(
          'bg-primary',
          'border-primary',
        );
      });
      card.classList.add('border-primary', 'bg-primary/5');
      card
        .querySelector('.shipping-radio')
        ?.classList.add('bg-primary', 'border-primary');

      renderCheckoutItems();
    });
  });

  // Payment Card Selection
  document.querySelectorAll('.payment-card').forEach((card) => {
    card.addEventListener('click', () => {
      const bank = (card as HTMLElement).dataset.bank || '';
      const acc = (card as HTMLElement).dataset.acc || '';
      const name = (card as HTMLElement).dataset.accname || '';
      const logo = (card as HTMLElement).dataset.logo || '';

      // Update hidden inputs
      (document.getElementById('payment-method') as HTMLInputElement).value =
        bank;
      (document.getElementById('payment-acc') as HTMLInputElement).value = acc;
      (document.getElementById('payment-accname') as HTMLInputElement).value =
        name;
      (document.getElementById('payment-logo') as HTMLInputElement).value =
        logo;

      // Update UI active state
      document.querySelectorAll('.payment-card').forEach((c) => {
        c.classList.remove('border-primary', 'bg-primary/5');
        c.querySelector('.payment-radio')?.classList.remove(
          'bg-primary',
          'border-primary',
        );
      });
      card.classList.add('border-primary', 'bg-primary/5');
      card
        .querySelector('.payment-radio')
        ?.classList.add('bg-primary', 'border-primary');
    });
  });

  // Phone Validation
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  const phoneError = document.getElementById('phone-error');
  phoneInput?.addEventListener('input', () => {
    const val = phoneInput.value.replace(/\D/g, '');
    const phoneRegex = /^(08|628)[0-9]{8,13}$/;
    if (val.length > 0 && !phoneRegex.test(val)) {
      phoneError?.classList.remove('hidden');
      phoneInput.classList.add('border-red-500', 'ring-red-500');
    } else {
      phoneError?.classList.add('hidden');
      phoneInput.classList.remove('border-red-500', 'ring-red-500');
    }
  });

  // Supabase Auth logic
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session?.user) {
      // Auto-fill and hide password fields if logged in
      const pwSection = document.getElementById('password-section');
      if (pwSection) pwSection.style.display = 'none';
      const emailEl = document.getElementById('email') as HTMLInputElement;
      if (emailEl && session.user.email) {
        emailEl.value = session.user.email;
        emailEl.readOnly = true;
      }
    }
  });

  // Proceed button logic
  const btnProceed = document.getElementById('btn-proceed');
  btnProceed?.addEventListener('click', async () => {
    const form = document.getElementById('checkout-form') as HTMLFormElement;
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const phoneInput = document.getElementById('phone') as HTMLInputElement;
    const phoneVal = phoneInput.value;
    const phoneRegex = /^(08|62)[0-9]{8,13}$/;
    
    if (!phoneRegex.test(phoneVal)) {
      showToast(
        'Format nomor WhatsApp tidak valid. Harus diawali 08... atau 62... (10-15 digit).',
        'warning',
      );
      phoneInput.focus();
      const phoneError = document.getElementById('phone-error');
      phoneError?.classList.remove('hidden');
      return;
    }

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement)
      ?.value;
    const confirmPassword = (
      document.getElementById('confirm-password') as HTMLInputElement
    )?.value;

    const {
      data: { session },
    } = await supabase.auth.getSession();

    if (!session && password) {
      if (password !== confirmPassword) {
        showToast(
          'Password dan konfirmasi password tidak cocok. Harap periksa kembali.',
          'warning',
          'upload-toast',
        );
        console.warn('[Checkout] Password mismatch for email:', email);
        return;
      }

      const { data, error } = await supabase.auth.signUp({ email, password });

      if (error) {
        console.error('[Checkout] Supabase signUp error:', error);
        showToast(
          'Gagal membuat akun: ' + error.message,
          'error',
          'upload-toast',
        );
        return;
      }
    }

    // Update UI for Payment Method selection (Instructions)
    const bankName = (
      document.getElementById('payment-method') as HTMLInputElement
    ).value;
    const bankAcc = (document.getElementById('payment-acc') as HTMLInputElement)
      .value;
    const bankAccName = (
      document.getElementById('payment-accname') as HTMLInputElement
    ).value;
    const bankLogo = (
      document.getElementById('payment-logo') as HTMLInputElement
    ).value;

    if (!bankName) {
      showToast(
        'Harap pilih channel pembayaran terlebih dahulu.',
        'warning',
        'upload-toast',
      );
      return;
    }

    const bNameEl = document.getElementById('bank-name');
    if (bNameEl) bNameEl.innerText = bankName;

    const bAccEl = document.getElementById('bank-account');
    if (bAccEl) bAccEl.innerText = bankAcc;

    const bAccNameEl = document.getElementById('bank-acc-name');
    if (bAccNameEl) bAccNameEl.innerText = 'A.N. ' + bankAccName;

    const bLogoEl = document.getElementById('bank-logo') as HTMLImageElement;
    if (bLogoEl) {
      if (bankLogo) {
        bLogoEl.src = bankLogo;
        bLogoEl.classList.remove('hidden');
      } else {
        bLogoEl.classList.add('hidden');
      }
    }

    document.getElementById('checkout-container')?.classList.add('hidden');
    document.getElementById('upload-section')?.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });

    // Copy Button logic
    const btnCopy = document.getElementById('btn-copy');
    btnCopy?.addEventListener('click', () => {
      navigator.clipboard.writeText(bankAcc).then(() => {
        const originalIcon = btnCopy.innerHTML;
        btnCopy.innerHTML =
          '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
        setTimeout(() => {
          btnCopy.innerHTML = originalIcon;
        }, 2000);
      });
    });
  });

  // Confirm button logic
  const btnConfirm = document.getElementById(
    'btn-confirm',
  ) as HTMLButtonElement | null;
  btnConfirm?.addEventListener('click', async () => {
    // Validations
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const phoneInput = document.getElementById('phone') as HTMLInputElement;
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(emailInput.value)) {
      showToast('Harap masukkan format email yang valid.', 'warning');
      return;
    }



    const fileInput = document.getElementById(
      'payment-proof',
    ) as HTMLInputElement;
    if (!fileInput.files || fileInput.files.length === 0) {
      showToast('Harap upload foto bukti transfer terlebih dahulu.', 'warning');
      console.warn('[Checkout] User tried to confirm without uploading proof.');
      return;
    }

    const file = fileInput.files[0];
    if (file.size > 4 * 1024 * 1024) {
      // 4MB
      showToast(
        'Ukuran file maksimal 4MB. Harap kompres atau pilih file lain.',
        'warning',
      );
      return;
    }

    const orderId = 'ORD-' + Date.now();
    if (btnConfirm) {
      btnConfirm.innerText = 'Mengupload...';
      btnConfirm.setAttribute('disabled', 'true');
    }

    // Build order details first (needed for both upload-success and fallback paths)
    const cart = cartStore.get();
    let orderList = '';
    Object.values(cart).forEach((item) => {
      orderList += `- ${item.name} (${item.quantity}x)\n`;
    });
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const total = document.getElementById('summary-total')?.innerText || '0';

    // 1. Upload to Supabase Storage (bucket: payment-proofs, must be public)
    let publicUrl = '(tidak tersedia)';
    const { data: uploadData, error: uploadError } = await supabase.storage
      .from('payment-proofs')
      .upload(`proofs/${orderId}-${file.name}`, file);

    if (uploadError) {
      // 1. Log to browser console
      console.error('[Checkout] Supabase Storage upload error:', uploadError);

      // 2. Log to CMS Terminal (as requested)
      await logToTerminal(`Upload gagal untuk Order ID: ${orderId}`, {
        error: uploadError.message,
        hint: 'Pastikan SQL Policy sudah dijalankan di Dashboard Supabase!',
        bucket: 'payment-proofs',
        fileName: file.name,
      });

      // Show friendly non-blocking warning — order still proceeds
      showToast(
        'Upload bukti gagal (storage belum dikonfigurasi). Pesanan tetap dilanjutkan — harap kirim bukti transfer manual ke admin.',
        'warning',
      );

      // Give user 2s to read the warning before proceeding
      await new Promise((r) => setTimeout(r, 2000));
    } else {
      const { data: urlData } = supabase.storage
        .from('payment-proofs')
        .getPublicUrl(`proofs/${orderId}-${file.name}`);
      publicUrl = urlData?.publicUrl || publicUrl;
      console.log('[Checkout] Upload success. Public URL:', publicUrl);
    }

    // 2. Save to Payload CMS API
    try {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      const payloadTransaction = {
        tenant: tenantIdVar || undefined,
        orderId,
        status: uploadError ? 'Pending' : 'Paid',
        customerDetails: {
          name: (document.getElementById('name') as HTMLInputElement).value,
          email: emailInput.value,
          phone: phoneInput.value,
          address: (document.getElementById('address') as HTMLTextAreaElement)
            .value,
        },
        items: Object.values(cart).map((item) => ({
          productId: item.id,
          productName: item.name,
          quantity: Number(item.quantity),
          priceAtPurchase: Number(item.price),
        })),
        shippingMethod: (
          document.getElementById('shipping-method') as HTMLInputElement
        ).value,
        shippingCost: Number(
          (document.getElementById('shipping-price') as HTMLInputElement).value,
        ),
        paymentChannel: (
          document.getElementById('payment-method') as HTMLInputElement
        ).value,
        subtotal: Object.values(cart).reduce(
          (acc, item) => acc + Number(item.price) * Number(item.quantity),
          0,
        ),
        total: Number(total.replace(/[^0-9]/g, '')),
        paymentProofUrl: publicUrl,
        supabaseUserId: session?.user?.id || 'guest',
      };

      console.log(
        '[Checkout] Sending transaction to Payload CMS...',
        payloadTransaction,
      );

      const response = await fetch(`${CMS_URL}/api/transactions`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payloadTransaction),
      });

      console.log('[Checkout] Payload response status:', response.status);

      if (!response.ok) {
        const errData = await response.json();
        console.error('[Checkout] Payload API error:', errData);
        showToast(
          'Gagal memproses pesanan ke server. Silakan coba lagi.',
          'error',
        );
        if (btnConfirm) {
          btnConfirm.innerText = 'Konfirmasi & Hubungi Admin via WhatsApp';
          btnConfirm.removeAttribute('disabled');
        }
        return; // Hentikan proses, jangan reset cart
      } else {
        console.log('[Checkout] Transaction saved to Payload CMS.');
      }
    } catch (e) {
      console.error('[Checkout] Failed to save transaction to Payload:', e);
      showToast(
        'Gagal terhubung ke server (Network Error). Silakan periksa koneksi Anda.',
        'error',
      );
      if (btnConfirm) {
        btnConfirm.innerText = 'Konfirmasi & Hubungi Admin via WhatsApp';
        btnConfirm.removeAttribute('disabled');
      }
      return; // Hentikan proses, jangan reset cart
    }

    // 3. Clear cart (hanya jika sukses masuk database)
    cartStore.set({});

    // 4. Redirect to WhatsApp
    const email = emailInput.value;
    const phone = phoneInput.value;
    const address = (document.getElementById('address') as HTMLTextAreaElement)
      .value;
    const province = (document.getElementById('province') as HTMLInputElement)
      .value;
    const city = (document.getElementById('city') as HTMLInputElement).value;
    const shippingMethod = (
      document.getElementById('shipping-method') as HTMLInputElement
    ).value;

    const brandName = btnConfirm?.dataset.brand || 'Mulia Gold';
    const waText = `Halo Admin ${brandName}, saya ingin konfirmasi pembayaran:

*Order ID:* ${orderId}
*Nama Lengkap:* ${name}
*Email:* ${email}
*No Telephone:* ${phone}
*Alamat Pengiriman:* ${address}, ${city}, ${province}
*Jasa Pengiriman:* ${shippingMethod}

*Daftar Pesanan:*
${orderList}
*Total Pembayaran:* ${total}

*Bukti Pembayaran:* ${publicUrl}`;

    // 4. Show Success Modal instead of direct redirect (to avoid popup blocker)
    const adminWA = btnConfirm?.dataset.wa || '6281234567890';
    const waUrl = `https://wa.me/${adminWA}?text=${encodeURIComponent(waText)}`;

    const modal = document.getElementById('success-modal');
    const modalContent = document.getElementById('success-modal-content');
    const btnSuccessWa = document.getElementById('btn-success-wa');

    if (modal && modalContent && btnSuccessWa) {
      modal.classList.remove('hidden');
      setTimeout(() => {
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
      }, 50);

      btnSuccessWa.addEventListener('click', () => {
        // Open WA in new tab (This is now a direct user action, so it won't be blocked)
        window.open(waUrl, '_blank');
        // Redirect current tab to Track Order
        window.location.href = `/track-order?id=${orderId}`;
      });
    }
  });
  // Real-time Phone Validation
  const phoneInputEl = document.getElementById('phone') as HTMLInputElement;
  const phoneErrorEl = document.getElementById('phone-error');

  phoneInputEl?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    // Bersihkan karakter non-angka
    const originalValue = target.value;
    const cleanedValue = originalValue.replace(/\D/g, '');
    
    if (originalValue !== cleanedValue) {
      target.value = cleanedValue;
    }

    // Validasi format awalan (08 atau 62)
    const val = target.value;
    if (val.length >= 2) {
      if (!val.startsWith('08') && !val.startsWith('62')) {
        phoneErrorEl?.classList.remove('hidden');
        target.classList.add('border-red-500', 'ring-red-500');
      } else {
        phoneErrorEl?.classList.add('hidden');
        target.classList.remove('border-red-500', 'ring-red-500');
      }
    } else if (val.length > 0) {
       // Masih mengetik digit pertama, jangan show error dulu kecuali jika digit pertama bukan 0 atau 6
       if (val !== '0' && val !== '6') {
         phoneErrorEl?.classList.remove('hidden');
       } else {
         phoneErrorEl?.classList.add('hidden');
       }
    } else {
      phoneErrorEl?.classList.add('hidden');
      target.classList.remove('border-red-500', 'ring-red-500');
    }
  });

  // Phone Validation on Blur
  phoneInputEl?.addEventListener('blur', () => {
    const val = phoneInputEl.value;
    if (val.length > 0 && !val.startsWith('08') && !val.startsWith('62')) {
      phoneErrorEl?.classList.remove('hidden');
      phoneInputEl.classList.add('border-red-500', 'ring-red-500');
    }
  });

  // Password Validation on Blur
  const passwordInputEl = document.getElementById('password') as HTMLInputElement;
  const passwordErrorEl = document.getElementById('password-error');
  passwordInputEl?.addEventListener('blur', () => {
    const val = passwordInputEl.value;
    if (val.length < 6) {
      passwordErrorEl?.classList.remove('hidden');
      passwordInputEl.classList.add('border-red-500', 'ring-red-500');
    } else {
      passwordErrorEl?.classList.add('hidden');
      passwordInputEl.classList.remove('border-red-500', 'ring-red-500');
    }
  });

  passwordInputEl?.addEventListener('input', () => {
    const val = passwordInputEl.value;
    if (val.length >= 6) {
      passwordErrorEl?.classList.add('hidden');
      passwordInputEl.classList.remove('border-red-500', 'ring-red-500');
    }
  });

  // Real-time Email Check on Blur (RPC)
  const emailInputEl = document.getElementById('email') as HTMLInputElement;
  emailInputEl?.addEventListener('blur', async () => {
    const email = emailInputEl.value;
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) return;

    console.log('[Checkout] Checking email existence via RPC:', email);
    const { data: exists, error } = await supabase.rpc('check_email_exists', { email_to_check: email });

    if (error) {
      console.error('[Checkout] RPC error checking email:', error);
      return;
    }

    if (exists) {
      console.log('[Checkout] Email already exists, showing login modal');
      const loginModal = document.getElementById('login-modal');
      const modalContent = document.getElementById('login-modal-content');
      if (loginModal && modalContent) {
        loginModal.classList.remove('hidden');
        setTimeout(() => {
          modalContent.classList.remove('scale-95', 'opacity-0');
          modalContent.classList.add('scale-100', 'opacity-100');
        }, 50);
        
        const modalEmailInput = document.getElementById('modal-email') as HTMLInputElement;
        if (modalEmailInput) modalEmailInput.value = email;
      }
    }
  });

  // Modal Login Form Submission
  const modalLoginForm = document.getElementById('modal-login-form') as HTMLFormElement;
  modalLoginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('modal-email') as HTMLInputElement).value;
    const password = (document.getElementById('modal-password') as HTMLInputElement).value;
    const modalLoginErrorEl = document.getElementById('modal-login-error');

    modalLoginErrorEl?.classList.add('hidden');

    console.log('[Checkout Modal] Attempting login for:', email);
    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      console.error('[Checkout Modal] Login error:', error);
      if (modalLoginErrorEl) {
        modalLoginErrorEl.innerText = 'Gagal masuk: ' + error.message;
        modalLoginErrorEl.classList.remove('hidden');
      }
      return;
    }

    console.log('[Checkout Modal] Login success, hiding modal and reloading session');
    const loginModal = document.getElementById('login-modal');
    if (loginModal) loginModal.classList.add('hidden');
    
    window.location.reload();
  });

  // Close Login Modal
  const btnCloseLoginModal = document.getElementById('btn-close-login-modal');
  btnCloseLoginModal?.addEventListener('click', () => {
    const loginModal = document.getElementById('login-modal');
    if (loginModal) loginModal.classList.add('hidden');
  });

  // Toggle Password Visibility
  document.querySelectorAll('.toggle-password').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;
      const input = document.getElementById(targetId) as HTMLInputElement;
      if (!input) return;
      
      if (input.type === 'password') {
        input.type = 'text';
        btn.innerHTML = `<svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7 1.274-4.057-5.064-7-9.542-7 4.477 0 8.268-2.943 9.542-7zm-5.04 1.524c-1.265-.438-2.432-1.112-3.473-1.983m1.42-1.42a3 3 0 114.243 4.243 3 3 0 01-4.243-4.243z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 3l18 18'></path></svg>`;
      } else {
        input.type = 'password';
        btn.innerHTML = `<svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>`;
      }
    });
  });
</script>
