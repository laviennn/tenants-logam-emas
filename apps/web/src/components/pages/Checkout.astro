            ✅
          </div>
          <h3 class='text-2xl font-black text-gray-900 dark:text-white mb-2'>
            Pesanan Berhasil!
          </h3>
          <p class='text-gray-500 dark:text-gray-400 mb-8'>
            Data pesanan Anda telah kami terima. Silakan klik tombol di bawah
            untuk konfirmasi via WhatsApp dan melacak pesanan Anda.
          </p>

          <div class='space-y-3'>
            <button
              id='btn-success-wa'
              class='w-full bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-4 px-6 rounded-2xl transition-all shadow-lg flex items-center justify-center gap-3'>
              <svg
                class='w-6 h-6'
                fill='currentColor'
                viewBox='0 0 24 24'
                ><path
                  d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'
                ></path></svg
              >
              Konfirmasi WhatsApp
            </button>
            <p
              class='text-[10px] text-gray-400 uppercase font-black tracking-widest mt-4 italic'>
              Otomatis diarahkan ke halaman lacak pesanan
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Login Modal -->
    <div
      id='login-modal'
      class='fixed inset-0 z-[100] flex items-center justify-center px-4 hidden'>
      <div class='absolute inset-0 bg-gray-900/60 backdrop-blur-sm'></div>
      <div
        class='bg-white dark:bg-surface-dark w-full max-w-md rounded-3xl shadow-2xl relative z-10 overflow-hidden transform transition-all'
        id='login-modal-content'>
        <div class='p-8'>
          <div class='text-center mb-6'>
            <div class='w-16 h-16 bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl'>
              ⚠️
            </div>
            <h3 class='text-xl font-bold text-gray-900 dark:text-white mb-2' data-i18n="checkout.email_registered_title">
              {t('checkout.email_registered_title') || 'Email Sudah Terdaftar'}
            </h3>
            <p class='text-sm text-gray-500 dark:text-gray-400' data-i18n="checkout.email_registered_desc">
              {t('checkout.email_registered_desc') || 'Email ini sudah memiliki akun. Silakan masuk untuk melanjutkan pesanan.'}
            </p>
          </div>

          <form id='modal-login-form' class='space-y-4'>
            <!-- Error Container -->
            <div id='modal-login-error' class='hidden rounded-lg p-3 text-sm font-medium bg-red-50 text-red-800 border border-red-200 dark:bg-red-900/30 dark:text-red-200 dark:border-red-800'></div>
            
            <div>
              <label for='modal-email' class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' data-i18n="checkout.email">{t('checkout.email')}</label>
              <input type='email' id='modal-email' readonly class='w-full px-4 py-2 bg-gray-100 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary' />
            </div>
            <div>
              <label for='modal-password' class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' data-i18n="checkout.password">{t('checkout.password')}</label>
              <div class='relative'>
                <input type='password' id='modal-password' required class='w-full px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-primary' />
                <button type='button' class='absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 toggle-password' data-target='modal-password'>
                  <!-- Eye Icon -->
                  <svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>
                </button>
