---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../SectionTitle.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';

interface Props {
  lang?: 'id' | 'en' | 'my';
}

const { lang: propLang } = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('login.forgot_password') || 'Lupa Password'}>
  <div class="min-h-[70vh] flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white dark:bg-surface-dark p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800">
      <div>
        <SectionTitle title={t('login.forgot_password') || 'Lupa Password'} i18nTitle="login.forgot_password" />
        <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400" data-i18n="forgot_password.desc">
          {t('forgot_password.desc') || 'Masukkan email Anda untuk menerima link reset password.'}
        </p>
      </div>
      <form id="forgot-password-form" class="mt-8 space-y-6">
        <!-- Toast Notification Container -->
        <div id="toast" class="hidden rounded-lg p-4 mb-4 text-sm font-medium"></div>
        
        <div class="rounded-md shadow-sm space-y-4">
          <div>
            <label for="email-address" class="sr-only">Email address</label>
            <input id="email-address" name="email" type="email" autocomplete="email" required class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-700 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-primary focus:border-primary focus:z-10 sm:text-sm" placeholder="Email address">
          </div>
          <div>
            <label for="new-password" class="sr-only">Password Baru</label>
            <div class="relative">
              <input id="new-password" name="password" type="password" required minlength="6" class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-700 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-primary focus:border-primary focus:z-10 sm:text-sm" placeholder="Password Baru">
              <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 toggle-password" data-target="new-password">
                <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>
              </button>
            </div>
            <p id="password-error" class="text-xs text-red-500 hidden mt-1">Password minimal 6 karakter.</p>
          </div>
        </div>

        <div>
          <button type="submit" id="btn-submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-primary hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors disabled:opacity-50" data-i18n="forgot_password.submit_btn">
            {t('forgot_password.submit_btn') || 'Ubah Password'}
          </button>
        </div>

        <div class="text-center">
          <a href={localizePath('/login', lang)} class="font-medium text-primary hover:text-primary-dark" data-i18n="forgot_password.back_to_login">
            {t('forgot_password.back_to_login') || 'Kembali ke Login'}
          </a>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase';

  const form = document.getElementById('forgot-password-form') as HTMLFormElement;
  const btnSubmit = document.getElementById('btn-submit');
  const toast = document.getElementById('toast');

  const showToast = (message: string, type: 'error' | 'success') => {
    if(!toast) return;
    toast.innerText = message;
    toast.classList.remove('hidden', 'bg-red-50', 'text-red-800', 'border-red-200', 'bg-green-50', 'text-green-800', 'border-green-200');
    toast.classList.add('border');
    if(type === 'error') {
      toast.classList.add('bg-red-50', 'text-red-800', 'border-red-200', 'dark:bg-red-900/30', 'dark:text-red-200');
    } else {
      toast.classList.add('bg-green-50', 'text-green-800', 'border-green-200', 'dark:bg-green-900/30', 'dark:text-green-200');
    }
    toast.classList.remove('hidden');
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(btnSubmit) {
      btnSubmit.innerText = 'Memproses...';
      btnSubmit.setAttribute('disabled', 'true');
    }

    const email = (document.getElementById('email-address') as HTMLInputElement).value;
    const newPassword = (document.getElementById('new-password') as HTMLInputElement).value;

    if (newPassword.length < 6) {
      showToast('Password minimal 6 karakter!', 'error');
      if(btnSubmit) {
        btnSubmit.innerText = 'Ubah Password';
        btnSubmit.removeAttribute('disabled');
      }
      return;
    }

    console.log('[ForgotPassword] Attempting direct password reset for:', email);
    const { data: success, error } = await supabase.rpc('reset_password_direct', { 
      email_to_find: email, 
      new_password: newPassword 
    });

    if (error) {
      console.error('[ForgotPassword] RPC error:', error);
      showToast('Gagal: ' + error.message, 'error');
      if(btnSubmit) {
        btnSubmit.innerText = 'Ubah Password';
        btnSubmit.removeAttribute('disabled');
      }
    } else if (!success) {
      showToast('Email tidak ditemukan!', 'error');
      if(btnSubmit) {
        btnSubmit.innerText = 'Ubah Password';
        btnSubmit.removeAttribute('disabled');
      }
    } else {
      showToast('Password berhasil diubah! Silakan login.', 'success');
      setTimeout(() => {
        window.location.href = '/login';
      }, 2000);
    }
  });

  // Password Validation on Blur
  const passwordInputEl = document.getElementById('new-password') as HTMLInputElement;
  const passwordErrorEl = document.getElementById('password-error');
  passwordInputEl?.addEventListener('blur', () => {
    const val = passwordInputEl.value;
    if (val.length > 0 && val.length < 6) {
      passwordErrorEl?.classList.remove('hidden');
      passwordInputEl.classList.add('border-red-500', 'ring-red-500');
    } else {
      passwordErrorEl?.classList.add('hidden');
      passwordInputEl.classList.remove('border-red-500', 'ring-red-500');
    }
  });

  // Toggle Password Visibility
  document.querySelectorAll('.toggle-password').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;
      const input = document.getElementById(targetId) as HTMLInputElement;
      if (!input) return;
      
      if (input.type === 'password') {
        input.type = 'text';
        btn.innerHTML = `<svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7 1.274-4.057-5.064-7-9.542-7 4.477 0 8.268-2.943 9.542-7zm-5.04 1.524c-1.265-.438-2.432-1.112-3.473-1.983m1.42-1.42a3 3 0 114.243 4.243 3 3 0 01-4.243-4.243z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 3l18 18'></path></svg>`;
      } else {
        input.type = 'password';
        btn.innerHTML = `<svg class='h-5 w-5 text-gray-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg>`;
      }
    });
  });
</script>
