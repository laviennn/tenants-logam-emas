---
import { Image } from 'astro:assets';
import { formatCurrency } from '../utils/currency';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  id: string;
  name: string;
  image: string;
  price: number;
  strikePrice?: number;
  soldCount?: number;
  rating?: number;
  showWhatsAppBuyButton?: boolean;
  whatsappNumber?: string;
  brandName?: string;
}

const {
  id,
  name,
  image,
  price,
  strikePrice,
  soldCount = 0,
  rating = 5,
  showWhatsAppBuyButton = false,
  whatsappNumber = '',
  brandName = 'Admin',
} = Astro.props;

// Format price using dynamic region-aware utility
const formattedPrice = formatCurrency(price);

const discountPercent = strikePrice
  ? Math.round(((strikePrice - price) / strikePrice) * 100)
  : 0;
---

<div
  class='bg-white dark:bg-surface-dark rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden hover:shadow-md transition-all duration-300 group flex flex-col h-full relative'>
  <!-- Card Link Overlay (Covers the card, but below buttons) -->
  <a
    href={`/products/${id}`}
    class='absolute inset-0 z-10'
    aria-label={`View ${name}`}
  ></a>

  <!-- Discount Badge -->
  {
    discountPercent > 0 && (
      <div class='absolute top-3 left-3 z-20 bg-red-600 text-white text-[10px] font-black px-2 py-1 rounded-lg shadow-sm pointer-events-none'>
        -{discountPercent}%
      </div>
    )
  }

  <!-- Image -->
  <div
    class='relative aspect-square overflow-hidden bg-gray-50 dark:bg-gray-900 p-3 sm:p-4 block'>
    <Image
      src={image}
      alt={name || 'Product Image'}
      width={300}
      height={300}
      loading='lazy'
      class='w-full h-full object-contain group-hover:scale-105 transition-transform duration-500'
    />
  </div>

  <div class='p-3 sm:p-4 flex flex-col flex-grow relative z-20'>
    <!-- Title -->
    <div class='block'>
      <h3
        class='text-sm font-bold text-product-title mb-2 line-clamp-2 h-10 group-hover:text-primary transition-colors'>
        {name}
      </h3>
    </div>

    <!-- Rating & Sold -->
    <div class='flex items-center gap-1 mb-2'>
      <div class='flex text-yellow-400'>
        {
          Array.from({ length: 5 }).map((_, i) => (
            <svg
              class={`w-3.5 h-3.5 ${i < Math.floor(rating) ? 'fill-current' : 'text-gray-300 dark:text-gray-600'}`}
              viewBox='0 0 20 20'>
              <path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' />
            </svg>
          ))
        }
      </div>
      <span class='text-[10px] text-gray-400 font-medium'
        >({rating.toFixed(1)}) ({soldCount})</span
      >
    </div>

    <!-- Price -->
    <div class='flex flex-wrap items-center gap-2 mb-4'>
      {
        strikePrice && (
          <span class='text-xs text-gray-400 line-through decoration-gray-400'>
            {formatCurrency(strikePrice)}
          </span>
        )
      }
      <div class='text-lg font-black text-product-price'>
        {formattedPrice}
      </div>
    </div>

    <!-- Buttons (Stacked) -->
    <div class='mt-auto space-y-2'>
      <!-- Add to Cart -->
      <button
        type='button'
        data-product={JSON.stringify({ id, name, price, image })}
        class='btn-add-cart w-full flex items-center justify-center gap-1.5 py-2 px-2 sm:px-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs sm:text-sm font-bold transition-all whitespace-nowrap'>
        <svg
          class='w-4 h-4'
          fill='none'
          stroke='currentColor'
          viewBox='0 0 24 24'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z'
          ></path>
        </svg>
        <span>{t('index.cart')}</span>
      </button>

      <!-- Buy Now -->
      <button
        type='button'
        data-product={JSON.stringify({ id, name, price, image })}
        class='btn-buy-now w-full flex items-center justify-center gap-1.5 py-2.5 px-2 sm:px-4 rounded-xl bg-cart-button hover:opacity-90 text-white text-xs sm:text-sm font-bold transition-all shadow-sm whitespace-nowrap'>
        <svg
          class='w-4 h-4'
          fill='none'
          stroke='currentColor'
          viewBox='0 0 24 24'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z'
          ></path>
        </svg>
        <span>{t('index.buy')}</span>
      </button>

      <!-- Buy via WA -->
      {
        showWhatsAppBuyButton && (
          <a
            href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(
              lang === 'id'
                ? `Halo Admin ${brandName}, saya ingin Beli:\n\n*Daftar Pesanan:*\n- ${name} (1x)\n\n*Total Harga:* ${formattedPrice}`
                : lang === 'my'
                ? `Salam ${brandName}, saya ingin mengesahkan pembayaran:\n\n*Senarai Pesanan:*\n- ${name} (1x)\n\n*Jumlah Pembayaran:* ${formattedPrice}`
                : `Hi ${brandName}, I would like to confirm my payment:\n\n*Order List:*\n- ${name} (1x)\n\n*Total Payment:* ${formattedPrice}`
            )}`}
            target='_blank'
            rel='noopener noreferrer'
            class='btn-buy-wa w-full flex items-center justify-center gap-1 sm:gap-1.5 py-2 px-1 sm:px-4 rounded-xl bg-[#25D366] hover:bg-[#20ba5a] text-white text-[11px] sm:text-sm font-bold transition-all shadow-sm relative z-30 whitespace-nowrap'
          >
            <svg class='w-3.5 h-3.5 fill-current flex-shrink-0' viewBox='0 0 24 24'>
              <path d='M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.963C16.588 2.03 14.113.999 11.5.999c-5.442 0-9.87 4.372-9.874 9.802-.001 1.73.46 3.42 1.332 4.927l-.995 3.635 3.738-.971c1.479.807 3.12 1.233 4.805 1.234zm10.51-6.912c-.297-.148-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z'/>
            </svg>
            <span>{t('product.buy_via_wa')}</span>
          </a>
        )
      }
    </div>
  </div>
</div>

<script>
  import { addToCart } from '../lib/cart';

  function initButtons() {
    document.querySelectorAll('.btn-add-cart').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const data = target.dataset.product;
        if (data) {
          const product = JSON.parse(data);
          addToCart(product, 1);
        }
      });
    });

    document.querySelectorAll('.btn-buy-now').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const data = target.dataset.product;
        if (data) {
          const product = JSON.parse(data);
          addToCart(product, 1);
          window.location.href = '/checkout';
        }
      });
    });
  }

  // Run on first load
  initButtons();
  // Run on view transition (if using Astro view transitions)
  document.addEventListener('astro:after-swap', initButtons);
</script>
