---
import { Image } from 'astro:assets';
import { formatCurrency } from '../utils/currency';

interface Props {
  id: string;
  name: string;
  image: string;
  price: number;
  strikePrice?: number;
  discountPercent?: number;
  spreadPrice?: number;
}

const {
  id,
  name,
  image,
  price,
  strikePrice,
  discountPercent: propDiscountPercent = 0,
  spreadPrice: propSpreadPrice = 0,
} = Astro.props;

const discountPercent = propDiscountPercent || 0;
const spreadPrice = propSpreadPrice || 0;

let finalPrice = price;
let hasDiscount = false;
let displayedDiscount = 0;

if (discountPercent !== 0 || spreadPrice !== 0) {
  hasDiscount = true;
  let discounted = price * (1 - (discountPercent / 100));
  finalPrice = discounted + spreadPrice;
  if (finalPrice < 0) finalPrice = 0;
  
  if (price > 0 && finalPrice < price) {
    displayedDiscount = Math.round(((price - finalPrice) / price) * 100);
  }
} else if (strikePrice && strikePrice > price) {
  hasDiscount = true;
  finalPrice = price;
  displayedDiscount = Math.round(((strikePrice - price) / strikePrice) * 100);
}

const originalPrice = hasDiscount ? (discountPercent !== 0 || spreadPrice !== 0 ? price : strikePrice) : null;
const formattedPrice = formatCurrency(finalPrice);
---

<div
  class='bg-white dark:bg-surface-dark rounded-none shadow-sm overflow-hidden hover:shadow-lg transition-all duration-300 group flex flex-col h-full relative border border-gray-100 dark:border-gray-800'>
  <!-- Card Link Overlay (Covers the card, but below buttons) -->
  <a
    href={`/products/${id}`}
    class='absolute inset-0 z-10'
    aria-label={`View ${name}`}
  ></a>

  <!-- Discount Badge -->
  {
    displayedDiscount > 0 && (
      <div class='absolute top-2 left-2 md:top-3 md:left-3 z-20 bg-red-600 text-white text-[10px] md:text-xs font-black px-2 py-1 tracking-wider uppercase pointer-events-none'>
        SALE -{displayedDiscount}%
      </div>
    )
  }

  <!-- Image -->
  <div
    class='relative aspect-square overflow-hidden bg-gray-50 dark:bg-gray-900 block'>
    <Image
      src={image}
      alt={name || 'Product Image'}
      width={400}
      height={400}
      loading='lazy'
      class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out'
    />
  </div>

  <div class='p-3 md:p-5 flex flex-col flex-grow relative z-20 text-center bg-white dark:bg-surface-dark'>
    <!-- Title -->
    <div class='block flex-grow'>
      <h3
        class='text-sm md:text-lg font-bold text-gray-900 dark:text-white mb-2 line-clamp-2 transition-colors uppercase tracking-wide' style="font-family: var(--font-family, 'Fjalla One', sans-serif); letter-spacing: 0.5px;">
        {name}
      </h3>
    </div>

    <!-- Price -->
    <div class='flex flex-col items-center justify-center gap-0.5 md:gap-1 mb-4 md:mb-5'>
      <div class='text-lg md:text-xl font-black text-red-600'>
        {formattedPrice}
      </div>
      {
        originalPrice && (
          <span class='text-xs md:text-sm text-gray-400 line-through decoration-gray-400 font-medium'>
            {formatCurrency(originalPrice)}
          </span>
        )
      }
    </div>

    <!-- Buttons (Stacked on Mobile, Side-by-side on Desktop) -->
    <div class='mt-auto flex flex-col xl:flex-row gap-2'>
      <!-- Add to Cart (Transparent Border) -->
      <button
        type='button'
        data-product={JSON.stringify({ id, name, price: finalPrice, image })}
        style="border-color: var(--color-cart-button); color: var(--color-cart-button);"
        class='btn-add-cart flex-1 flex items-center justify-center py-2.5 px-2 rounded-none border-2 bg-transparent hover:bg-[var(--color-cart-button)] hover:!text-white text-[10px] sm:text-xs font-black transition-all uppercase tracking-wider'>
        ADD TO CART
      </button>

      <!-- Buy Now (Solid) -->
      <button
        type='button'
        data-product={JSON.stringify({ id, name, price: finalPrice, image })}
        style="background-color: var(--color-cart-button);"
        class='btn-buy-now flex-1 flex items-center justify-center py-2.5 px-2 rounded-none text-white text-[10px] sm:text-xs font-black transition-all hover:opacity-90 uppercase tracking-wider'>
        BUY NOW
      </button>
    </div>
  </div>
</div>

<script>
  import { addToCart } from '../lib/cart';

  function initLuxuryButtons() {
    // Only bind if they haven't been bound yet or if needed
    document.querySelectorAll('.btn-add-cart').forEach((btn) => {
      // remove existing listeners to prevent duplicate if any
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const data = target.dataset.product;
        if (data) {
          const product = JSON.parse(data);
          addToCart(product, 1);
        }
      });
    });

    document.querySelectorAll('.btn-buy-now').forEach((btn) => {
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(newBtn, btn);

      newBtn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const data = target.dataset.product;
        if (data) {
          const product = JSON.parse(data);
          addToCart(product, 1);
          window.location.href = '/checkout';
        }
      });
    });
  }

  // Run on first load
  initLuxuryButtons();
  // Run on view transition
  document.addEventListener('astro:after-swap', initLuxuryButtons);
</script>
